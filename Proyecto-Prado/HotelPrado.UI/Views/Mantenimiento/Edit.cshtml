@model HotelPrado.Abstracciones.Modelos.Mantenimiento.MantenimientoDTO

@{
    ViewBag.Title = "Editar Mantenimiento";
}

<style>
    .card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
    }

    .form-label {
        font-weight: 500;
        margin-bottom: .5rem;
        font-size: 0.9em;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border: 1px solid #dee2e6;
        padding: .5rem .75rem;
        font-size: 0.9em;
    }

        .form-control:focus, .form-select:focus {
            border-color: #80bdff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
        }

    .text-danger {
        font-size: 0.8rem;
        margin-top: .25rem;
    }
</style>

<div class="container-fluid px-4">
    <div class="row my-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Editar Mantenimiento</h2>
                <a href="@Url.Action("IndexMantenimiento")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
                        @Html.HiddenFor(model => model.IdMantenimiento)

                        <div class="row g-4">
                            <div class="col-md-12 mb-3">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Descripcion, "Descripción", new { @class = "form-label" })
                                    @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = "3" })
                                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Estado, "Estado", new { @class = "form-label" })
                                    @Html.DropDownListFor(model => model.Estado,
                                        (SelectList)ViewBag.Estados,
                                        new { @class = "form-select" })
                                    @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-group">
                                    <label class="form-label">Tipo</label>
                                    <select id="tipoSeleccionado" name="tipoSeleccionado" class="form-select" onchange="toggleTipo()">
                                        <option value="">Seleccione un tipo</option>
                                        <option value="Departamento" @(ViewBag.TipoSeleccionado == "Departamento" ? "selected" : "")>Departamento</option>
                                        <option value="Habitacion" @(ViewBag.TipoSeleccionado == "Habitacion" ? "selected" : "")>Habitación</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3" id="departamentoGroup" style="display: @(ViewBag.TipoSeleccionado == "Habitacion" ? "none" : "block");">
                                <div class="form-group">
                                    <label class="form-label">Departamento</label>
                                    @Html.DropDownListFor(model => model.idDepartamento,
                                        (SelectList)ViewBag.Departamentos,
                                        new { @class = "form-select", id = "idDepartamento" })
                                    @Html.ValidationMessageFor(model => model.idDepartamento, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="col-md-6 mb-3" id="habitacionGroup" style="display: @(ViewBag.TipoSeleccionado == "Habitacion" ? "block" : "none");">
                                <div class="form-group">
                                    <label class="form-label">Habitación</label>
                                    @Html.DropDownListFor(model => model.idHabitacion,
                                        (SelectList)ViewBag.Habitaciones,
                                        new { @class = "form-select", id = "idHabitacion" })
                                    @Html.ValidationMessageFor(model => model.idHabitacion, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save me-2"></i>Guardar Cambios
                                    </button>
                                    <a href="@Url.Action("IndexMantenimiento")" class="btn btn-secondary">
                                        <i class="fas fa-times me-2"></i>Cancelar
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        function toggleTipo() {
            var tipo = document.getElementById("tipoSeleccionado").value;
            var departamentoGroup = document.getElementById("departamentoGroup");
            var habitacionGroup = document.getElementById("habitacionGroup");
            var idDepartamento = document.getElementById("idDepartamento");
            var idHabitacion = document.getElementById("idHabitacion");

            if (tipo === "Departamento") {
                departamentoGroup.style.display = "block";
                habitacionGroup.style.display = "none";
                idHabitacion.value = "0"; // Reset habitación
                idDepartamento.required = true;
                idHabitacion.required = false;
            } else if (tipo === "Habitacion") {
                departamentoGroup.style.display = "none";
                habitacionGroup.style.display = "block";
                idDepartamento.value = "0"; // Reset departamento
                idDepartamento.required = false;
                idHabitacion.required = true;
            } else {
                departamentoGroup.style.display = "none";
                habitacionGroup.style.display = "none";
                idDepartamento.value = "0";
                idHabitacion.value = "0";
                idDepartamento.required = false;
                idHabitacion.required = false;
            }
        }

        // Inicializar al cargar la página
        document.addEventListener("DOMContentLoaded", function () {
            toggleTipo();
        });
    </script>
}
