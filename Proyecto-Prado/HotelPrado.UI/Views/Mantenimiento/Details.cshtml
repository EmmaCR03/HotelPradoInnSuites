@model HotelPrado.Abstracciones.Modelos.Mantenimiento.MantenimientoDTO

@{
    ViewBag.Title = "Detalles del Mantenimiento";
}

<style>
    .card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
    }

    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid rgba(0,0,0,.05);
        padding: 1rem 1.5rem;
    }

    .detail-label {
        font-weight: 600;
        color: #6c757d;
        font-size: 0.9em;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
    }

    .detail-value {
        font-size: 1em;
        color: #212529;
        margin-bottom: 1.5rem;
    }

    .badge {
        font-weight: 500;
        padding: 0.5em 1em;
    }
</style>

<div class="container-fluid px-4">
    <div class="row my-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Detalles del Mantenimiento</h2>
                <a href="@Url.Action("IndexMantenimiento")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-4">
                                <div class="detail-label">ID Mantenimiento</div>
                                <div class="detail-value">@Html.DisplayFor(model => model.IdMantenimiento)</div>
                            </div>

                            <div class="mb-4">
                                <div class="detail-label">Departamento</div>
                                <div class="detail-value">@Html.DisplayFor(model => model.DepartamentoNombre)</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-4">
                                <div class="detail-label">Estado</div>
                                <div class="detail-value">
                                    <span class="badge rounded-pill @(Model.Estado == "Completado" ? "bg-success" :
                                                                    Model.Estado == "En Proceso" ? "bg-warning" :
                                                                    Model.Estado == "Pendiente" ? "bg-danger" : "bg-secondary")">
                                        @Model.Estado
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="mb-4">
                                <div class="detail-label">Descripción</div>
                                <div class="detail-value">@Html.DisplayFor(model => model.Descripcion)</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2 justify-content-end">
                        <a href="@Url.Action("Edit", new { id = Model.IdMantenimiento })" class="btn btn-primary">
                            <i class="fas fa-edit me-2"></i>Editar
                        </a>
                        <a href="@Url.Action("IndexMantenimiento")" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 