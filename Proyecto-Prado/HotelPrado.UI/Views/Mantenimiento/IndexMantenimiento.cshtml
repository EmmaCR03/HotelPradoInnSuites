@model IEnumerable<HotelPrado.Abstracciones.Modelos.Mantenimiento.MantenimientoDTO>

@{
    ViewBag.Title = "Gestión de Mantenimientos";
}

<style>
    .table th {
        font-weight: 600;
        font-size: 0.9em;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .table td {
        vertical-align: middle;
        font-size: 0.9em;
    }

    .badge {
        font-weight: 500;
        padding: 0.5em 1em;
    }

    .btn-group .btn {
        padding: 0.25rem 0.5rem;
    }

    .btn-group .btn i {
        font-size: 0.875rem;
    }

    .card {
        border: none;
        border-radius: 8px;
    }

    .card-body {
        padding: 1.5rem;
    }
</style>

<div class="container-fluid px-4">
    <div class="row my-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Gestión de Mantenimientos</h2>
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="fas fa-plus-circle me-2"></i>Nuevo Mantenimiento
                </a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.IdMantenimiento)</th>
                                    <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
                                    <th>@Html.DisplayNameFor(model => model.Estado)</th>
                                    <th>@Html.DisplayNameFor(model => model.DepartamentoNombre)</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(modelItem => item.IdMantenimiento)</td>
                                        <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                                        <td>
                                            <span class="badge rounded-pill @(item.Estado == "Completado" ? "bg-success" : 
                                                                            item.Estado == "En Proceso" ? "bg-warning" : 
                                                                            item.Estado == "Pendiente" ? "bg-danger" : "bg-secondary")">
                                                @item.Estado
                                            </span>
                                        </td>
                                        <td>@Html.DisplayFor(modelItem => item.DepartamentoNombre)</td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Edit", new { id = item.IdMantenimiento })" class="btn btn-sm btn-outline-primary" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="@Url.Action("Details", new { id = item.IdMantenimiento })" class="btn btn-sm btn-outline-info" title="Detalles">
                                                    <i class="fas fa-info-circle"></i>
                                                </a>
                                                <!-- <a href="@Url.Action("Delete", new { id = item.IdMantenimiento })" class="btn btn-sm btn-outline-danger" title="Eliminar">
         <i class="fas fa-trash-alt"></i>
     </a>-->
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/your-code.js" crossorigin="anonymous"></script>
}
