@model HotelPrado.UI.Models.RegisterViewModel

@{
    ViewBag.Title = "Crear Usuario";
}

<div class="container py-4">
    <div class="card shadow-sm rounded-4">
        <div class="card-body px-5 py-4">
            <h2 class="mb-4 fw-bold text-primary">Crear Usuario</h2>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.NombreCompleto, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(model => model.NombreCompleto, new { @class = "form-control rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.NombreCompleto, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.cedula, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(model => model.cedula, new { @class = "form-control rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.cedula, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.Telefono, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(model => model.Telefono, new { @class = "form-control rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.Telefono, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.Rol, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.DropDownListFor(model => model.Rol, new SelectList(ViewBag.Roles, "Value", "Text"), "- Selecciona un rol -", new { @class = "form-select rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.Rol, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.Password, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.PasswordFor(model => model.Password, new { @class = "form-control rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(model => model.ConfirmPassword, htmlAttributes: new { @class = "form-label fw-semibold" })
                        @Html.PasswordFor(model => model.ConfirmPassword, new { @class = "form-control rounded-3 shadow-sm" })
                        @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-primary fw-semibold px-4 py-2 rounded-3 shadow-sm">
                        Crear Usuario
                    </button>
                </div>
            }
        </div>
    </div>
</div>
