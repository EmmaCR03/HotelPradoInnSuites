@model HotelPrado.Abstracciones.Modelos.Colaborador.ColaboradorDTO

@{
    ViewBag.Title = "Crear Colaborador";
}

<style>
    .card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
    }

    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid rgba(0,0,0,.05);
        padding: 1rem 1.5rem;
    }

    .form-label {
        font-weight: 500;
        margin-bottom: .5rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border: 1px solid #dee2e6;
        padding: .5rem .75rem;
        font-size: 0.9rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #80bdff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
        }

    .btn-primary {
        padding: .5rem 1.5rem;
        font-weight: 500;
    }

    .btn-secondary {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
        padding: .5rem 1.5rem;
        font-weight: 500;
    }

    .text-danger {
        font-size: 0.8rem;
        margin-top: .25rem;
    }
</style>

<div class="container-fluid px-4">
    <div class="row my-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Crear Nuevo Colaborador</h2>
                <a href="@Url.Action("IndexColaborador")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    @using (Html.BeginForm("Create", "Colaborador", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="row g-4">
                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.NombreColaborador, new { @class = "form-label" })
                                @Html.EditorFor(model => model.NombreColaborador, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.NombreColaborador, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.PrimerApellidoColaborador, new { @class = "form-label" })
                                @Html.EditorFor(model => model.PrimerApellidoColaborador, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.PrimerApellidoColaborador, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.SegundoApellidoColaborador, new { @class = "form-label" })
                                @Html.EditorFor(model => model.SegundoApellidoColaborador, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.SegundoApellidoColaborador, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.CedulaColaborador, new { @class = "form-label" })
                                @Html.EditorFor(model => model.CedulaColaborador, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.CedulaColaborador, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.IngresoColaborador, new { @class = "form-label" })
                                @Html.EditorFor(model => model.IngresoColaborador, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.IngresoColaborador, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.PuestoColaborador, new { @class = "form-label" })
                                @Html.EditorFor(model => model.PuestoColaborador, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.PuestoColaborador, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(model => model.EstadoLaboral, new { @class = "form-label" })
                                @Html.DropDownListFor(model => model.EstadoLaboral,
                                    new SelectList(new List<SelectListItem> {
                                        new SelectListItem { Value = "Activo", Text = "Activo" },
                                        new SelectListItem { Value = "De Vacaciones", Text = "De Vacaciones" },
                                        new SelectListItem { Value = "Incapacitado", Text = "Incapacitado" },
                                        new SelectListItem { Value = "Licencia con goce de salario", Text = "Licencia con goce de salario" },
                                        new SelectListItem { Value = "Licencia sin goce de salario", Text = "Licencia sin goce de salario" },
                                        new SelectListItem { Value = "Permiso Especial", Text = "Permiso Especial" }
                                    }, "Value", "Text"),
                                    "Seleccione un tipo",
                                    new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.EstadoLaboral, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-12 mt-4 d-flex justify-content-end">
                                <input type="submit" value="Crear Colaborador" class="btn btn-primary" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
