@model HotelPrado.Abstracciones.Modelos.Colaborador.ColaboradorDTO

<div class="card mt-5">
    <div class="card-header">
        <h2>Editar Colaborador</h2>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Edit", "Colaborador", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(model => model.IdColaborador)

            <div class="form-group row">
                @Html.LabelFor(model => model.NombreColaborador, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.EditorFor(model => model.NombreColaborador, new { htmlAttributes = new { @class = "form-control w-100" } })
                    @Html.ValidationMessageFor(model => model.NombreColaborador, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group row">
                @Html.LabelFor(model => model.PrimerApellidoColaborador, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.EditorFor(model => model.PrimerApellidoColaborador, new { htmlAttributes = new { @class = "form-control w-100" } })
                    @Html.ValidationMessageFor(model => model.PrimerApellidoColaborador, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group row">
                @Html.LabelFor(model => model.SegundoApellidoColaborador, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.EditorFor(model => model.SegundoApellidoColaborador, new { htmlAttributes = new { @class = "form-control w-100" } })
                    @Html.ValidationMessageFor(model => model.SegundoApellidoColaborador, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group row">
                @Html.LabelFor(model => model.CedulaColaborador, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.EditorFor(model => model.CedulaColaborador, new { htmlAttributes = new { @class = "form-control w-100" } })
                    @Html.ValidationMessageFor(model => model.CedulaColaborador, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group row">
                @Html.LabelFor(model => model.IngresoColaborador, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.EditorFor(model => model.IngresoColaborador, new { htmlAttributes = new { @class = "form-control w-100" } })
                    @Html.ValidationMessageFor(model => model.IngresoColaborador, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group row">
                @Html.LabelFor(model => model.PuestoColaborador, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.DropDownListFor(model => model.PuestoColaborador, (SelectList)ViewBag.PuestoColaborador, "Seleccione un puesto", new { @class = "form-control w-100" })
                    @Html.ValidationMessageFor(model => model.PuestoColaborador, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group row">
                @Html.LabelFor(model => model.EstadoLaboral, new { @class = "control-label col-md-3 text-wrap" })
                <div class="col-md-9 w-100">
                    @Html.DropDownListFor(model => model.EstadoLaboral, (SelectList)ViewBag.EstadoLaboral, "Seleccione un estado laboral", new { @class = "form-control w-100" })
                    @Html.ValidationMessageFor(model => model.EstadoLaboral, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-9 offset-md-3 w-100">
                    <input type="submit" value="Guardar Cambios" class="btn btn-primary w-100" />
                </div>
            </div>
        </div>
        }
        <div>
            @Html.ActionLink("Volver", "IndexColaborador", null, new { @class = "btn btn-secondary w-100" })
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

