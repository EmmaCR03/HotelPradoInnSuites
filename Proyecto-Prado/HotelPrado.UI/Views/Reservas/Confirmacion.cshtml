@{
    ViewBag.Title = "Solicitud de Reserva Enviada";
}

<div class="container mt-5 text-center">
    <div class="card shadow-lg border-0 rounded">
        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0"><i class="fas fa-clock"></i> Solicitud de Reserva Enviada</h2>
        </div>
        <div class="card-body p-4">
            <div class="mb-4">
                <i class="fas fa-hourglass-half fa-4x text-warning mb-3"></i>
            </div>
            <p class="lead text-secondary">¡Su solicitud de reserva ha sido enviada exitosamente!</p>
            <p class="text-muted">
                Nuestro equipo de administración revisará su solicitud y verificará la disponibilidad. 
                Le notificaremos por correo electrónico una vez que se haya revisado su solicitud.
            </p>
            <div class="alert alert-info mt-4">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Estado:</strong> Su solicitud está pendiente de revisión. 
                Puede ver el estado de sus reservas en "Mis Reservas".
            </div>
            <div class="mt-4">
                @Html.ActionLink("Ir a Inicio", "Index", "Home", null, new { @class = "btn btn-primary btn-lg shadow" })
            </div>
            <div class="mt-3">
                @Html.ActionLink("Ver Mis Reservas", "ReservasUsuario", "Reservas", null, new { @class = "btn btn-outline-primary btn-lg shadow" })
            </div>
        </div>
    </div>
</div>