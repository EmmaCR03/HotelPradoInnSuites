@{
    ViewBag.Title = "Confirmación de Reserva";
}

<div class="container mt-5 text-center">
    <div class="card shadow-lg border-0 rounded">
        <div class="card-header bg-success text-white">
            <h2 class="mb-0"><i class="fas fa-check-circle"></i> Reserva Confirmada</h2>
        </div>
        <div class="card-body p-4">
            <p class="lead text-secondary">¡Su reserva ha sido creada exitosamente!</p>
            <p class="text-muted">Recibirá un correo con los detalles de su reserva.</p>
            <div class="mt-4">
                @Html.ActionLink("Ir a Inicio", "Index", "Home", null, new { @class = "btn btn-primary btn-lg shadow" })
            </div>
            <div class="mt-4">
                @Html.ActionLink("Ver Reservas", "ReservasUsuario", "Reservas", null, new { @class = "btn btn-succes btn-lg shadow" })
            </div>
        </div>
    </div>
</div>