@model IEnumerable<HotelPrado.Abstracciones.Modelos.Reservas.ReservasDTO>

@{
    ViewBag.Title = "Mis Reservas";
}

<div class="container-fluid mt-4">
    <h2 class="text-center mb-4 text-primary fw-bold">Mis Reservas</h2>

    <div class="table-responsive">
        <table class="table table-bordered table-hover shadow-lg w-100">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Id Reserva</th>
                    <th>Nombre Cliente</th>
                    <th>Habitación</th>
                    <th>Cantidad Personas</th>
                    <th>Fecha Inicio</th>
                    <th>Fecha Final</th>
                    <th>Estado</th>
                    <th>Monto Total</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int count = 1;
                    foreach (var reserva in Model)
                    {
                        <tr>
                            <td>@count</td>
                            <td>@reserva.IdReserva</td>
                            <td>@reserva.NombreCliente</td>
                            <td>@reserva.IdHabitacion</td>
                            <td>@reserva.cantidadPersonas</td>
                            <td>@(reserva.FechaInicio.HasValue ? reserva.FechaInicio.Value.ToString("dd/MM/yyyy") : "No definida")</td>
                            <td>@(reserva.FechaFinal.HasValue ? reserva.FechaFinal.Value.ToString("dd/MM/yyyy") : "No definida")</td>
                            <td><span class="badge bg-success p-2">@reserva.EstadoReserva</span></td>
                            <td class="fw-bold text-success">₡@reserva.MontoTotal.ToString("0.00")</td>
                            <td class="text-center">
                                <a href="@Url.Action("DetalleReserva", "Reservas", new { id = reserva.IdReserva })" class="btn btn-outline-info btn-sm" title="Ver Detalles">
                                    <i class="fas fa-info-circle"></i> Detalles
                                </a>
                                <div class="d-flex justify-content-center gap-2 mt-2">
                                    <a href="@($"https://wa.me/{reserva.NumeroEmpresa}?text=Hola,%20estoy%20interesado%20en%20una%20cotizaci%C3%B3n%20del%20departamento%20")"
                                       class="btn btn-outline-success btn-sm" target="_blank">
                                        <i class="fab fa-whatsapp"></i> WhatsApp
                                    </a>
                                    <a href="@($"mailto:{reserva.CorreoEmpresa}?subject=Solicitud%20de%20cotizaci%C3%B3n&body=Hola,%20estoy%20interesado%20en%20una%20cotizaci%C3%B3n%20del%20departamento%20")"
                                       class="btn btn-outline-primary btn-sm" target="_blank">
                                        <i class="fas fa-envelope"></i> Correo
                                    </a>
                                </div>
                            </td>
                        </tr>
                        count++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center text-danger fw-bold">No tienes reservas.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://kit.fontawesome.com/a076d05399.js"></script>

<style>
    .container-fluid {
        max-width: 95%;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .table {
        font-size: 1rem;
        border-radius: 10px;
    }

        .table th, .table td {
            text-align: center;
            vertical-align: middle;
            padding: 12px;
        }

        .table thead {
            background-color: #212529;
            color: white;
        }

        .table tbody tr:hover {
            background-color: #f8f9fa;
            transition: 0.3s ease-in-out;
        }

    .btn {
        font-size: 0.85rem;
        padding: 6px 10px;
        border-radius: 8px;
    }

    .btn-outline-info:hover {
        background-color: #17a2b8;
        color: white;
    }

    .btn-outline-success:hover {
        background-color: #28a745;
        color: white;
    }

    .btn-outline-primary:hover {
        background-color: #007bff;
        color: white;
    }
</style>