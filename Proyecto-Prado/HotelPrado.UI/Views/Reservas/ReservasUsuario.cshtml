@model HotelPrado.UI.Models.ReservasUsuarioViewModel

@{
    ViewBag.Title = "Mis Reservas";
}

<div class="container-fluid mt-4 reservas-usuario-container">
    <!-- Header mejorado -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="mb-1">
                        <i class="fas fa-calendar-check me-2 text-primary"></i>Mis Reservas
                    </h1>
                    <p class="text-muted mb-0">Gestiona y consulta todas tus reservas</p>
                </div>
                @if (Model.TieneReservas)
                {
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-end">
                            <div class="h4 mb-0 text-primary">@Model.TotalReservas</div>
                            <small class="text-muted">Reserva(s)</small>
                        </div>
                        <div class="vr"></div>
                        <a href="@Url.Action("habitacionesInfo", "Habitacion")" class="btn btn-primary">
                            <i class="fas fa-plus-circle me-2"></i>Nueva Reserva
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (Model.TieneReservas)
    {
        <!-- Filtros -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-3">
                        <div class="d-flex flex-wrap align-items-center gap-3">
                            <label class="mb-0 fw-semibold">Filtrar por estado:</label>
                            <div class="btn-group" role="group">
                                <input type="radio" class="btn-check" name="filtroEstado" id="filtroTodos" value="todos" checked>
                                <label class="btn btn-outline-primary btn-sm" for="filtroTodos">
                                    <i class="fas fa-list me-1"></i>Todas
                                </label>
                                
                                <input type="radio" class="btn-check" name="filtroEstado" id="filtroConfirmadas" value="Confirmada">
                                <label class="btn btn-outline-success btn-sm" for="filtroConfirmadas">
                                    <i class="fas fa-check-circle me-1"></i>Confirmadas
                                </label>
                                
                                <input type="radio" class="btn-check" name="filtroEstado" id="filtroSolicitadas" value="Solicitada">
                                <label class="btn btn-outline-warning btn-sm" for="filtroSolicitadas">
                                    <i class="fas fa-hourglass-half me-1"></i>Solicitadas
                                </label>
                                
                                <input type="radio" class="btn-check" name="filtroEstado" id="filtroListaEspera" value="En Lista de Espera">
                                <label class="btn btn-outline-info btn-sm" for="filtroListaEspera">
                                    <i class="fas fa-clock me-1"></i>En Espera
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cards de reservas -->
        <div class="row" id="reservasContainer">
            @{
                int count = 1;
            }
            @foreach (var reserva in Model.Reservas)
            {
                var noches = reserva.FechaInicio.HasValue && reserva.FechaFinal.HasValue
                    ? (reserva.FechaFinal.Value - reserva.FechaInicio.Value).Days
                    : 0;
                
                var numeroHabitacion = reserva.NumeroHabitacion > 0 ? reserva.NumeroHabitacion.ToString() : reserva.IdHabitacion.ToString();
                var fechaInicio = reserva.FechaInicio.HasValue ? reserva.FechaInicio.Value.ToString("dd/MM/yyyy") : "N/D";
                var fechaFinal = reserva.FechaFinal.HasValue ? reserva.FechaFinal.Value.ToString("dd/MM/yyyy") : "N/D";
                var horaInicio = reserva.FechaInicio.HasValue && reserva.FechaInicio.Value.Hour != 0 
                    ? reserva.FechaInicio.Value.ToString("HH:mm") 
                    : "15:00";
                var horaFinal = reserva.FechaFinal.HasValue && reserva.FechaFinal.Value.Hour != 0 
                    ? reserva.FechaFinal.Value.ToString("HH:mm") 
                    : "11:00";
                
                var mensajeWhatsApp = $"Hola, tengo una consulta sobre mi reserva #{reserva.IdReserva}. " +
                    $"Habitación: {numeroHabitacion}, " +
                    $"Check-in: {fechaInicio} {horaInicio}, " +
                    $"Check-out: {fechaFinal} {horaFinal}, " +
                    $"Personas: {reserva.cantidadPersonas}";
                
                var mensajeCorreo = $"Hola,%0D%0A%0D%0A" +
                    $"Tengo una consulta sobre mi reserva:%0D%0A" +
                    $"ID Reserva: {reserva.IdReserva}%0D%0A" +
                    $"Habitación: {numeroHabitacion}%0D%0A" +
                    $"Check-in: {fechaInicio} {horaInicio}%0D%0A" +
                    $"Check-out: {fechaFinal} {horaFinal}%0D%0A" +
                    $"Personas: {reserva.cantidadPersonas}%0D%0A" +
                    $"Estado: {reserva.EstadoReserva}%0D%0A" +
                    $"Total: ₡{reserva.MontoTotal:N2}%0D%0A%0D%0A" +
                    $"Gracias.";
                
                var estadoClass = reserva.EstadoReserva == "Confirmada" ? "success" :
                    reserva.EstadoReserva == "Solicitada" ? "warning" :
                    reserva.EstadoReserva == "En Lista de Espera" ? "info" :
                    reserva.EstadoReserva == "Pendiente" ? "warning" :
                    reserva.EstadoReserva == "Completado" ? "info" :
                    reserva.EstadoReserva == "Rechazada" || reserva.EstadoReserva == "Cancelada" ? "danger" : "secondary";
                
                var estadoIcon = reserva.EstadoReserva == "Confirmada" ? "fa-check-circle" :
                    reserva.EstadoReserva == "Solicitada" ? "fa-hourglass-half" :
                    reserva.EstadoReserva == "En Lista de Espera" ? "fa-clock" :
                    reserva.EstadoReserva == "Pendiente" ? "fa-clock" :
                    reserva.EstadoReserva == "Completado" ? "fa-check-double" :
                    reserva.EstadoReserva == "Rechazada" || reserva.EstadoReserva == "Cancelada" ? "fa-times-circle" : "fa-question-circle";
                
                <div class="col-12 col-lg-6 col-xl-4 mb-4 reserva-card" data-estado="@reserva.EstadoReserva">
                    <div class="card h-100 shadow-sm border-0 reserva-card-inner">
                        <div class="card-header bg-white border-bottom-0 pb-0">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="badge bg-secondary">#@count</span>
                                    <h5 class="mb-1 mt-2">
                                        <i class="fas fa-door-open text-primary me-2"></i>
                                        Habitación #@numeroHabitacion
                                    </h5>
                                </div>
                                <span class="badge bg-@estadoClass bg-opacity-25 text-dark">
                                    <i class="fas @estadoIcon me-1"></i>
                                    @reserva.EstadoReserva
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(reserva.NombreCliente))
                            {
                                <p class="text-muted mb-0 small">
                                    <i class="fas fa-user me-1"></i>@reserva.NombreCliente
                                </p>
                            }
                        </div>
                        <div class="card-body">
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="reserva-info-item">
                                        <i class="fas fa-calendar-check text-success me-2"></i>
                                        <div>
                                            <small class="text-muted d-block">Check-in</small>
                                            <strong>@fechaInicio</strong>
                                            <small class="text-muted d-block">@horaInicio</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="reserva-info-item">
                                        <i class="fas fa-calendar-times text-danger me-2"></i>
                                        <div>
                                            <small class="text-muted d-block">Check-out</small>
                                            <strong>@fechaFinal</strong>
                                            <small class="text-muted d-block">@horaFinal</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="reserva-info-item">
                                        <i class="fas fa-users text-info me-2"></i>
                                        <div>
                                            <small class="text-muted d-block">Personas</small>
                                            <strong>@reserva.cantidadPersonas</strong>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="reserva-info-item">
                                        <i class="fas fa-moon text-secondary me-2"></i>
                                        <div>
                                            <small class="text-muted d-block">Noches</small>
                                            <strong>@noches</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="border-top pt-3">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-muted small">Total:</span>
                                    <span class="h5 mb-0 text-success fw-bold">
                                        <i class="fas fa-money-bill-wave me-1"></i>
                                        ₡@reserva.MontoTotal.ToString("N2")
                                    </span>
                                </div>
                                <div class="d-grid gap-2">
                                    <a href="@($"https://wa.me/{Model.NumeroEmpresa.Replace("+", "")}?text={Uri.EscapeDataString(mensajeWhatsApp)}")"
                                       class="btn btn-success btn-sm"
                                       target="_blank">
                                        <i class="fab fa-whatsapp me-2"></i>Contactar por WhatsApp
                                    </a>
                                    <a href="@($"mailto:{Model.CorreoEmpresa}?subject=Consulta sobre Reserva #{reserva.IdReserva}&body={mensajeCorreo}")"
                                       class="btn btn-outline-primary btn-sm"
                                       target="_blank">
                                        <i class="fas fa-envelope me-2"></i>Enviar Correo
                                    </a>
                                </div>
                            </div>
                            @if (reserva.EstadoReserva == "En Lista de Espera")
                            {
                                <div class="alert alert-info alert-sm mt-3 mb-0">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <small>El administrador revisará su solicitud y se comunicará con usted.</small>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                count++;
            }
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-calendar-times text-muted mb-3" style="font-size: 4rem; opacity: 0.5;"></i>
                        <h5 class="text-muted mb-2">No tienes reservas</h5>
                        <p class="text-muted small mb-4">Cuando hagas una reserva, aparecerá aquí</p>
                        <a href="@Url.Action("habitacionesInfo", "Habitacion")" class="btn btn-primary rounded-pill px-4">
                            <i class="fas fa-bed me-2"></i>Explorar Habitaciones
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
    <link href="~/Content/Reservas/reservas-usuario.css" rel="stylesheet" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Filtro por estado
            var filtros = document.querySelectorAll('input[name="filtroEstado"]');
            var reservasCards = document.querySelectorAll('.reserva-card');
            
            filtros.forEach(function(filtro) {
                filtro.addEventListener('change', function() {
                    var estadoFiltro = this.value;
                    
                    reservasCards.forEach(function(card) {
                        var estadoReserva = card.getAttribute('data-estado');
                        
                        if (estadoFiltro === 'todos' || estadoReserva === estadoFiltro) {
                            card.style.display = '';
                            card.classList.add('fade-in');
                        } else {
                            card.style.display = 'none';
                        }
                    });
                });
            });
        });
    </script>
}
