@model IEnumerable<HotelPrado.Abstracciones.Modelos.Reservas.ReservasDTO>

@{
    ViewBag.Title = "Mis Reservas";
}

<div class="container-fluid mt-4">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-gradient-primary text-white py-3">
            <h2 class="text-center mb-0 fw-bold"><i class="fas fa-calendar-check me-2"></i>Mis Reservas</h2>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light-primary">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Cliente</th>
                            <th>Habitación</th>
                            <th>Personas</th>
                            <th>Check-In</th>
                            <th>Check-Out</th>
                            <th>Estado</th>
                            <th>Total</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int count = 1;
                            foreach (var reserva in Model)
                            {
                                <tr class="border-top">
                                    <td class="ps-4 fw-semibold">@count</td>
                                   
                                    <td>@reserva.NombreCliente</td>
                                    <td class="fw-medium">@reserva.IdHabitacion</td>
                                    <td class="fw-medium">@reserva.cantidadPersonas</td>
                                    <td><span class="d-inline-block px-2 py-1 rounded-3 bg-light">@(reserva.FechaInicio.HasValue ? reserva.FechaInicio.Value.ToString("dd/MM/yyyy") : "N/D")</span></td>
                                    <td><span class="d-inline-block px-2 py-1 rounded-3 bg-light">@(reserva.FechaFinal.HasValue ? reserva.FechaFinal.Value.ToString("dd/MM/yyyy") : "N/D")</span></td>
                                    <td>
                                        @{
                                            var estadoClass = reserva.EstadoReserva == "Confirmada" ? "bg-success" :
                                                            reserva.EstadoReserva == "Pendiente" ? "bg-warning" : "bg-secondary";
                                        }
                                        <span class="badge @estadoClass bg-opacity-25 text-dark p-2 rounded-pill">
                                            <i class="fas fa-circle small me-1" style="font-size: 0.5rem; vertical-align: middle;"></i>
                                            @reserva.EstadoReserva
                                        </span>
                                    </td>
                                    <td class="fw-bold text-success">₡@reserva.MontoTotal.ToString("0.00")</td>
                                    <td class="pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="@($"https://wa.me/{reserva.NumeroEmpresa}?text=Hola,%20estoy%20interesado%20en%20una%20cotizaci%C3%B3n%20del%20departamento%20")"
                                               class="btn btn-sm btn-success rounded-pill px-3 d-flex align-items-center"
                                               target="_blank">
                                                <i class="fab fa-whatsapp me-1"></i> WhatsApp
                                            </a>
                                            <a href="@($"mailto:{reserva.CorreoEmpresa}?subject=Solicitud%20de%20cotizaci%C3%B3n&body=Hola,%20estoy%20interesado%20en%20una%20cotizaci%C3%B3n%20del%20departamento%20")"
                                               class="btn btn-sm btn-primary rounded-pill px-3 d-flex align-items-center"
                                               target="_blank">
                                                <i class="fas fa-envelope me-1"></i> Correo
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                count++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center py-4">
                                    <div class="d-flex flex-column align-items-center justify-content-center">
                                        <i class="fas fa-calendar-times text-muted mb-3" style="font-size: 3rem;"></i>
                                        <h5 class="text-muted mb-2">No tienes reservas</h5>
                                        <p class="text-muted small">Cuando hagas una reserva, aparecerá aquí</p>
                                        <a href="#" class="btn btn-primary mt-2 rounded-pill px-4">Explorar habitaciones</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #3a7bd5 0%, #00d2ff 100%);
    }

    .bg-light-primary {
        background-color: rgba(58, 123, 213, 0.1);
    }

    .card {
        border: none;
        overflow: hidden;
    }

    .table {
        font-size: 0.95rem;
    }

        .table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            color: #4a5568;
        }

        .table td {
            padding: 1rem 0.5rem;
        }

        .table tr:not(:last-child) {
            border-bottom: 1px solid #edf2f7;
        }

        .table tr:hover {
            background-color: #f8fafc !important;
        }

    .badge {
        font-weight: 500;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .btn {
        transition: all 0.2s ease;
        font-weight: 500;
    }

    .btn-sm {
        padding: 0.35rem 0.75rem;
        font-size: 0.8rem;
    }

    .btn-success {
        background-color: #25D366;
        border-color: #25D366;
    }

    .btn-primary {
        background-color: #3a7bd5;
        border-color: #3a7bd5;
    }

    .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>