@model HotelPrado.UI.Models.LoginViewModel
@{
    ViewBag.Title = "Iniciar sesión";
}

<main class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg border-0 p-5 w-100" style="max-width: 1200px; border-radius: 25px;">
        <h2 class="text-center text-dark fw-bold mb-5 fs-2">@ViewBag.Title</h2>

        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="row g-4">
                <div class="col-md-6">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold text-dark fs-5" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", placeholder = "Correo electrónico" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold text-dark fs-5" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg", placeholder = "Contraseña" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-check mt-4">
                @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.RememberMe, new { @class = "form-check-label text-dark" })
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3">Iniciar sesión</button>
            </div>

            <div class="text-center mt-4">
                @Html.ActionLink("¿No tienes cuenta? Regístrate aquí", "Register", null, new { @class = "text-decoration-none text-dark fw-semibold" })
            </div>
        }
    </div>
</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
