@model HotelPrado.Abstracciones.Modelos.Citas.CitasDTO

@{
    ViewBag.Title = "Edit";
}

<h2>Edit</h2>


@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>CitasDTO</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.IdCita)
        @Html.HiddenFor(model => model.IdDepartamento)

        <div class="form-group">
            @Html.LabelFor(model => model.IdColaborador, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(
    model => model.IdColaborador,
    ViewBag.Colaborador as List<SelectListItem> ?? new List<SelectListItem>(), // Evita errores si ViewBag.Colaborador es null
    "Seleccione un colaborador",
    new { @class = "form-control" }
)

                @Html.ValidationMessageFor(model => model.IdColaborador, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.FechaHoraInicio, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.FechaHoraInicio, new { @class = "form-control", id = "fechaInicio" })
                @Html.ValidationMessageFor(model => model.FechaHoraInicio, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.FechaHoraFin, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.FechaHoraFin, new { @class = "form-control", id = "fechaFin" })
                @Html.ValidationMessageFor(model => model.FechaHoraFin, "", new { @class = "text-danger" })
            </div>
        </div>





        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Save" class="btn btn-default" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Back to List", "IndexCitas")
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
    flatpickr("#fechaInicio", {
        enableTime: true,
        dateFormat: "Y-m-d H:i",
        time_24hr: true,
        defaultDate: "@(Model.FechaHoraInicio.HasValue ? Model.FechaHoraInicio.Value.ToString("yyyy-MM-dd HH:mm") : "")"
    });

    flatpickr("#fechaFin", {
        enableTime: true,
        dateFormat: "Y-m-d H:i",
        time_24hr: true,
        defaultDate: "@(Model.FechaHoraFin.HasValue ? Model.FechaHoraFin.Value.ToString("yyyy-MM-dd HH:mm") : "")"
    });
    </script>

}

