                            <img src="~/Img/images/FOTOS/IMG_7632.JPG" class="blog-img img-fluid rounded-4" style="height: 400px; width: auto;" alt="img">
                            <div class="position-absolute bottom-0 p-5">
                                <a href="#"><span class="bg-secondary text-body m-0 px-2 py-1 rounded-2 fs-6">Hotel</span></a>
                                <h4 class="display-6 fw-normal mt-2"><a href="index.html"></a></h4>
                                <p class="m-0 align-items-center">
