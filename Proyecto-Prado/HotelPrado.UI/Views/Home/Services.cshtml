        <path d="M6 5h2v14H6V5zm10 0h2v14h-2V5zm-8 4h4v6H8V9zm6 0h4v6h-4V9z" />
    </symbol>

    <symbol id="car-icon" viewBox="0 0 24 24">
        <path d="M19 15h1v3a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2v-1H8v1a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-3h1l1.5-5h15L19 15zm-9-1a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm8 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM4.5 8L3 13h18l-1.5-5h-15z" />
