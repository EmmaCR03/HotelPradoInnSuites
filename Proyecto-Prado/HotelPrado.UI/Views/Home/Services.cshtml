    <symbol id="dining-icon" viewBox="0 0 24 24">
        <path d="M18 3v2h-2v3h2v2h-2v3h2v2h-8v2h-2v2H8v-2H6v-2h2v-2h2V3h8zm-2 2h-4v8h4V5z" />
    </symbol>
</svg>