@{
    Layout = null;
    var returnUrl = ViewBag.ReturnUrl as string ?? "/";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión - Hotel Prado</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 2rem; max-width: 400px; margin: 2rem auto; background: #f5f5f5; }
        h1 { font-size: 1.5rem; color: #333; }
        input { display: block; width: 100%; padding: 0.5rem; margin: 0.5rem 0; box-sizing: border-box; }
        button { background: #212529; color: white; border: none; padding: 0.75rem 1.5rem; cursor: pointer; width: 100%; margin-top: 0.5rem; }
        button:hover { background: #6D7BB8; }
        .link { margin-top: 1rem; }
        .link a { color: #007bff; }
        .error { color: #c00; font-size: 0.9rem; }
    </style>
</head>
<body>
    <h1>Iniciar sesión</h1>
    @if (ViewBag.ErrorMessage != null)
    {
        <p class="error">@ViewBag.ErrorMessage</p>
    }
    else
    {
        <p>Introduzca sus datos para iniciar sesión.</p>
    }
    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = returnUrl }, FormMethod.Post, new { id = "formLogin" }))
    {
        @Html.AntiForgeryToken()
        <label>Correo</label>
        <input type="email" name="Email" required placeholder="correo@ejemplo.com" />
        <label>Contraseña</label>
        <input type="password" name="Password" required />
        <label style="display:flex;align-items:center;gap:0.5rem;">
            <input type="checkbox" name="RememberMe" value="true" style="width:auto;" />
            Recordarme
        </label>
        <button type="submit">Entrar</button>
    }
    <div class="link">
        <a href="@Url.Action("Register", "Account")">Registrarse</a> |
        <a href="/">Inicio</a> |
        <a href="/Ping">Ping</a>
    </div>
</body>
</html>
