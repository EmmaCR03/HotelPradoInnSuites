@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrarse - Hotel Prado</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 2rem; max-width: 400px; margin: 2rem auto; background: #f5f5f5; }
        h1 { font-size: 1.5rem; color: #333; }
        input { display: block; width: 100%; padding: 0.5rem; margin: 0.5rem 0; box-sizing: border-box; }
        button { background: #212529; color: white; border: none; padding: 0.75rem 1.5rem; cursor: pointer; width: 100%; margin-top: 0.5rem; }
        button:hover { background: #6D7BB8; }
        .link { margin-top: 1rem; }
        .link a { color: #007bff; }
        .ok { color: green; font-size: 0.9rem; }
    </style>
</head>
<body>
    <h1>Registrarse</h1>
    <p class="ok">Si ves esta página, la app corre. El formulario envía a Account/Register.</p>
    <p><a href="@Url.Action("Register", "Account")">Ir a la página de registro completa →</a></p>
    <div class="link">
        <a href="/Entrar">Iniciar sesión</a> |
        <a href="/">Inicio</a> |
        <a href="/Ping">Ping</a>
    </div>
</body>
</html>
