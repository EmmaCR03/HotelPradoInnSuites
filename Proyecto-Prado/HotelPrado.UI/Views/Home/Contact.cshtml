@{
    ViewBag.Title = "Contact";
}

<div class="container d-flex justify-content-center align-items-center py-5" style="min-height: 80vh;">
    <div class="service text-center rounded-4 p-5 bg-light shadow-lg">
        <div class="position-relative mb-4">
            <svg class="color" width="70" height="70"><use xlink:href="#phone"></use></svg>
        </div>
        <h2 class="display-4 fw-bold text-primary mb-4" style="font-family: 'Roboto', sans-serif;">Contáctanos</h2>
        <p class="text-muted mb-5" style="font-size: 1.2rem;">
            ¿Tienes dudas o necesitas ayuda con alguno de nuestros servicios?
            Estamos aquí para ti. Puedes llamarnos directamente al <strong class="text-dark">2256-0106</strong>,
            enviarnos un correo a <strong class="text-dark">info@pradoinn.com</strong>, o escribirnos por nuestras redes sociales.
            ¡Queremos que tu experiencia sea lo más cómoda posible!
        </p>

        <ul class="list-unstyled mb-5">
            <li class="mb-3 d-flex justify-content-center align-items-center">
                <svg class="me-3" width="18" height="18"><use xlink:href="#phone"></use></svg>
                <span class="fs-5 text-dark">2256-0106</span>
            </li>
            <li class="d-flex justify-content-center align-items-center">
                <svg class="me-3" width="18" height="18"><use xlink:href="#email"></use></svg>
                <span class="fs-5 text-dark">info@pradoinn.com</span>
            </li>
        </ul>

        <ul class="social-links d-flex justify-content-center list-unstyled">
            <li class="social me-4">
                <a href="https://www.facebook.com/share/19uV5QTfRa/?mibextid=LQQJ4d">
                    <svg class="social" width="25" height="25"><use xlink:href="#facebook"></use></svg>
                </a>
            </li>
            <li class="social ms-4">
                <a href="#">
                    <svg class="social" width="25" height="25"><use xlink:href="#instagram"></use></svg>
                </a>
            </li>
        </ul>
    </div>
</div>

<style>
    .service {
        background: linear-gradient(145deg, #ffffff, #f0f4f8);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

        .service h2 {
            font-size: 2.5rem;
            color: #0275d8;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

    .social a {
        transition: transform 0.3s ease;
    }

        .social a:hover {
            transform: scale(1.1);
        }

    .social svg {
        fill: #0275d8;
    }

    .social a:hover svg {
        fill: #ff6347;
    }

    .service p {
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .list-unstyled li {
        font-size: 1.1rem;
        color: #333;
    }
</style>
