@model HotelPrado.Abstracciones.Modelos.Departamento.DepartamentoDTO

@{
    ViewBag.Title = "Editar Departamento";
}

<style>
    :root {
        --hotel-primary: #6D7BB8;
        --hotel-gold: #D4AF37;
        --hotel-dark: #2c3e50;
    }

    .edit-container {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: calc(100vh - 200px);
        padding: 2rem 0;
    }

    .page-header {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .page-header h1 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--hotel-dark);
        margin-bottom: 0.5rem;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .form-section {
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid #e9ecef;
    }

    .form-section:last-child {
        border-bottom: none;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--hotel-primary);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .section-title i {
        font-size: 1.1rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: var(--hotel-dark);
        margin-bottom: 0.5rem;
        display: block;
        font-size: 0.95rem;
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 2px solid #dee2e6;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        width: 100%;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--hotel-primary);
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(109, 123, 184, 0.25);
    }

    .form-control[readonly] {
        background-color: #f8f9fa;
        cursor: not-allowed;
    }

    .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
        border: 2px solid #dee2e6;
        transition: all 0.3s ease;
    }

    .checkbox-wrapper:hover {
        background: #e9ecef;
        border-color: var(--hotel-primary);
    }

    .checkbox-wrapper input[type="checkbox"] {
        width: 24px;
        height: 24px;
        cursor: pointer;
        accent-color: var(--hotel-primary);
    }

    .checkbox-wrapper label {
        margin: 0;
        cursor: pointer;
        font-weight: 500;
        color: var(--hotel-dark);
        flex: 1;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 2px solid #e9ecef;
    }

    .form-actions .btn {
        min-width: 200px;
        padding: 0.75rem 1.5rem;
        justify-content: center;
    }

    .btn {
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--hotel-primary), #5a6ba5);
        color: white;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #5a6ba5, var(--hotel-primary));
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(109, 123, 184, 0.3);
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
    }

    .btn-secondary:hover {
        background: #5a6268;
        transform: translateY(-2px);
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 0.25rem;
        display: block;
    }

    .alert-danger {
        background: #fee;
        border: 2px solid #dc3545;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        color: #721c24;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -0.75rem;
    }

    .col-md-6 {
        flex: 0 0 50%;
        max-width: 50%;
        padding: 0 0.75rem;
    }

    .col-md-12 {
        flex: 0 0 100%;
        max-width: 100%;
        padding: 0 0.75rem;
    }

    @@media (max-width: 768px) {
        .col-md-6 {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="edit-container">
    <div class="container-fluid">
        <!-- Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h1><i class="fas fa-edit me-2" style="color: var(--hotel-primary);"></i>Editar Departamento</h1>
                    <p class="text-muted mb-0">Modifica la información del departamento</p>
                </div>
                <a href="@Url.Action("IndexDepartamentos")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Volver a la Lista
                </a>
            </div>
        </div>

        @if (ViewBag.mensaje != null)
        {
            <div class="alert alert-danger mb-4" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.mensaje
            </div>
        }
        @using (Html.BeginForm("Edit", "Departamento", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
            @Html.HiddenFor(model => model.IdDepartamento)
            @Html.HiddenFor(model => model.IdCliente)

            <div class="form-card">
                <!-- Información Básica -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-info-circle"></i>
                        Información Básica
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(model => model.Nombre, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control", placeholder = "Nombre del departamento" } })
                                @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(model => model.NumeroDepartamento, new { @class = "form-label" })
                                @Html.EditorFor(model => model.NumeroDepartamento, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", placeholder = "Opcional. Dejar vacío para sin número" } })
                                @Html.ValidationMessageFor(model => model.NumeroDepartamento, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                @Html.LabelFor(model => model.Descripcion, new { @class = "form-label" })
                                @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = "4", placeholder = "Descripción detallada del departamento" })
                                @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Configuración del Departamento -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-cog"></i>
                        Configuración
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(model => model.IdTipoDepartamento, new { @class = "form-label" })
                                @Html.DropDownListFor(
                                    model => model.IdTipoDepartamento,
                                    (SelectList)ViewBag.TipoDepartamento,
                                    "Seleccione un tipo de Habitación",
                                    new { @class = "form-select" }
                                )
                                @Html.ValidationMessageFor(model => model.IdTipoDepartamento, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(model => model.Estado, new { @class = "form-label" })
                                @Html.DropDownListFor(
                                    model => model.Estado,
                                    new SelectList(new List<SelectListItem>
                                    {
                                        new SelectListItem { Value = "Disponible", Text = "Disponible" },
                                        new SelectListItem { Value = "Ocupado", Text = "Ocupado" }
                                    }, "Value", "Text", Model.Estado),
                                    "Seleccione un estado",
                                    new { @class = "form-select" }
                                )
                                @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(model => model.NumeroHabitaciones, new { @class = "form-label" })
                                @Html.EditorFor(model => model.NumeroHabitaciones, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1" } })
                                @Html.ValidationMessageFor(model => model.NumeroHabitaciones, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                @Html.LabelFor(model => model.Precio, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Precio, new { htmlAttributes = new { @class = "form-control", type = "number", step = "0.01", min = "0" } })
                                @Html.ValidationMessageFor(model => model.Precio, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <div class="checkbox-wrapper">
                                    @Html.CheckBoxFor(model => model.Amueblado, new { id = "Amueblado" })
                                    <label for="Amueblado">
                                        <i class="fas fa-couch me-2" style="color: var(--hotel-primary);"></i>
                                        Departamento Amueblado
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Acciones -->
                <div class="form-actions">
                    <a href="@Url.Action("IndexDepartamentos")" class="btn btn-secondary">
                        <i class="fas fa-times me-2"></i>Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
