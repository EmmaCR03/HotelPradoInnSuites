@model HotelPrado.Abstracciones.Modelos.Departamento.DepartamentoDTO

@{
    ViewBag.Title = "Detalles del Departamento";
}

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container py-5">
    <div class="department-detail-card">
        <div class="row g-4">
            <!-- Image Gallery -->
            <div class="col-lg-7">
                @{
                    var images = !string.IsNullOrEmpty(Model.UrlImagenes)
                        ? Model.UrlImagenes.Split(',').Select(img => { var t = (img ?? "").Trim(); var bar = t.IndexOf('|'); return bar >= 0 ? t.Substring(0, bar).Trim() : t; }).Where(img => !string.IsNullOrEmpty(img)).ToList()
                        : new List<string>();
                }

                <div id="departmentGallery" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner rounded-4">
                        @if (images.Any())
                        {
                            for (int i = 0; i < images.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@Url.Content(images[i])" class="d-block w-100 department-main-image" alt="Imagen de @Model.Nombre">
                                </div>
                            }
                        }
                        else
                        {
                            <div class="carousel-item active">
                                <img src="@Url.Content("~/imagenes/default.jpg")" class="d-block w-100 department-main-image" alt="Imagen por defecto">
                            </div>
                        }
                    </div>

                    <!-- Thumbnail Navigation -->
                    @if (images.Count > 1)
                    {
                        <div class="thumbnail-container mt-3">
                            @for (int i = 0; i < images.Count; i++)
                            {
                                <a data-bs-target="#departmentGallery" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")">
                                    <img src="@Url.Content(images[i])" class="thumbnail-img" alt="Thumbnail @(i+1)">
                                </a>
                            }
                        </div>
                    }

                    <button class="carousel-control-prev" type="button" data-bs-target="#departmentGallery" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#departmentGallery" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>

            <!-- Department Info -->
            <div class="col-lg-5">
                <div class="department-info">
                    <h1 class="department-title">@Model.Nombre</h1>


                    <p class="department-description">@Model.Descripcion</p>

                    <div class="department-highlights">
                        <div class="highlight-item">
                            <i class="fas fa-bed highlight-icon"></i>
                            <span>@Model.NumeroHabitaciones Habitaciones</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-couch highlight-icon"></i>
                            <span>@(Model.Amueblado ? "Amueblado" : "Sin amueblar")</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-ruler-combined highlight-icon"></i>
                            <span>90 m²</span>
                        </div>
                    </div>


                    <div class="action-buttons mt-5">
                        <div class="action-buttons-grid-four">
                            <a href="@($"https://wa.me/{Model.NumeroEmpresa}?text=Hola,%20estoy%20interesado%20en%20una%20cotización%20del%20departamento%20")"
                               class="btn btn-success whatsapp-btn" target="_blank">
                                <i class="fab fa-whatsapp me-2"></i> WhatsApp
                            </a>
                            <a href="@($"mailto:{Model.CorreoEmpresa}?subject=Solicitud%20de%20cotización&body=Hola,%20estoy%20interesado%20en%20una%20cotización%20del%20departamento%20")"
                               class="btn btn-primary email-btn" target="_blank">
                                <i class="fas fa-envelope me-2"></i> Correo
                            </a>
                            @Html.ActionLink("Solicitar Visita", "Create", "Citas", new { id = Model.IdDepartamento }, new { @class = "btn btn-outline-primary visit-btn" })
                            <a href="@Url.Action("IndexDepartamentosClientes", "Departamento")" class="btn btn-light back-btn">
                                <i class="fas fa-arrow-left me-2"></i> Volver
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-color: #2c3e50;
        --secondary-color: #3498db;
        --accent-color: #e74c3c;
        --light-color: #f8f9fa;
        --dark-color: #212529;
        --text-color: #495057;
        --border-radius: 0.5rem;
        --box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        --transition: all 0.3s ease;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f5f5f5;
        color: var(--text-color);
    }

    .department-detail-card {
        background: white;
        border-radius: var(--border-radius);
        box-shadow: var(--box-shadow);
        overflow: hidden;
        padding: 2rem;
    }

    .department-main-image {
        height: 400px;
        object-fit: cover;
        border-radius: var(--border-radius);
        transition: var(--transition);
    }

    .thumbnail-container {
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    .thumbnail-img {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: calc(var(--border-radius) / 2);
        cursor: pointer;
        opacity: 0.7;
        transition: var(--transition);
        border: 2px solid transparent;
    }

        .thumbnail-img:hover,
        .thumbnail-container a.active .thumbnail-img {
            opacity: 1;
            border-color: var(--secondary-color);
        }

    .department-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }

    .rating {
        font-size: 1.1rem;
        color: #ffc107;
    }

    .department-description {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--text-color);
        margin: 1.5rem 0;
    }

    .department-highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin: 1.5rem 0;
        padding: 1rem 0;
        border-top: 1px solid #eee;
        border-bottom: 1px solid #eee;
    }

    .highlight-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .highlight-icon {
        color: var(--secondary-color);
        font-size: 1.2rem;
    }

    .department-price {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: var(--border-radius);
    }

    .price-label {
        display: block;
        font-size: 0.9rem;
        color: #6c757d;
    }

    .price-amount {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    .price-period {
        font-size: 1rem;
        color: #6c757d;
    }

    .action-buttons .btn {
        padding: 0.75rem 1rem;
        font-weight: 500;
        border-radius: var(--border-radius);
        transition: var(--transition);
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none;
        border: 2px solid transparent;
    }

    .action-buttons-grid-four {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        max-width: 400px;
    }
    .action-buttons-grid-four .btn {
        width: 100%;
        white-space: nowrap;
        padding: 0.6rem 1rem;
        font-size: 0.95rem;
        min-height: 44px;
        box-sizing: border-box;
    }
    @@media (max-width: 400px) {
        .action-buttons-grid-four .btn {
            white-space: normal;
            font-size: 0.85rem;
            padding: 0.55rem 0.75rem;
        }
    }

    .whatsapp-btn {
        background-color: #25D366 !important;
        border-color: #25D366 !important;
    }
    .whatsapp-btn:hover {
        background-color: #128C7E !important;
        border-color: #128C7E !important;
        transform: translateY(-2px);
    }

    .email-btn:hover,
    .visit-btn:hover {
        transform: translateY(-2px);
    }

    .back-btn {
        border: 1px solid #dee2e6;
    }

        .back-btn:hover {
            background-color: #e9ecef;
        }

    .carousel-control-prev,
    .carousel-control-next {
        width: 50px;
        height: 50px;
        background-color: rgba(0, 0, 0, 0.2);
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0;
        transition: var(--transition);
    }

    #departmentGallery:hover .carousel-control-prev,
    #departmentGallery:hover .carousel-control-next {
        opacity: 1;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(1);
    }

    @@media (max-width: 992px) {
        .department-main-image {
            height: 350px;
        }
    }

    @@media (max-width: 768px) {
        .department-title {
            font-size: 1.8rem;
        }

        .department-main-image {
            height: 300px;
        }

        .department-highlights {
            gap: 1rem;
        }
    }

</style>