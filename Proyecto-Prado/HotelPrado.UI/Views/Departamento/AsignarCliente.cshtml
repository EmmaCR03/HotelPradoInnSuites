@{
    ViewBag.Title = "Asignar Cliente al Departamento";
    Layout = "~/Views/Shared/_Layout.cshtml";
    Response.ContentType = "text/html; charset=utf-8";
    var departamento = ViewBag.Departamento as HotelPrado.Abstracciones.ModelosDeBaseDeDatos.Departamento.DepartamentoTabla;
    var departamentoNombre = ViewBag.DepartamentoNombre as string;
    var clientes = ViewBag.Clientes as List<HotelPrado.UI.Models.ApplicationUser> ?? new List<HotelPrado.UI.Models.ApplicationUser>();
    var clienteActual = ViewBag.ClienteActual as HotelPrado.UI.Models.ApplicationUser;
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("IndexDepartamentos", "Departamento")">Departamentos</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("DetallesAdmin", "Departamento", new { id = departamento.IdDepartamento })">@departamentoNombre</a></li>
            <li class="breadcrumb-item active" aria-current="page">Asignar Cliente</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="text-primary fw-bold mb-1">
                <i class="fas fa-user-plus me-2"></i>Asignar Cliente
            </h2>
            <p class="text-muted mb-0">@departamentoNombre</p>
        </div>
        <div>
            <a href="@Url.Action("DetallesAdmin", "Departamento", new { id = departamento.IdDepartamento })" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver al departamento
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <!-- Información del Departamento -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-building me-2"></i>Información del Departamento</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <label class="text-muted small">Departamento</label>
                            <div class="fs-5 fw-bold text-primary">@departamento.Nombre</div>
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted small">Estado Actual</label>
                            <div>
                                @if (departamento.Estado == "Disponible")
                                {
                                    <span class="badge bg-success fs-6">@departamento.Estado</span>
                                }
                                else if (departamento.Estado == "Ocupado")
                                {
                                    <span class="badge bg-danger fs-6">@departamento.Estado</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning fs-6">@departamento.Estado</span>
                                }
                            </div>
                        </div>
                        @if (clienteActual != null)
                        {
                            <div class="col-md-6">
                                <label class="text-muted small">Cliente Actual</label>
                                <div class="alert alert-info mb-0 py-2">
                                    <i class="fas fa-user me-2"></i>
                                    <strong>@(!string.IsNullOrWhiteSpace(clienteActual.NombreCompleto) ? clienteActual.NombreCompleto : clienteActual.UserName)</strong>
                                    @if (!string.IsNullOrWhiteSpace(clienteActual.Email))
                                    {
                                        <span class="text-muted">(@clienteActual.Email)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Barra de búsqueda y contador -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-3">
                    <input type="text" id="searchClientes" class="form-control shadow-sm" style="max-width: 400px;" 
                           placeholder="Buscar por nombre, email o cédula...">
                    <span class="badge bg-secondary" id="contadorClientes">Total: @clientes.Count</span>
                </div>
            </div>

            @if (clientes.Count == 0)
            {
                <div class="alert alert-warning text-center">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>No hay clientes registrados en el sistema.</strong><br>
                    Por favor, registre usuarios con rol "Cliente" primero.
                </div>
            }
            else
            {
                <!-- Formulario oculto para enviar la selección -->
                using (Html.BeginForm("AsignarCliente", "Departamento", new { id = departamento.IdDepartamento }, FormMethod.Post, new { id = "formAsignarCliente" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="IdCliente" id="selectedClienteId" value="0" />
                }

                <!-- Card para desocupar -->
                <div class="row mb-3">
                    <div class="col-md-4 col-lg-3 mb-3">
                        <div class="card border-0 shadow-sm h-100 cliente-card desocupar-card" 
                             data-nombre="sin cliente desocupar" 
                             data-email=""
                             data-cedula=""
                             data-cliente-id="0">
                            <div class="card-body text-center">
                                <div class="mb-3">
                                    <i class="fas fa-door-open fa-3x text-warning"></i>
                                </div>
                                <h5 class="fw-bold text-dark mb-2">Desocupar Departamento</h5>
                                <p class="text-muted small mb-3">Quitar el cliente asignado y marcar como disponible</p>
                                <button type="button" class="btn btn-warning btn-sm w-100 seleccionar-cliente" data-cliente-id="0">
                                    <i class="fas fa-check me-2"></i>Seleccionar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cards de clientes -->
                <div class="row" id="clientesContainer">
                    @foreach (var cliente in clientes)
                    {
                        <div class="col-md-4 col-lg-3 mb-4 cliente-item" 
                             data-nombre="@((!string.IsNullOrWhiteSpace(cliente.NombreCompleto) ? cliente.NombreCompleto : cliente.UserName).ToLower())" 
                             data-email="@(cliente.Email ?? "")" 
                             data-cedula="@(cliente.cedula ?? "")"
                             data-cliente-id="@cliente.Id"
                             data-cliente-nombre="@(!string.IsNullOrWhiteSpace(cliente.NombreCompleto) ? cliente.NombreCompleto : cliente.UserName)">
                            <div class="card border-0 shadow-sm h-100 cliente-card @(clienteActual != null && clienteActual.Id == cliente.Id ? "border-primary border-2" : "")">
                                <div class="card-body">
                                    <div class="text-center mb-3">
                                        <div class="cliente-avatar mb-2">
                                            <i class="fas fa-user-circle fa-3x @(clienteActual != null && clienteActual.Id == cliente.Id ? "text-primary" : "text-secondary")"></i>
                                        </div>
                                        <h5 class="fw-bold text-dark mb-1">
                                            @(!string.IsNullOrWhiteSpace(cliente.NombreCompleto) ? cliente.NombreCompleto : cliente.UserName)
                                        </h5>
                                        @if (!string.IsNullOrWhiteSpace(cliente.Email))
                                        {
                                            <p class="text-muted small mb-2">
                                                <i class="fas fa-envelope me-1"></i>@cliente.Email
                                            </p>
                                        }
                                    </div>
                                    
                                    <div class="cliente-info">
                                        @if (!string.IsNullOrWhiteSpace(cliente.UserName) && cliente.UserName != cliente.Email)
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted d-block">Usuario:</small>
                                                <strong>@cliente.UserName</strong>
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrWhiteSpace(cliente.cedula))
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted d-block">Cédula:</small>
                                                <strong>@cliente.cedula</strong>
                                            </div>
                                        }
                                        
                                        @if (!string.IsNullOrWhiteSpace(cliente.Telefono))
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted d-block">Teléfono:</small>
                                                <strong>@cliente.Telefono</strong>
                                            </div>
                                        }

                                        @if (clienteActual != null && clienteActual.Id == cliente.Id)
                                        {
                                            <div class="mb-2">
                                                <span class="badge bg-primary">
                                                    <i class="fas fa-check-circle me-1"></i>Cliente Actual
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                <div class="card-footer bg-light border-0 pt-0">
                                    <button type="button" class="btn btn-primary btn-sm w-100 seleccionar-cliente" data-cliente-id="@cliente.Id">
                                        <i class="fas fa-check me-2"></i>Seleccionar
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div id="noResults" class="alert alert-warning text-center mt-4" style="display: none;">
                    <i class="fas fa-search me-2"></i>No se encontraron clientes que coincidan con la búsqueda.
                </div>

                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mt-3">
                        <h5><i class="fas fa-exclamation-triangle me-2"></i>Errores:</h5>
                        @Html.ValidationSummary(true, "", new { @class = "mb-0" })
                    </div>
                }

                <div class="alert alert-info mt-4">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Nota:</strong> Al asignar un cliente, el departamento cambiará a estado "Ocupado". 
                    Al desocupar, cambiará a "Disponible" y se creará automáticamente una solicitud de limpieza.
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal para confirmar asignación de cliente -->
<div class="modal fade" id="modalConfirmarAsignacion" tabindex="-1" aria-labelledby="modalConfirmarAsignacionLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalConfirmarAsignacionLabel">
                    <i class="fas fa-user-check me-2"></i>Confirmar Asignación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-3">
                    <i class="fas fa-user-circle fa-4x text-primary"></i>
                </div>
                <h5 class="mb-3">¿Desea asignar este cliente al departamento?</h5>
                <div class="alert alert-info">
                    <strong id="modalClienteNombre"></strong>
                    <div class="mt-2" id="modalClienteInfo"></div>
                </div>
                <p class="text-muted mb-0">
                    <i class="fas fa-building me-2"></i><strong>@departamentoNombre</strong>
                </p>
                <p class="text-muted small mt-2">
                    El departamento cambiará a estado <span class="badge bg-danger">Ocupado</span>
                </p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancelar
                </button>
                <button type="button" class="btn btn-primary" id="btnConfirmarAsignacion">
                    <i class="fas fa-check me-2"></i>Confirmar Asignación
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal para confirmar desocupar departamento -->
<div class="modal fade" id="modalConfirmarDesocupar" tabindex="-1" aria-labelledby="modalConfirmarDesocuparLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="modalConfirmarDesocuparLabel">
                    <i class="fas fa-door-open me-2"></i>Confirmar Desocupar Departamento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-3">
                    <i class="fas fa-door-open fa-4x text-warning"></i>
                </div>
                <h5 class="mb-3">¿Desea desocupar este departamento?</h5>
                <div class="alert alert-warning">
                    <p class="mb-0">
                        <i class="fas fa-building me-2"></i><strong>@departamentoNombre</strong>
                    </p>
                </div>
                <p class="text-muted">
                    Al desocupar el departamento:
                </p>
                <ul class="list-unstyled text-start">
                    <li><i class="fas fa-check-circle text-success me-2"></i>Se quitará el cliente asignado</li>
                    <li><i class="fas fa-check-circle text-success me-2"></i>El estado cambiará a <span class="badge bg-success">Disponible</span></li>
                    <li><i class="fas fa-check-circle text-success me-2"></i>Se creará automáticamente una solicitud de limpieza</li>
                </ul>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancelar
                </button>
                <button type="button" class="btn btn-warning" id="btnConfirmarDesocupar">
                    <i class="fas fa-check me-2"></i>Confirmar Desocupar
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .cliente-card {
        transition: all 0.3s ease;
        border-radius: 10px;
        cursor: pointer;
    }
    
    .cliente-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
    }
    
    .cliente-card.border-primary {
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.25) !important;
    }
    
    .desocupar-card {
        background: linear-gradient(135deg, #fff3cd 0%, #ffe69c 100%);
    }
    
    .cliente-avatar {
        transition: transform 0.3s ease;
    }
    
    .cliente-card:hover .cliente-avatar {
        transform: scale(1.1);
    }
    
    .seleccionar-cliente {
        transition: all 0.2s ease;
    }
    
    .seleccionar-cliente:hover {
        transform: scale(1.05);
    }
</style>

<!-- Scripts optimizados -->
<script>
    (function() {
        'use strict';
        
        var searchInput = document.getElementById('searchClientes');
        var clientesContainer = document.getElementById('clientesContainer');
        var noResults = document.getElementById('noResults');
        var contador = document.getElementById('contadorClientes');
        var formAsignar = document.getElementById('formAsignarCliente');
        var selectedClienteId = document.getElementById('selectedClienteId');
        
        // Función de búsqueda con debounce
        var searchTimeout;
        function performSearch() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                var searchTerm = searchInput.value.toLowerCase().trim();
                var items = document.querySelectorAll('.cliente-item, .desocupar-card');
                var visibleCount = 0;
                
                items.forEach(function(item) {
                    var nombre = item.getAttribute('data-nombre') || '';
                    var email = item.getAttribute('data-email') || '';
                    var cedula = item.getAttribute('data-cedula') || '';
                    
                    var matches = nombre.includes(searchTerm) || 
                                 email.includes(searchTerm) || 
                                 cedula.includes(searchTerm);
                    
                    if (matches || searchTerm === '') {
                        item.style.display = '';
                        visibleCount++;
                    } else {
                        item.style.display = 'none';
                    }
                });
                
                // Mostrar/ocultar mensaje de no resultados
                if (visibleCount === 0 && searchTerm !== '') {
                    noResults.style.display = 'block';
                } else {
                    noResults.style.display = 'none';
                }
                
                // Actualizar contador
                if (contador) {
                    contador.textContent = 'Mostrando: ' + visibleCount + ' de ' + items.length;
                }
            }, 300);
        }
        
        // Event listener para búsqueda
        if (searchInput) {
            searchInput.addEventListener('input', performSearch);
            searchInput.addEventListener('keyup', performSearch);
        }
        
        // Variables para los modales
        var modalAsignacion = document.getElementById('modalConfirmarAsignacion');
        var modalDesocupar = document.getElementById('modalConfirmarDesocupar');
        var btnConfirmarAsignacion = document.getElementById('btnConfirmarAsignacion');
        var btnConfirmarDesocupar = document.getElementById('btnConfirmarDesocupar');
        var clienteIdSeleccionado = null;
        
        // Inicializar modales de Bootstrap si están disponibles
        var modalAsignacionInstance = null;
        var modalDesocuparInstance = null;
        
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            modalAsignacionInstance = new bootstrap.Modal(modalAsignacion);
            modalDesocuparInstance = new bootstrap.Modal(modalDesocupar);
        }
        
        // Función para mostrar modal de asignación
        function mostrarModalAsignacion(clienteId, clienteNombre, clienteEmail, clienteCedula) {
            document.getElementById('modalClienteNombre').textContent = clienteNombre;
            var infoHtml = '';
            if (clienteEmail) {
                infoHtml += '<div><i class="fas fa-envelope me-2"></i>' + clienteEmail + '</div>';
            }
            if (clienteCedula) {
                infoHtml += '<div class="mt-1"><i class="fas fa-id-card me-2"></i>' + clienteCedula + '</div>';
            }
            document.getElementById('modalClienteInfo').innerHTML = infoHtml;
            clienteIdSeleccionado = clienteId;
            
            if (modalAsignacionInstance) {
                modalAsignacionInstance.show();
            } else if (modalAsignacion) {
                // Fallback si Bootstrap no está disponible
                modalAsignacion.style.display = 'block';
                modalAsignacion.classList.add('show');
                // Agregar backdrop
                var backdrop = document.createElement('div');
                backdrop.className = 'modal-backdrop fade show';
                backdrop.id = 'modalBackdrop';
                document.body.appendChild(backdrop);
            }
        }
        
        // Función para mostrar modal de desocupar
        function mostrarModalDesocupar() {
            clienteIdSeleccionado = '0';
            if (modalDesocuparInstance) {
                modalDesocuparInstance.show();
            } else if (modalDesocupar) {
                // Fallback si Bootstrap no está disponible
                modalDesocupar.style.display = 'block';
                modalDesocupar.classList.add('show');
                // Agregar backdrop
                var backdrop = document.createElement('div');
                backdrop.className = 'modal-backdrop fade show';
                backdrop.id = 'modalBackdrop';
                document.body.appendChild(backdrop);
            }
        }
        
        // Confirmar asignación desde el modal
        if (btnConfirmarAsignacion) {
            btnConfirmarAsignacion.addEventListener('click', function() {
                if (selectedClienteId && clienteIdSeleccionado) {
                    selectedClienteId.value = clienteIdSeleccionado;
                    if (formAsignar) {
                        if (modalAsignacionInstance) {
                            modalAsignacionInstance.hide();
                        } else if (modalAsignacion) {
                            modalAsignacion.style.display = 'none';
                            modalAsignacion.classList.remove('show');
                            var backdrop = document.getElementById('modalBackdrop');
                            if (backdrop) backdrop.remove();
                        }
                        formAsignar.submit();
                    }
                }
            });
        }
        
        // Confirmar desocupar desde el modal
        if (btnConfirmarDesocupar) {
            btnConfirmarDesocupar.addEventListener('click', function() {
                if (selectedClienteId) {
                    selectedClienteId.value = '0';
                    if (formAsignar) {
                        if (modalDesocuparInstance) {
                            modalDesocuparInstance.hide();
                        } else if (modalDesocupar) {
                            modalDesocupar.style.display = 'none';
                            modalDesocupar.classList.remove('show');
                            var backdrop = document.getElementById('modalBackdrop');
                            if (backdrop) backdrop.remove();
                        }
                        formAsignar.submit();
                    }
                }
            });
        }
        
        // Event listeners para seleccionar cliente
        document.querySelectorAll('.seleccionar-cliente').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var clienteId = this.getAttribute('data-cliente-id');
                
                if (clienteId === '0') {
                    // Mostrar modal de desocupar
                    mostrarModalDesocupar();
                } else {
                    // Obtener información del cliente desde los data-attributes de la card
                    var card = this.closest('.cliente-item');
                    var clienteNombre = '';
                    var clienteEmail = '';
                    var clienteCedula = '';
                    
                    if (card) {
                        // Obtener información desde data-attributes (más confiable)
                        clienteNombre = card.getAttribute('data-cliente-nombre') || '';
                        clienteEmail = card.getAttribute('data-email') || '';
                        clienteCedula = card.getAttribute('data-cedula') || '';
                        
                        // Si no hay nombre en data-attribute, obtenerlo del h5
                        if (!clienteNombre) {
                            var nombreElement = card.querySelector('h5');
                            clienteNombre = nombreElement ? nombreElement.textContent.trim() : 'Cliente';
                        }
                    }
                    
                    // Mostrar modal de asignación
                    mostrarModalAsignacion(clienteId, clienteNombre, clienteEmail, clienteCedula);
                }
            });
        });
        
        // Cerrar modales al hacer click fuera
        if (modalAsignacion) {
            modalAsignacion.addEventListener('click', function(e) {
                if (e.target === modalAsignacion) {
                    if (modalAsignacionInstance) {
                        modalAsignacionInstance.hide();
                    } else if (modalAsignacion) {
                        modalAsignacion.style.display = 'none';
                        modalAsignacion.classList.remove('show');
                        var backdrop = document.getElementById('modalBackdrop');
                        if (backdrop) backdrop.remove();
                    }
                }
            });
        }
        
        if (modalDesocupar) {
            modalDesocupar.addEventListener('click', function(e) {
                if (e.target === modalDesocupar) {
                    if (modalDesocuparInstance) {
                        modalDesocuparInstance.hide();
                    } else if (modalDesocupar) {
                        modalDesocupar.style.display = 'none';
                        modalDesocupar.classList.remove('show');
                        var backdrop = document.getElementById('modalBackdrop');
                        if (backdrop) backdrop.remove();
                    }
                }
            });
        }
    })();
</script>
