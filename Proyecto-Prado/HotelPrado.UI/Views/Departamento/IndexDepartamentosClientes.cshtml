@model IEnumerable<HotelPrado.Abstracciones.Modelos.Departamento.DepartamentoDTO>

@{
    ViewBag.Title = "IndexDepartamentosClientes";
}

<!-- Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Custom CSS -->
<link href="~/Content/DepartamentoClientes/departamentosgeneral.css" rel="stylesheet" />

<section id="departments" class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Nuestros Exclusivos Departamentos</h2>
            <p class="section-subtitle">Descubre el confort y elegancia que tenemos para ofrecerte</p>
        </div>

        <div class="row g-4">
            @foreach (var depto in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="department-card">
                        <!-- Image Carousel -->
                        <div id="carousel-@depto.IdDepartamento" class="carousel slide" data-bs-ride="carousel">
                            <div class="carousel-inner rounded-top">
                                @if (!string.IsNullOrEmpty(depto.UrlImagenes))
                                {
                                    var images = depto.UrlImagenes.Split(',').ToList();
                                    for (int i = 0; i < images.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <img src="@Url.Content(images[i])" class="d-block w-100 department-img" alt="Imagen de @depto.Nombre">
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="carousel-item active">
                                        <img src="@Url.Content("~/imagenes/default.jpg")" class="d-block w-100 department-img" alt="Imagen de @depto.Nombre">
                                    </div>
                                }
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#carousel-@depto.IdDepartamento" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carousel-@depto.IdDepartamento" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>

                        <!-- Card Body -->
                        <div class="department-card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="department-title">@depto.Nombre</h3>
                                <span class="badge bg-primary">Disponible</span>
                            </div>

                            <p class="department-description">@depto.Descripcion</p>

                            <div class="department-features">
                                <div class="feature-item">
                                    <i class="fas fa-bed feature-icon"></i>
                                    <span>@depto.NumeroHabitaciones Habitaciones</span>
                                </div>
                                <div class="feature-item">
                                    <i class="fas fa-couch feature-icon"></i>
                                    <span>@(depto.Amueblado ? "Amueblado" : "Sin amueblar")</span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-4">

                                <a href="@Url.Action("Details", "Departamento", new { id = depto.IdDepartamento })" class="btn btn-primary btn-details">
                                    <i class="fas fa-eye me-2"></i>Ver Detalles
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Scripts -->
<script src="~/Scripts/bootstrap.bundle.min.js"></script>

<style>
    :root {
        --primary-color: #2c3e50;
        --secondary-color: #3498db;
        --accent-color: #e74c3c;
        --light-color: #ecf0f1;
        --dark-color: #2c3e50;
        --text-color: #34495e;
        --shadow: 0 10px 20px rgba(0,0,0,0.1);
        --transition: all 0.3s ease;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
        background-color: #f9f9f9;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
        position: relative;
        display: inline-block;
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: var(--secondary-color);
            border-radius: 2px;
        }

    .section-subtitle {
        font-size: 1.1rem;
        color: #7f8c8d;
        max-width: 700px;
        margin: 0 auto;
    }

    .department-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: var(--transition);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .department-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

    .department-img {
        height: 250px;
        object-fit: cover;
        transition: var(--transition);
    }

    .department-card:hover .department-img {
        opacity: 0.9;
    }

    .department-card-body {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .department-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 0;
    }

    .department-description {
        color: #7f8c8d;
        margin: 1rem 0;
        flex-grow: 1;
    }

    .department-features {
        display: flex;
        gap: 1.5rem;
        margin: 1rem 0;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .feature-icon {
        color: var(--secondary-color);
        font-size: 1.1rem;
    }

    .department-price {
        text-align: left;
    }

    .price-label {
        display: block;
        font-size: 0.8rem;
        color: #7f8c8d;
    }

    .price-amount {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    .price-period {
        font-size: 0.9rem;
        color: #7f8c8d;
    }

    .btn-details {
        background-color: var(--secondary-color);
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-weight: 500;
        transition: var(--transition);
    }

        .btn-details:hover {
            background-color: var(--primary-color);
            transform: translateY(-2px);
        }

    .badge {
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.35rem 0.75rem;
        border-radius: 50px;
    }

    .carousel-control-prev, .carousel-control-next {
        width: 40px;
        height: 40px;
        background: rgba(0,0,0,0.3);
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0;
        transition: var(--transition);
    }

    .department-card:hover .carousel-control-prev,
    .department-card:hover .carousel-control-next {
        opacity: 1;
    }

    @@media (max-width: 768px) {
        .section-title {
            font-size: 2rem;
        }

        .department-features {
            flex-direction: column;
            gap: 0.5rem;
        }

        .department-card-body {
            padding: 1.25rem;
        }
    }
</style>