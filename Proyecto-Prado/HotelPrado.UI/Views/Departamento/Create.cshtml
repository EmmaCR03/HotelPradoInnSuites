@model HotelPrado.Abstracciones.Modelos.Departamento.DepartamentoDTO

@{
    ViewBag.Title = "Crear Departamento";
}

<style>
    .card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
    }

    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid rgba(0,0,0,.05);
        padding: 1rem 1.5rem;
    }

    .form-label {
        font-weight: 500;
        margin-bottom: .5rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border: 1px solid #dee2e6;
        padding: .5rem .75rem;
        font-size: 0.9rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #80bdff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
        }

    .btn-primary {
        padding: .5rem 1.5rem;
        font-weight: 500;
    }

    .btn-secondary {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
        padding: .5rem 1.5rem;
        font-weight: 500;
    }

    .text-danger {
        font-size: 0.8rem;
        margin-top: .25rem;
    }

    .preview-img {
        width: 100px;
        margin-right: 10px;
        border-radius: 8px;
        box-shadow: 0px 2px 5px rgba(0,0,0,0.2);
    }
</style>

<div class="container-fluid px-4">
    <div class="row my-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Crear Nuevo Departamento</h2>
                <a href="@Url.Action("IndexDepartamentos")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Regresar
                </a>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    @using (Html.BeginForm("Create", "Departamento", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="row g-4">
                            <div class="col-md-6">
                                @Html.LabelFor(model => model.Nombre, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.NumeroDepartamento, new { @class = "form-label" })
                                @Html.EditorFor(model => model.NumeroDepartamento, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.NumeroDepartamento, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-12">
                                @Html.LabelFor(model => model.Descripcion, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Descripcion, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.IdTipoDepartamento, new { @class = "form-label" })
                                @Html.DropDownListFor(model => model.IdTipoDepartamento, (SelectList)ViewBag.TipoDepartamento, "Seleccione un tipo de Habitación", new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.IdTipoDepartamento, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.Precio, new { @class = "form-label" })
                                @Html.EditorFor(model => model.Precio, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Precio, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6">
                                @Html.LabelFor(model => model.Estado, new { @class = "form-label" })
                                @Html.DropDownListFor(model => model.Estado,
                                    new SelectList(new List<SelectListItem>
                                    {
                                        new SelectListItem { Value = "Disponible", Text = "Disponible" },
                                        new SelectListItem { Value = "Ocupado", Text = "Ocupado" },
                                        new SelectListItem { Value = "Mantenimiento", Text = "Mantenimiento" }
                                    }, "Value", "Text"), "Seleccione un estado", new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Imágenes</label>
                                <input type="file" id="imagenInput" name="Imagenes" multiple class="d-none" accept="image/*" />
                                <button type="button" class="btn btn-outline-primary" onclick="document.getElementById('imagenInput').click();">
                                    Subir Imágenes
                                </button>
                                <span id="fileCount" class="text-muted ms-2">No se han seleccionado archivos</span>
                                <div id="preview" class="mt-3 d-flex flex-wrap"></div>
                            </div>

                            <div class="col-12 mt-4 d-flex justify-content-end">
                                <input type="submit" value="Crear Departamento" class="btn btn-primary" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        document.getElementById('imagenInput').addEventListener('change', function (event) {
            let preview = document.getElementById('preview');
            let fileCount = document.getElementById('fileCount');
            preview.innerHTML = '';

            if (event.target.files.length > 0) {
                fileCount.textContent = event.target.files.length + " archivo(s) seleccionado(s)";
            } else {
                fileCount.textContent = "No se han seleccionado archivos";
            }

            for (let file of event.target.files) {
                let reader = new FileReader();
                reader.onload = function (e) {
                    let img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'preview-img';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
