@model HotelPrado.Abstracciones.Modelos.Departamento.DepartamentoDTO

<div class="card mt-5">
    <div class="card-header">
        <h2>Crear Departamento</h2>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "Departamento", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-horizontal">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <div class="form-group row">
                    @Html.LabelFor(model => model.Nombre, new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control w-100" } })
                        @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group row">
                    @Html.LabelFor(model => model.NumeroDepartamento, new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        @Html.EditorFor(model => model.NumeroDepartamento, new { htmlAttributes = new { @class = "form-control w-100" } })
                        @Html.ValidationMessageFor(model => model.NumeroDepartamento, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group row">
                    @Html.LabelFor(model => model.Descripcion, new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        @Html.EditorFor(model => model.Descripcion, new { htmlAttributes = new { @class = "form-control w-100" } })
                        @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group row">
                    @Html.LabelFor(model => model.IdTipoDepartamento, new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        @Html.DropDownListFor(model => model.IdTipoDepartamento, (SelectList)ViewBag.TipoDepartamento, "Seleccione un tipo de Habitación", new { @class = "form-control w-100" })
                        @Html.ValidationMessageFor(model => model.IdTipoDepartamento, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group row">
                    @Html.LabelFor(model => model.Precio, new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        @Html.EditorFor(model => model.Precio, new { htmlAttributes = new { @class = "form-control w-100" } })
                        @Html.ValidationMessageFor(model => model.Precio, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group row">
                    @Html.LabelFor(model => model.Estado, new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        @Html.DropDownListFor(model => model.Estado, new SelectList(new List<SelectListItem>
                                {
                            new SelectListItem { Value = "Disponible", Text = "Disponible" },
                            new SelectListItem { Value = "Ocupado", Text = "Ocupado" },
                            new SelectListItem { Value = "Mantenimiento", Text = "Mantenimiento" }
                        }, "Value", "Text"), "Seleccione un tipo", new { @class = "form-control w-100" })
                        @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="form-group row">
                    @Html.Label("Imágenes", new { @class = "control-label col-md-3 text-wrap" })
                    <div class="col-md-9 w-100">
                        <input type="file" id="imagenInput" name="Imagenes" multiple class="d-none" accept="image/*" />
                        <button type="button" class="btn btn-primary" onclick="document.getElementById('imagenInput').click();">
                            Subir Imágenes
                        </button>
                        <span id="fileCount" class="text-muted ml-2">No se han seleccionado archivos</span>
                        <div id="preview" class="mt-2"></div>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-9 offset-md-3 w-100">
                        <input type="submit" value="Crear Departamento" class="btn btn-primary w-100" />
                    </div>
                </div>
            </div>
        }
        <div>
            @Html.ActionLink("Regresar", "IndexDepartamentos", null, new { @class = "btn btn-secondary w-100" })
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        document.getElementById('imagenInput').addEventListener('change', function (event) {
            let preview = document.getElementById('preview');
            let fileCount = document.getElementById('fileCount');
            preview.innerHTML = '';

            if (event.target.files.length > 0) {
                fileCount.textContent = event.target.files.length + " archivos seleccionados";
            } else {
                fileCount.textContent = "No se han seleccionado archivos";
            }

            for (let file of event.target.files) {
                let reader = new FileReader();
                reader.onload = function (e) {
                    let img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.width = '100px';
                    img.style.marginRight = '10px';
                    img.style.borderRadius = '8px';
                    img.style.boxShadow = '0px 2px 5px rgba(0,0,0,0.2)';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
