        // Event listeners para botones de cambio de estado (mantenimiento, disponible, etc.)
        document.addEventListener('click', function(e) {
            if (e.target.closest('.btn-cambiar-estado')) {
                var btn = e.target.closest('.btn-cambiar-estado');
                var habitacionId = btn.getAttribute('data-habitacion-id');
                var estadoNuevo = btn.getAttribute('data-estado-nuevo');
                
                if (!habitacionId || !estadoNuevo) {
                    showNotificationModal('error', 'Error', 'Datos incompletos para cambiar el estado.');
                    return;
                }
                
                // Mostrar modal de confirmación según el estado
                if (estadoNuevo === 'Mantenimiento') {
                    // Obtener número de habitación
                    var habitacionCard = btn.closest('.habitacion-card');
                    var numeroHabitacion = habitacionCard ? habitacionCard.querySelector('.habitacion-numero')?.textContent || habitacionId : habitacionId;
                    
                    // Configurar modal de mantenimiento
                    if (document.getElementById('mantenimiento-habitacion-numero')) {
                        document.getElementById('mantenimiento-habitacion-numero').textContent = numeroHabitacion;
                    }
                    if (document.getElementById('mantenimiento-fecha-hora')) {
                        var ahora = new Date();
                        var fechaHora = ahora.toLocaleDateString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                        document.getElementById('mantenimiento-fecha-hora').textContent = fechaHora;
                    }
                    
                    // Mostrar modal
                    var modalMantenimiento = document.getElementById('modalMantenimiento');
                    var modalMantenimientoInstance = null;
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        modalMantenimientoInstance = new bootstrap.Modal(modalMantenimiento);
                        modalMantenimientoInstance.show();
                    } else if (modalMantenimiento) {
                        modalMantenimiento.style.display = 'block';
                        modalMantenimiento.classList.add('show');
                        var backdrop = document.createElement('div');
                        backdrop.className = 'modal-backdrop fade show';
                        backdrop.id = 'modalBackdropMantenimiento';
                        document.body.appendChild(backdrop);
                    }
                    
                    // Guardar datos para cuando se confirme
                    modalMantenimiento.dataset.habitacionId = habitacionId;
                    modalMantenimiento.dataset.estadoNuevo = estadoNuevo;
                    modalMantenimiento.dataset.btnId = btn.id || 'btn-' + Date.now();
                    
                    // Guardar referencia al botón
                    if (!window.btnCambiarEstado) {
                        window.btnCambiarEstado = {};
                    }
                    window.btnCambiarEstado[habitacionId] = btn;
                } else if (estadoNuevo === 'Disponible') {
                    // Obtener número de habitación
                    var habitacionCard = btn.closest('.habitacion-card');
                    var numeroHabitacion = habitacionCard ? habitacionCard.querySelector('.habitacion-numero')?.textContent || habitacionId : habitacionId;
                    
                    // Configurar modal de disponible
                    if (document.getElementById('disponible-habitacion-numero')) {
                        document.getElementById('disponible-habitacion-numero').textContent = numeroHabitacion;
                    }
                    if (document.getElementById('disponible-fecha-hora')) {
                        var ahora = new Date();
                        var fechaHora = ahora.toLocaleDateString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                        document.getElementById('disponible-fecha-hora').textContent = fechaHora;
                    }
                    
                    // Mostrar modal
                    var modalDisponible = document.getElementById('modalDisponible');
                    var modalDisponibleInstance = null;
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        modalDisponibleInstance = new bootstrap.Modal(modalDisponible);
                        modalDisponibleInstance.show();
                    } else if (modalDisponible) {
                        modalDisponible.style.display = 'block';
                        modalDisponible.classList.add('show');
                        var backdrop = document.createElement('div');
                        backdrop.className = 'modal-backdrop fade show';
                        backdrop.id = 'modalBackdropDisponible';
                        document.body.appendChild(backdrop);
                    }
                    
                    // Guardar datos para cuando se confirme
                    modalDisponible.dataset.habitacionId = habitacionId;
                    modalDisponible.dataset.estadoNuevo = estadoNuevo;
                    
                    // Guardar referencia al botón
                    if (!window.btnCambiarEstado) {
                        window.btnCambiarEstado = {};
                    }
                    window.btnCambiarEstado[habitacionId] = btn;
                } else {
                    // Para otros estados, usar confirmación simple
                    var confirmar = confirm(`¿Desea cambiar el estado de la habitación a "${estadoNuevo}"?`);
                    if (!confirmar) return;
                    
                    cambiarEstadoHabitacion(habitacionId, estadoNuevo, btn, null);
                }
            }
        });
        
        // Función para cambiar estado de habitación o departamento
        function cambiarEstadoHabitacion(habitacionId, estadoNuevo, btn, descripcionMantenimiento, tipo) {
            // Deshabilitar botón
            if (btn) {
                btn.disabled = true;
                var textoOriginal = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Procesando...';
            }
            
            // Obtener token anti-forgery
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            
            // Obtener tipo desde el botón si no se proporciona
            if (!tipo) {
                tipo = btn ? (btn.getAttribute('data-tipo') || 'habitacion') : 'habitacion';
            }
            
            // Realizar petición AJAX
            var formData = new FormData();
            formData.append('IdHabitacion', parseInt(habitacionId));
            formData.append('Estado', estadoNuevo);
            formData.append('Tipo', tipo);
            if (descripcionMantenimiento) {
                formData.append('DescripcionMantenimiento', descripcionMantenimiento);
            }
            formData.append('__RequestVerificationToken', token);
            
            fetch('@Url.Action("ToggleEstado", "Habitacion")', {
                method: 'POST',
                credentials: 'same-origin',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: formData
            })
            .then(response => {
                // Intentar parsear como JSON primero
                const contentType = response.headers.get("content-type");
                if (contentType && contentType.includes("application/json")) {
                    return response.json();
                } else {
                    // Si no es JSON, asumir éxito y recargar
                    return { success: true, message: 'Estado actualizado correctamente' };
                }
            })
            .then(data => {
                if (data.success) {
                    showNotificationModal('success', 'Estado Actualizado', data.message || `Estado cambiado a ${estadoNuevo}`, function() {
                        // Recargar página para mostrar cambios
                        window.location.reload();
                    });
                } else {
                    showNotificationModal('error', 'Error', data.message || 'Error al cambiar el estado');
                    if (btn) {
                        btn.disabled = false;
                        var textoOriginal = btn.getAttribute('data-texto-original');
                        if (textoOriginal) {
                            btn.innerHTML = textoOriginal;
                        }
                    }
                }
            })
            .catch(error => {
                showNotificationModal('error', 'Error', 'Error al cambiar el estado. Por favor, intente nuevamente.');
                if (btn) {
                    btn.disabled = false;
                    var textoOriginal = btn.getAttribute('data-texto-original');
                    if (textoOriginal) {
                        btn.innerHTML = textoOriginal;
                    }
                }
            });
        }
        
        // Función global para confirmar disponible (llamada desde onclick)
        window.confirmarDisponible = function() {
            var modalDisponible = document.getElementById('modalDisponible');
            if (!modalDisponible) {
                alert('Error: No se encontró el modal de disponible.');
                return false;
            }
            
            var habitacionId = modalDisponible.dataset.habitacionId;
            var estadoNuevo = modalDisponible.dataset.estadoNuevo;
            
            if (!habitacionId || !estadoNuevo) {
                alert('Error: No se encontraron los datos de la habitación.');
                return false;
            }
            
            // Obtener botón original
            var btn = window.btnCambiarEstado && window.btnCambiarEstado[habitacionId] 
                ? window.btnCambiarEstado[habitacionId] 
                : document.querySelector('[data-habitacion-id="' + habitacionId + '"]');
            
            // Cerrar modal
            var modalDisponibleInstance = null;
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                modalDisponibleInstance = bootstrap.Modal.getInstance(modalDisponible);
                if (modalDisponibleInstance) {
                    modalDisponibleInstance.hide();
                }
            } else if (modalDisponible) {
                modalDisponible.style.display = 'none';
                modalDisponible.classList.remove('show');
                var backdrop = document.getElementById('modalBackdropDisponible');
                if (backdrop) backdrop.remove();
            }
            
            // Cambiar estado
            cambiarEstadoHabitacion(habitacionId, estadoNuevo, btn, null);
            
            return false; // Prevenir comportamiento por defecto
        };
        
        // Función global para confirmar mantenimiento (llamada desde onclick)
        window.confirmarMantenimiento = function() {
            var modalMantenimiento = document.getElementById('modalMantenimiento');
            if (!modalMantenimiento) {
                alert('Error: No se encontró el modal de mantenimiento.');
                return false;
            }
            
            var habitacionId = modalMantenimiento.dataset.habitacionId;
            var estadoNuevo = modalMantenimiento.dataset.estadoNuevo;
            
            if (!habitacionId || !estadoNuevo) {
                alert('Error: No se encontraron los datos de la habitación.');
                return false;
            }
            
            var descripcionTextarea = document.getElementById('mantenimiento-descripcion');
            var descripcionMantenimiento = descripcionTextarea ? descripcionTextarea.value.trim() : '';
            
            if (!descripcionMantenimiento) {
                alert('Por favor, ingrese una descripción del mantenimiento requerido.');
                if (descripcionTextarea) {
                    descripcionTextarea.focus();
                }
                return false;
            }
            
            // Obtener botón original
            var btn = window.btnCambiarEstado && window.btnCambiarEstado[habitacionId] 
                ? window.btnCambiarEstado[habitacionId] 
                : document.querySelector('[data-habitacion-id="' + habitacionId + '"]');
            
            // Cerrar modal
            var modalMantenimientoInstance = null;
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                modalMantenimientoInstance = bootstrap.Modal.getInstance(modalMantenimiento);
                if (modalMantenimientoInstance) {
                    modalMantenimientoInstance.hide();
                }
            } else if (modalMantenimiento) {
                modalMantenimiento.style.display = 'none';
                modalMantenimiento.classList.remove('show');
                var backdrop = document.getElementById('modalBackdropMantenimiento');
                if (backdrop) backdrop.remove();
            }
            
            // Cambiar estado con descripción
            cambiarEstadoHabitacion(habitacionId, estadoNuevo, btn, descripcionMantenimiento);
            
            // Limpiar textarea para próxima vez
            if (descripcionTextarea) {
                descripcionTextarea.value = '';
            }
            
            return false; // Prevenir comportamiento por defecto
        };
        
        // DESACTIVADO: Actualización automática cada 30 segundos
        // setInterval(function() {
        //     actualizarEstadoCompleto();
        // }, 30000);

    // Limpiar intervalo al salir de la página
    window.addEventListener('beforeunload', function () {
        clearInterval(autoRefreshInterval);
    });

    // Filtros del mapa
    document.addEventListener('DOMContentLoaded', function () {
        var filtros = document.querySelectorAll('.btn-filtro');
        var mapaContainer = document.querySelector('.mapa-habitaciones');
        
        filtros.forEach(function(filtro) {
            filtro.addEventListener('click', function() {
                // Remover active de todos
                filtros.forEach(function(f) {
                    f.classList.remove('active');
                });
                
                // Agregar active al clickeado
                this.classList.add('active');
                
                var filtroTipo = this.getAttribute('data-filtro');
                
                // Mostrar solo el tipo seleccionado: ocultar el resto
                if (mapaContainer) {
                    mapaContainer.classList.remove('hide-disponible', 'hide-ocupada', 'hide-mantenimiento', 'hide-limpieza');
                    if (filtroTipo === 'disponible') {
                        mapaContainer.classList.add('hide-ocupada', 'hide-mantenimiento', 'hide-limpieza');
                    } else if (filtroTipo === 'ocupada') {
                        mapaContainer.classList.add('hide-disponible', 'hide-mantenimiento', 'hide-limpieza');
                    } else if (filtroTipo === 'mantenimiento') {
                        mapaContainer.classList.add('hide-disponible', 'hide-ocupada', 'hide-limpieza');
                    } else if (filtroTipo === 'limpieza') {
                        mapaContainer.classList.add('hide-disponible', 'hide-ocupada', 'hide-mantenimiento');
                    }
                }
            });
        });

        // Click en habitación del mapa para mostrar detalles
        var habitacionesMapa = document.querySelectorAll('.mapa-habitacion-item');
        var habitacionesDetalle = document.querySelectorAll('.habitacion-card');
        
        habitacionesMapa.forEach(function(item) {
            item.addEventListener('click', function() {
                var id = this.getAttribute('data-id');
                var cardDetalle = document.querySelector('.habitacion-card[data-id="' + id + '"]');
                
                if (cardDetalle) {
                    // Scroll suave a la tarjeta de detalle
                    cardDetalle.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    
                    // Efecto de resaltado
                    cardDetalle.style.transform = 'scale(1.05)';
                    cardDetalle.style.boxShadow = '0 12px 32px rgba(109, 123, 184, 0.4)';
                    cardDetalle.style.transition = 'all 0.3s ease';
                    
                    setTimeout(function() {
                        cardDetalle.style.transform = '';
                        cardDetalle.style.boxShadow = '';
                    }, 2000);
                }
            });
        });
    });
</script>

