@model HotelPrado.UI.Models.EstadoHabitacionesViewModel

@{
    ViewBag.Title = "Estado de Habitaciones";
}

<div class="estado-habitaciones-container">
    <div class="container-fluid py-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="estado-title">
                            <i class="fas fa-tachometer-alt me-2"></i>Estado en Tiempo Real
                        </h1>
                        <p class="text-muted mb-0">Monitoreo en vivo del estado de habitaciones y departamentos</p>
                    </div>
                    <div>
                        <a href="@Url.Action("CalendarioHabitaciones", "Habitacion")" class="btn btn-primary">
                            <i class="fas fa-calendar-alt me-2"></i>Ver Calendario
                        </a>
                        <a href="@Url.Action("Create", "SolicitudLimpieza")" class="btn btn-info ms-2">
                            <i class="fas fa-broom me-2"></i>Solicitar Limpieza
                        </a>
                        <button id="btn-refrescar" class="btn btn-outline-primary ms-2">
                            <i class="fas fa-sync-alt me-2"></i>Actualizar
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estadísticas Habitaciones -->
        <div class="row mb-4">
            <div class="col-12 mb-3">
                <h4 class="mb-3"><i class="fas fa-bed me-2"></i>Habitaciones</h4>
            </div>
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="stat-card stat-disponible">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.HabitacionesDisponibles</h3>
                        <p class="stat-label">Disponibles</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="stat-card stat-ocupada">
                    <div class="stat-icon">
                        <i class="fas fa-bed"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.HabitacionesOcupadas</h3>
                        <p class="stat-label">Ocupadas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="stat-card stat-mantenimiento">
                    <div class="stat-icon">
                        <i class="fas fa-tools"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.HabitacionesMantenimiento</h3>
                        <p class="stat-label">Mantenimiento</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 mb-3">
                <div class="stat-card stat-limpieza">
                    <div class="stat-icon">
                        <i class="fas fa-broom"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.HabitacionesLimpieza</h3>
                        <p class="stat-label">Limpieza</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estadísticas Departamentos -->
        <div class="row mb-4">
            <div class="col-12 mb-3">
                <h4 class="mb-3"><i class="fas fa-building me-2"></i>Departamentos</h4>
            </div>
            <div class="col-md-4 col-sm-6 mb-3">
                <div class="stat-card stat-disponible">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.DepartamentosDisponibles</h3>
                        <p class="stat-label">Disponibles</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 mb-3">
                <div class="stat-card stat-ocupada">
                    <div class="stat-icon">
                        <i class="fas fa-bed"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.DepartamentosOcupados</h3>
                        <p class="stat-label">Ocupados</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 mb-3">
                <div class="stat-card stat-mantenimiento">
                    <div class="stat-icon">
                        <i class="fas fa-tools"></i>
                    </div>
                    <div class="stat-content">
                        <h3 class="stat-number">@Model.Estadisticas.DepartamentosMantenimiento</h3>
                        <p class="stat-label">Mantenimiento</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Información adicional -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="info-card">
                    <h5><i class="fas fa-calendar-check me-2"></i>Reservas Hoy</h5>
                    <p class="info-number">@Model.Estadisticas.ReservasHoy</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="info-card">
                    <h5><i class="fas fa-sign-out-alt me-2"></i>Check-outs Hoy</h5>
                    <p class="info-number">@Model.Estadisticas.CheckOutsHoy</p>
                </div>
            </div>
        </div>

        <!-- Plano del Hotel (diseño unificado: habitaciones = cama, departamentos = edificio; colores = estado) -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="mapa-container">
                    <div class="mapa-header d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <h3 class="mapa-title mb-0"><i class="fas fa-map me-2"></i>Plano del Hotel (hoy)</h3>
                        <div class="d-flex align-items-center gap-2">
                            <button type="button" class="btn btn-primary btn-sm" id="btn-ver-resumen-ocupacion" title="Ver ocupación y reservas de los próximos días, semanas o meses">
                                <i class="fas fa-calendar-week me-2"></i>Ver ocupación y reservas (próximos días/semanas/meses)
                            </button>
                        </div>
                        <div class="mapa-filtros" role="group" aria-label="Filtrar por estado">
                            <button class="btn-filtro active" data-filtro="todas" type="button">Todas</button>
                            <button class="btn-filtro" data-filtro="disponible" type="button">Disponibles</button>
                            <button class="btn-filtro" data-filtro="ocupada" type="button">Ocupadas</button>
                            <button class="btn-filtro" data-filtro="mantenimiento" type="button">Mantenimiento</button>
                            <button class="btn-filtro" data-filtro="limpieza" type="button">Limpieza</button>
                        </div>
                    </div>

                    <!-- Grid unificado: todas las unidades (habitación = icono cama, departamento = icono edificio) -->
                    <div class="mapa-habitaciones">
                        <div class="mapa-seccion">
                            <div class="mapa-grid mapa-grid-unificado">
                                @if (Model.Habitaciones != null)
                                {
                                    foreach (var habitacion in Model.Habitaciones)
                                    {
                                        <div class="mapa-habitacion-item" data-estado="@habitacion.Estado.ToLower()" data-id="@habitacion.IdHabitacion" data-tipo="habitacion">
                                            <div class="mapa-habitacion-box" style="background-color: @habitacion.ColorEstado; border-color: @habitacion.ColorEstado;">
                                                <div class="mapa-tipo-icono" title="Habitación"><i class="fas fa-bed"></i></div>
                                                <div class="mapa-numero-encima">@habitacion.NumeroHabitacion</div>
                                                <div class="mapa-habitacion-numero"><span>@habitacion.NumeroHabitacion</span></div>
                                                <div class="mapa-habitacion-estado">@(habitacion.EstadoLeyenda ?? habitacion.Estado)</div>
                                                <div class="mapa-habitacion-acciones">
                                                    <button type="button" class="btn btn-sm btn-outline-dark btn-eventos-unidad" title="Próximos eventos (reservas, check-in, check-out)" data-idhabitacion="@habitacion.IdHabitacion" data-iddepartamento="" data-numero="@habitacion.NumeroHabitacion" data-tipo="Hab."><i class="fas fa-info-circle"></i></button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary btn-convertir-unidad" title="Convertir a departamento" data-tipoactual="habitacion" data-id="@habitacion.IdHabitacion" data-numero="@habitacion.NumeroHabitacion"><i class="fas fa-building"></i></button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                @if (Model.Departamentos != null)
                                {
                                    foreach (var departamento in Model.Departamentos)
                                    {
                                        <div class="mapa-habitacion-item" data-estado="@departamento.Estado.ToLower()" data-id="@departamento.IdDepartamento" data-tipo="departamento">
                                            <div class="mapa-habitacion-box mapa-departamento" style="background-color: @departamento.ColorEstado; border-color: @departamento.ColorEstado;">
                                                <div class="mapa-tipo-icono" title="Departamento"><i class="fas fa-building"></i></div>
                                                <div class="mapa-numero-encima">@(string.IsNullOrEmpty(departamento.NumeroDepartamento) || departamento.NumeroDepartamento == "Sin número" ? "—" : departamento.NumeroDepartamento)</div>
                                                <div class="mapa-habitacion-numero"><span>@departamento.NumeroDepartamento</span></div>
                                                <div class="mapa-habitacion-estado">@(departamento.EstadoLeyenda ?? departamento.Estado)</div>
                                                <div class="mapa-habitacion-acciones">
                                                    <button type="button" class="btn btn-sm btn-outline-dark btn-eventos-unidad" title="Próximos eventos" data-idhabitacion="" data-iddepartamento="@departamento.IdDepartamento" data-numero="@departamento.NumeroDepartamento" data-tipo="Dep."><i class="fas fa-info-circle"></i></button>
                                                    <button type="button" class="btn btn-sm btn-outline-primary btn-convertir-unidad" title="Convertir a habitación" data-tipoactual="departamento" data-id="@departamento.IdDepartamento" data-numero="@departamento.NumeroDepartamento"><i class="fas fa-bed me-1"></i>Convertir</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Leyenda de colores (diseño mejorado) -->
                    <div class="mapa-leyenda mapa-leyenda-mejorada mt-4">
                        <div class="leyenda-titulo"><i class="fas fa-palette me-2"></i>Leyenda de colores</div>
                        <div class="leyenda-grid">
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-verde"></span><span class="leyenda-texto">Disponible / Libre</span></div>
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-rojo-oscuro"></span><span class="leyenda-texto">Check-out hoy</span></div>
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-granate"></span><span class="leyenda-texto">Ocupada +1 día o más</span></div>
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-rojo"></span><span class="leyenda-texto">Ocupada / Check-out pronto / No disponible</span></div>
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-morado"></span><span class="leyenda-texto">Reservada</span></div>
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-naranja"></span><span class="leyenda-texto">Check-in pronto</span></div>
                            <div class="leyenda-fila"><span class="leyenda-cuadro leyenda-azul"></span><span class="leyenda-texto">Limpieza</span></div>
                            <div class="leyenda-fila leyenda-tipos"><i class="fas fa-bed me-2"></i> Hab. &nbsp; <i class="fas fa-building me-2"></i> Dep.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Próximos eventos (por unidad) -->
        <div class="modal fade" id="modalProximosEventos" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-calendar-alt me-2"></i>Próximos eventos - <span id="modal-eventos-unidad"></span></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" id="modal-eventos-body">
                        <p class="text-muted">Cargando...</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Resumen ocupación y reservas (próximos días/semanas/meses) -->
        <div class="modal fade" id="modalResumenOcupacion" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-calendar-week me-2"></i>Ocupación y reservas</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-3">Vea qué está ocupado o con reserva en los próximos días, semanas o meses. Puede hacer <strong>check-out anticipado</strong> si un cliente se va antes o hay un problema.</p>
                        <div class="btn-group mb-3" role="group">
                            <button type="button" class="btn btn-outline-primary btn-resumen-dias active" data-dias="7">Próximos 7 días</button>
                            <button type="button" class="btn btn-outline-primary btn-resumen-dias" data-dias="30">Próximos 30 días</button>
                            <button type="button" class="btn btn-outline-primary btn-resumen-dias" data-dias="90">Próximos 3 meses</button>
                        </div>
                        <div id="resumen-ocupacion-loading" class="text-center py-4 text-muted" style="display:none;"><i class="fas fa-spinner fa-spin me-2"></i>Cargando...</div>
                        <div id="resumen-ocupacion-tabla" style="display:none;">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Unidad</th>
                                            <th>Tipo</th>
                                            <th>Estado actual</th>
                                            <th>Cliente / Próximos eventos</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody id="resumen-ocupacion-body"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Convertir unidad (habitación ↔ departamento) -->
        <div class="modal fade" id="modalConvertirUnidad" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-secondary text-white">
                        <h5 class="modal-title"><i class="fas fa-exchange-alt me-2"></i>Convertir unidad</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p id="modal-convertir-mensaje" class="mb-3">Para cambiar el tipo de unidad (habitación ↔ departamento) use la gestión de inventario.</p>
                        <p class="mb-0 small text-muted">Puede editar la habitación o el departamento desde el listado correspondiente y, en una futura versión, se permitirá cambiar el tipo desde aquí.</p>
                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <a href="@Url.Action("IndexHabitaciones", "Habitacion")" class="btn btn-outline-primary btn-sm"><i class="fas fa-bed me-1"></i>Gestión de habitaciones</a>
                            <a href="@Url.Action("IndexDepartamentos", "Departamento")" class="btn btn-outline-primary btn-sm"><i class="fas fa-building me-1"></i>Gestión de departamentos</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vista Detallada de Habitaciones -->
        @if (Model.Habitaciones != null && Model.Habitaciones.Any())
        {
            <div class="row mb-4">
                <div class="col-12">
                    <h3 class="mb-3"><i class="fas fa-bed me-2"></i>Detalles de Habitaciones</h3>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="habitaciones-detalle-grid">
                        @foreach (var habitacion in Model.Habitaciones)
                        {
                            <div class="habitacion-card" 
                                 data-estado="@habitacion.Estado" 
                                 data-id="@habitacion.IdHabitacion"
                                 data-fecha-checkin="@(habitacion.FechaCheckIn?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")"
                                 data-fecha-checkout="@(habitacion.FechaCheckOut?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")"
                                 data-fecha-inicio-limpieza="@(habitacion.FechaInicioLimpieza?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")">
                                <div class="habitacion-header" style="background-color: @habitacion.ColorEstado;">
                                    <div class="habitacion-numero">
                                        <i class="@habitacion.IconoEstado me-2"></i>
                                        Habitación @habitacion.NumeroHabitacion
                                    </div>
                                    <div class="habitacion-estado-badge">
                                        @habitacion.Estado
                                    </div>
                                </div>
                                <div class="habitacion-body">
                                    @if (habitacion.Estado == "Ocupada")
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-user me-2"></i>
                                            <strong>Cliente:</strong> @habitacion.ClienteActual
                                        </div>
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-users me-2"></i>
                                            <strong>Personas:</strong> @habitacion.CantidadPersonas / @habitacion.CapacidadMax
                                        </div>
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-calendar-check me-2"></i>
                                            <strong>Check-in:</strong> @(habitacion.FechaCheckIn?.ToString("dd/MM/yyyy") ?? "N/A")
                                        </div>
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-calendar-times me-2"></i>
                                            <strong>Check-out:</strong> @(habitacion.FechaCheckOut?.ToString("dd/MM/yyyy") ?? "N/A")
                                        </div>
                                        if (habitacion.DiasRestantes >= 0)
                                        {
                                            <div class="habitacion-info-item dias-restantes">
                                                <i class="fas fa-calendar-alt me-2"></i>
                                                <strong>Días restantes:</strong> @habitacion.DiasRestantes
                                            </div>
                                        }
                                        if (!string.IsNullOrEmpty(habitacion.TiempoOcupada))
                                        {
                                            <div class="habitacion-info-item" style="background: #fff3cd; padding: 0.75rem; border-radius: 8px; margin-top: 0.5rem;">
                                                <i class="fas fa-hourglass-half me-2" style="color: #856404;"></i>
                                                <strong style="color: #856404;">Tiempo ocupada:</strong> 
                                                <span style="color: #856404;">@habitacion.TiempoOcupada</span>
                                            </div>
                                        }
                                        if (!string.IsNullOrEmpty(habitacion.TiempoRestanteOcupacion))
                                        {
                                            <div class="habitacion-info-item" style="background: #d1ecf1; padding: 0.75rem; border-radius: 8px; margin-top: 0.5rem;">
                                                <i class="fas fa-clock me-2" style="color: #0c5460;"></i>
                                                <strong style="color: #0c5460;">Disponible en:</strong> 
                                                <span style="color: #0c5460;">@habitacion.TiempoRestanteOcupacion</span>
                                            </div>
                                        }
                                        
                                        <!-- Botones de Check-in/Check-out -->
                                        <div class="habitacion-actions mt-3">
                                            @if (habitacion.IdReserva > 0)
                                            {
                                                <!-- Verificar si ya se hizo check-in (reserva en proceso) -->
                                                if (habitacion.EstadoReserva == "Confirmada")
                                                {
                                                    <button type="button" class="btn btn-success btn-sm w-100 mb-2 btn-checkin" 
                                                            data-reserva-id="@habitacion.IdReserva"
                                                            data-habitacion-numero="@habitacion.NumeroHabitacion"
                                                            data-cliente="@habitacion.ClienteActual">
                                                        <i class="fas fa-sign-in-alt me-2"></i>Realizar Check-in
                                                    </button>
                                                }
                                                
                                                <!-- Verificar si está en proceso para permitir check-out (incl. anticipado) -->
                                                if (habitacion.EstadoReserva == "En Proceso" || habitacion.EstadoReserva == "Confirmada")
                                                {
                                                    <button type="button" class="btn btn-warning btn-sm w-100 btn-checkout" 
                                                            data-reserva-id="@habitacion.IdReserva"
                                                            data-habitacion-numero="@habitacion.NumeroHabitacion"
                                                            data-cliente="@habitacion.ClienteActual">
                                                        <i class="fas fa-sign-out-alt me-2"></i>Realizar Check-out (incl. anticipado)
                                                    </button>
                                                    <p class="small text-muted mt-1 mb-0">Si el cliente se va antes o hay un problema, puede hacer check-out anticipado aquí.</p>
                                                }
                                            }
                                        </div>
                                    }
                                    else if (habitacion.Estado == "Mantenimiento")
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-tools me-2"></i>
                                            <strong>Estado:</strong> En Mantenimiento
                                        </div>
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-users me-2"></i>
                                            <strong>Capacidad:</strong> @habitacion.CapacidadMax personas
                                        </div>
                                        <div class="habitacion-actions mt-3">
                                            <button type="button" class="btn btn-success btn-sm w-100 btn-cambiar-estado" 
                                                    data-habitacion-id="@habitacion.IdHabitacion"
                                                    data-estado-nuevo="Disponible">
                                                <i class="fas fa-check-circle me-2"></i>Marcar como Disponible
                                            </button>
                                        </div>
                                    }
                                    else if (habitacion.Estado == "Limpieza")
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-broom me-2"></i>
                                            <strong>Estado:</strong> En Limpieza
                                        </div>
                                        if (!string.IsNullOrEmpty(habitacion.DescripcionLimpieza))
                                        {
                                            <div class="habitacion-info-item">
                                                <i class="fas fa-info-circle me-2"></i>
                                                <strong>Descripción:</strong> @habitacion.DescripcionLimpieza
                                            </div>
                                        }
                                        if (!string.IsNullOrEmpty(habitacion.TiempoEnLimpieza))
                                        {
                                            <div class="habitacion-info-item" style="background: #d1ecf1; padding: 0.75rem; border-radius: 8px; margin-top: 0.5rem;">
                                                <i class="fas fa-hourglass-half me-2" style="color: #0c5460;"></i>
                                                <strong style="color: #0c5460;">Tiempo en limpieza:</strong> 
                                                <span style="color: #0c5460;">@habitacion.TiempoEnLimpieza</span>
                                            </div>
                                        }
                                        if (habitacion.FechaInicioLimpieza.HasValue)
                                        {
                                            <div class="habitacion-info-item">
                                                <i class="fas fa-calendar-check me-2"></i>
                                                <strong>Inicio:</strong> @habitacion.FechaInicioLimpieza.Value.ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                        }
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-users me-2"></i>
                                            <strong>Capacidad:</strong> @habitacion.CapacidadMax personas
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-users me-2"></i>
                                            <strong>Capacidad:</strong> @habitacion.CapacidadMax personas
                                        </div>
                                        <div class="habitacion-info-item disponible-message">
                                            <i class="fas fa-check-circle me-2"></i>
                                            Habitación disponible para reservar
                                        </div>
                                        <div class="habitacion-actions mt-3">
                                            <button type="button" class="btn btn-warning btn-sm w-100 mb-2 btn-cambiar-estado" 
                                                    data-habitacion-id="@habitacion.IdHabitacion"
                                                    data-estado-nuevo="Mantenimiento">
                                                <i class="fas fa-tools me-2"></i>Marcar en Mantenimiento
                                            </button>
                                            <a href="@Url.Action("Create", "SolicitudLimpieza", new { IdHabitacion = habitacion.IdHabitacion })" 
                                               class="btn btn-info btn-sm w-100">
                                                <i class="fas fa-broom me-2"></i>Solicitar Limpieza
                                            </a>
                                        </div>
                                    }
                                    <div class="habitacion-actions mt-2">
                                        <a href="@Url.Action("Create", "SolicitudLimpieza", new { IdHabitacion = habitacion.IdHabitacion })" 
                                           class="btn btn-sm btn-info w-100 mb-2">
                                            <i class="fas fa-broom me-2"></i>Solicitar Limpieza
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-primary w-100 btn-convertir-unidad btn-convertir-detalle" title="Convertir a departamento" data-tipoactual="habitacion" data-id="@habitacion.IdHabitacion" data-numero="@habitacion.NumeroHabitacion">
                                            <i class="fas fa-building me-2"></i>Convertir a departamento
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Vista Detallada de Departamentos -->
        @if (Model.Departamentos != null && Model.Departamentos.Any())
        {
            <div class="row mb-4">
                <div class="col-12">
                    <h3 class="mb-3"><i class="fas fa-building me-2"></i>Detalles de Departamentos</h3>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="habitaciones-detalle-grid">
                        @foreach (var departamento in Model.Departamentos)
                        {
                            <div class="habitacion-card" data-estado="@departamento.Estado" data-id="@departamento.IdDepartamento" data-tipo="departamento">
                                <div class="habitacion-header" style="background-color: @departamento.ColorEstado;">
                                    <div class="habitacion-numero">
                                        <i class="@departamento.IconoEstado me-2"></i>
                                        Departamento @departamento.NumeroDepartamento
                                    </div>
                                    <div class="habitacion-estado-badge">
                                        @departamento.Estado
                                    </div>
                                </div>
                                <div class="habitacion-body">
                                    <div class="habitacion-info-item">
                                        <i class="fas fa-building me-2"></i>
                                        <strong>Nombre:</strong> @departamento.Nombre
                                    </div>
                                    @if (departamento.Estado == "Ocupado")
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-user me-2"></i>
                                            <strong>Cliente:</strong> @departamento.ClienteActual
                                        </div>
                                    }
                                    else if (departamento.Estado == "Mantenimiento")
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-tools me-2"></i>
                                            <strong>Mantenimiento:</strong> @(!string.IsNullOrEmpty(departamento.DescripcionMantenimiento) ? departamento.DescripcionMantenimiento : "En mantenimiento")
                                        </div>
                                    }
                                    else if (departamento.Estado == "Limpieza")
                                    {
                                        <div class="habitacion-info-item">
                                            <i class="fas fa-broom me-2"></i>
                                            <strong>Limpieza:</strong> @(!string.IsNullOrEmpty(departamento.DescripcionMantenimiento) ? departamento.DescripcionMantenimiento : "En limpieza")
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="habitacion-info-item disponible-message">
                                            <i class="fas fa-check-circle me-2"></i>
                                            Departamento disponible para reservar
                                        </div>
                                    }
                                    <div class="habitacion-actions mt-2">
                                        <a href="@Url.Action("Create", "SolicitudLimpieza", new { IdDepartamento = departamento.IdDepartamento })" 
                                           class="btn btn-sm btn-info w-100 mb-2">
                                            <i class="fas fa-broom me-2"></i>Solicitar Limpieza
                                        </a>
                                        <button type="button" class="btn btn-sm btn-warning w-100 mb-2 btn-cambiar-estado" 
                                                data-habitacion-id="@departamento.IdDepartamento"
                                                data-tipo="departamento"
                                                data-estado-nuevo="Mantenimiento">
                                            <i class="fas fa-tools me-2"></i>Solicitar Mantenimiento
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-primary w-100 btn-convertir-unidad btn-convertir-detalle" title="Convertir a habitación" data-tipoactual="departamento" data-id="@departamento.IdDepartamento" data-numero="@departamento.NumeroDepartamento">
                                            <i class="fas fa-bed me-2"></i>Convertir a habitación
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- CSS específico -->
<link href="~/Content/Habitacion/estado-habitaciones.css" rel="stylesheet" />

<script>
    // Botón "Ver ocupación y reservas (próximos días/semanas/meses)"
    (function() {
        var btnVerResumen = document.getElementById('btn-ver-resumen-ocupacion');
        var modalResumen = document.getElementById('modalResumenOcupacion');
        var loadingEl = document.getElementById('resumen-ocupacion-loading');
        var tablaEl = document.getElementById('resumen-ocupacion-tabla');
        var bodyEl = document.getElementById('resumen-ocupacion-body');
        var cacheResumen = {};
        function cargarResumen(dias) {
            if (cacheResumen[dias]) {
                renderResumen(cacheResumen[dias], bodyEl);
                return;
            }
            if (loadingEl) loadingEl.style.display = 'block';
            if (tablaEl) tablaEl.style.display = 'none';
            fetch('@Url.Action("GetResumenOcupacionProximosDias", "Habitacion")' + '?dias=' + dias)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (loadingEl) loadingEl.style.display = 'none';
                    if (data.ok && data.unidades) {
                        cacheResumen[dias] = data.unidades;
                        renderResumen(data.unidades, bodyEl);
                        if (tablaEl) tablaEl.style.display = 'block';
                    } else {
                        if (bodyEl) bodyEl.innerHTML = '<tr><td colspan="5" class="text-muted">No se pudo cargar el resumen.</td></tr>';
                        if (tablaEl) tablaEl.style.display = 'block';
                    }
                })
                .catch(function() {
                    if (loadingEl) loadingEl.style.display = 'none';
                    if (bodyEl) bodyEl.innerHTML = '<tr><td colspan="5" class="text-danger">Error al cargar.</td></tr>';
                    if (tablaEl) tablaEl.style.display = 'block';
                });
        }
        function renderResumen(unidades, tbody) {
            if (!tbody) return;
            var html = '';
            unidades.forEach(function(u) {
                var tipoLabel = u.tipo === 'habitacion' ? 'Hab.' : 'Dep.';
                var eventosStr = '';
                if (u.eventos && u.eventos.length) {
                    eventosStr = u.eventos.slice(0, 6).map(function(e) { return e.fecha + ' ' + e.tipo + (e.descripcion ? ' (' + e.descripcion + ')' : ''); }).join('; ');
                    if (u.eventos.length > 6) eventosStr += '...';
                } else {
                    eventosStr = u.clienteActual || '—';
                }
                var accion = '';
                if (u.tipo === 'habitacion' && u.estadoActual === 'Ocupada' && u.idReserva > 0) {
                    accion = '<button type="button" class="btn btn-sm btn-warning btn-checkout-antecipado" data-reserva-id="' + u.idReserva + '" data-numero="' + u.numero + '" data-cliente="' + (u.clienteActual || '') + '"><i class="fas fa-sign-out-alt me-1"></i>Check-out anticipado</button>';
                } else {
                    accion = '<span class="text-muted">—</span>';
                }
                html += '<tr><td>' + u.numero + '</td><td>' + tipoLabel + '</td><td>' + (u.estadoLeyenda || u.estadoActual) + '</td><td class="small">' + eventosStr + '</td><td>' + accion + '</td></tr>';
            });
            tbody.innerHTML = html || '<tr><td colspan="5" class="text-muted">Sin datos.</td></tr>';
            // Enlazar botones check-out anticipado
            tbody.querySelectorAll('.btn-checkout-antecipado').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var reservaId = this.getAttribute('data-reserva-id');
                    var numero = this.getAttribute('data-numero');
                    var cliente = this.getAttribute('data-cliente');
                    if (document.getElementById('checkout-habitacion-numero')) document.getElementById('checkout-habitacion-numero').textContent = numero;
                    if (document.getElementById('checkout-cliente')) document.getElementById('checkout-cliente').textContent = cliente;
                    if (document.getElementById('checkout-fecha-hora')) {
                        var ahora = new Date();
                        document.getElementById('checkout-fecha-hora').textContent = ahora.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                    }
                    window.reservaIdSeleccionadaCheckout = reservaId;
                    var modalCheckOut = document.getElementById('modalCheckOut');
                    if (modalResumen && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        var inst = bootstrap.Modal.getInstance(modalResumen);
                        if (inst) inst.hide();
                    }
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal && modalCheckOut) {
                        var modalCheckOutInstance = new bootstrap.Modal(modalCheckOut);
                        modalCheckOutInstance.show();
                    }
                    var confirmBtn = document.getElementById('btnConfirmarCheckOut');
                    var modalCheckOutEl = document.getElementById('modalCheckOut');
                    if (confirmBtn) {
                        confirmBtn.addEventListener('click', function confirmarCheckoutDesdeResumen(ev) {
                            if (!window.reservaIdSeleccionadaCheckout) return;
                            ev.stopImmediatePropagation();
                            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                            var formData = new FormData();
                            formData.append('IdReserva', parseInt(window.reservaIdSeleccionadaCheckout));
                            formData.append('__RequestVerificationToken', token);
                            confirmBtn.disabled = true;
                            confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Procesando...';
                            fetch('@Url.Action("CheckOut", "Habitacion")', { method: 'POST', credentials: 'same-origin', body: formData })
                                .then(function(r) { return r.json(); })
                                .then(function(data) {
                                    if (data.success) {
                                        if (typeof bootstrap !== 'undefined' && modalCheckOutEl) { var m = bootstrap.Modal.getInstance(modalCheckOutEl); if (m) m.hide(); }
                                        alert('Check-out realizado correctamente.');
                                        window.location.reload();
                                    } else {
                                        alert('Error: ' + (data.message || 'No se pudo realizar el check-out.'));
                                        confirmBtn.disabled = false;
                                        confirmBtn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar Check-out';
                                    }
                                })
                                .catch(function() {
                                    confirmBtn.disabled = false;
                                    confirmBtn.innerHTML = '<i class="fas fa-check me-2"></i>Confirmar Check-out';
                                });
                        }, { once: true });
                    }
                });
            });
        }
        if (btnVerResumen) {
            btnVerResumen.addEventListener('click', function() {
                var modalInstance = modalResumen && typeof bootstrap !== 'undefined' && bootstrap.Modal ? new bootstrap.Modal(modalResumen) : null;
                if (modalInstance) modalInstance.show();
                var activo = document.querySelector('.btn-resumen-dias.active');
                cargarResumen(activo ? parseInt(activo.getAttribute('data-dias')) : 7);
            });
        }
        document.querySelectorAll('.btn-resumen-dias').forEach(function(btn) {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.btn-resumen-dias').forEach(function(b) { b.classList.remove('active'); });
                this.classList.add('active');
                cargarResumen(parseInt(this.getAttribute('data-dias')));
            });
        });
    })();

    // Botón Convertir (habitación ↔ departamento): mostrar modal con enlaces a gestión
    function initConvertirBotones() {
        var modalEl = document.getElementById('modalConvertirUnidad');
        var msgEl = document.getElementById('modal-convertir-mensaje');
        document.querySelectorAll('.btn-convertir-unidad, .btn-convertir-detalle').forEach(function(btn) {
            if (btn._convertirInit) return;
            btn._convertirInit = true;
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var tipoActual = this.getAttribute('data-tipoactual');
                var numero = this.getAttribute('data-numero');
                var destino = tipoActual === 'habitacion' ? 'departamento' : 'habitación';
                if (msgEl) msgEl.textContent = 'Para convertir la unidad ' + numero + ' en ' + destino + ', utilice la gestión de inventario (habitaciones o departamentos) o contacte al administrador. En una futura versión se podrá cambiar el tipo desde aquí.';
                if (modalEl && typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                    var m = new bootstrap.Modal(modalEl);
                    m.show();
                } else if (modalEl) {
                    modalEl.style.display = 'block';
                    modalEl.classList.add('show');
                }
            });
        });
    }
    initConvertirBotones();

    // Modal Próximos eventos por unidad
    (function() {
        document.querySelectorAll('.btn-eventos-unidad').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var idHab = this.getAttribute('data-idhabitacion') || '';
                var idDep = this.getAttribute('data-iddepartamento') || '';
                var numero = this.getAttribute('data-numero') || '';
                var tipo = this.getAttribute('data-tipo') || '';
                var titulo = tipo + ' ' + numero;
                document.getElementById('modal-eventos-unidad').textContent = titulo;
                document.getElementById('modal-eventos-body').innerHTML = '<p class="text-muted">Cargando...</p>';
                var modal = new bootstrap.Modal(document.getElementById('modalProximosEventos'));
                modal.show();
                var url = '@Url.Action("GetProximosEventosUnidad", "Habitacion")' + '?idHabitacion=' + idHab + '&idDepartamento=' + idDep + '&dias=14';
                fetch(url).then(function(r) { return r.json(); }).then(function(data) {
                    var html = '';
                    if (data.ok && data.eventos && data.eventos.length) {
                        html = '<ul class="list-group list-group-flush">';
                        data.eventos.forEach(function(e) {
                            html += '<li class="list-group-item d-flex justify-content-between"><span>' + e.fecha + ' - ' + e.tipo + '</span><span class="text-muted">' + (e.descripcion || '') + '</span></li>';
                        });
                        html += '</ul>';
                    } else {
                        html = '<p class="text-muted mb-0">No hay eventos (reservas, check-in, check-out) en los próximos 14 días.</p>';
                    }
                    document.getElementById('modal-eventos-body').innerHTML = html;
                }).catch(function() {
                    document.getElementById('modal-eventos-body').innerHTML = '<p class="text-danger">Error al cargar eventos.</p>';
                });
            });
        });
    })();

    // Función para actualizar tiempos en tiempo real sin recargar la página
    function actualizarTiempos() {
        // Actualizar tiempo ocupada
        document.querySelectorAll('.habitacion-card[data-estado="Ocupada"]').forEach(function(card) {
            var fechaCheckIn = card.getAttribute('data-fecha-checkin');
            if (fechaCheckIn) {
                var fechaInicio = new Date(fechaCheckIn);
                var ahora = new Date();
                var tiempoTranscurrido = ahora - fechaInicio;
                var tiempoFormateado = formatearTiempo(tiempoTranscurrido);
                
                var tiempoElement = card.querySelector('.tiempo-ocupada-actualizado');
                if (!tiempoElement) {
                    var infoItem = card.querySelector('.habitacion-info-item[style*="background: #fff3cd"]');
                    if (infoItem) {
                        tiempoElement = infoItem.querySelector('span');
                        if (tiempoElement) {
                            tiempoElement.textContent = tiempoFormateado;
                        }
                    }
                }
            }
        });

        // Actualizar tiempo en limpieza
        document.querySelectorAll('.habitacion-card[data-estado="Limpieza"]').forEach(function(card) {
            var fechaInicioLimpieza = card.getAttribute('data-fecha-inicio-limpieza');
            if (fechaInicioLimpieza) {
                var fechaInicio = new Date(fechaInicioLimpieza);
                var ahora = new Date();
                var tiempoTranscurrido = ahora - fechaInicio;
                var tiempoFormateado = formatearTiempo(tiempoTranscurrido);
                
                var tiempoElement = card.querySelector('.tiempo-limpieza-actualizado');
                if (!tiempoElement) {
                    var infoItem = card.querySelector('.habitacion-info-item[style*="background: #d1ecf1"]');
                    if (infoItem) {
                        tiempoElement = infoItem.querySelector('span');
                        if (tiempoElement) {
                            tiempoElement.textContent = tiempoFormateado;
                        }
                    }
                }
            }
        });
    }

    // Función auxiliar para formatear tiempo
    function formatearTiempo(milisegundos) {
        var segundos = Math.floor(milisegundos / 1000);
        var minutos = Math.floor(segundos / 60);
        var horas = Math.floor(minutos / 60);
        var dias = Math.floor(horas / 24);

        if (dias > 0) {
            horas = horas % 24;
            if (horas > 0) {
                return dias + ' día' + (dias > 1 ? 's' : '') + ', ' + horas + ' hora' + (horas > 1 ? 's' : '');
            }
            return dias + ' día' + (dias > 1 ? 's' : '');
        } else if (horas > 0) {
            minutos = minutos % 60;
            if (minutos > 0) {
                return horas + ' hora' + (horas > 1 ? 's' : '') + ', ' + minutos + ' minuto' + (minutos > 1 ? 's' : '');
            }
            return horas + ' hora' + (horas > 1 ? 's' : '');
        } else if (minutos > 0) {
            return minutos + ' minuto' + (minutos > 1 ? 's' : '');
        } else {
            return 'Menos de 1 minuto';
        }
    }

    // Auto-refresh cada 15 segundos (más frecuente para tiempo real)
    // DESACTIVADO: Recarga automática de página
    // var autoRefreshInterval = setInterval(function () {
    //     // Usar window.location.href para evitar problemas de contexto
    //     setTimeout(function() {
    //         window.location.href = window.location.href.split('#')[0];
    //     }, 100);
    // }, 15000);

    
    // Función para actualizar el estado completo sin recargar la página
    function actualizarEstadoCompleto() {
        // Mostrar indicador de carga sutil
        var btnRefrescar = document.getElementById('btn-refrescar');
        var iconoOriginal = btnRefrescar ? btnRefrescar.innerHTML : '';
        if (btnRefrescar) {
            btnRefrescar.disabled = true;
            btnRefrescar.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Actualizando...';
        }
        
        // Hacer fetch a la misma página para obtener el HTML actualizado
        fetch(window.location.href, {
            method: 'GET',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            },
            cache: 'no-cache'
        })
        .then(response => {
            if (!response.ok) {
                throw new Error('Error al obtener datos');
            }
            return response.text();
        })
        .then(html => {
            // Crear un elemento temporal para parsear el HTML
            var tempDiv = document.createElement('div');
            tempDiv.innerHTML = html;
            
            // Actualizar el contenedor principal
            var nuevoContenido = tempDiv.querySelector('.estado-habitaciones-container');
            var contenedorActual = document.querySelector('.estado-habitaciones-container');
            
            if (nuevoContenido && contenedorActual) {
                // Guardar posición de scroll
                var scrollPosition = window.pageYOffset || document.documentElement.scrollTop;
                
                // Actualizar contenido
                contenedorActual.innerHTML = nuevoContenido.innerHTML;
                
                // Restaurar posición de scroll
                window.scrollTo(0, scrollPosition);
                
                // Re-inicializar eventos después de actualizar
                setTimeout(function() {
                    inicializarEventos();
                    actualizarTiempos();
                    
                    // Restaurar botón
                    if (btnRefrescar) {
                        btnRefrescar.disabled = false;
                        btnRefrescar.innerHTML = iconoOriginal;
                    }
                }, 100);
            } else {
                // Si no se puede actualizar parcialmente, recargar
                window.location.reload();
            }
        })
        .catch(error => {
            // Si falla, recargar la página completa
            if (btnRefrescar) {
                btnRefrescar.disabled = false;
                btnRefrescar.innerHTML = iconoOriginal;
            }
            // No recargar automáticamente para evitar loops
        });
    }
    
    // Función para inicializar eventos después de actualizar el contenido
    function inicializarEventos() {
        initConvertirBotones();
        // Re-inicializar eventos de check-in y check-out
        var reservaIdSeleccionada = null;
        var modalCheckIn = document.getElementById('modalCheckIn');
        var modalCheckOut = document.getElementById('modalCheckOut');
        var btnConfirmarCheckIn = document.getElementById('btnConfirmarCheckIn');
        var btnConfirmarCheckOut = document.getElementById('btnConfirmarCheckOut');
        
        // Event listeners para botones de check-in
        document.querySelectorAll('.btn-checkin').forEach(function(btn) {
            btn.addEventListener('click', function() {
                reservaIdSeleccionada = this.getAttribute('data-reserva-id');
                var habitacionNumero = this.getAttribute('data-habitacion-numero');
                var cliente = this.getAttribute('data-cliente');
                
                if (document.getElementById('checkin-habitacion-numero')) {
                    document.getElementById('checkin-habitacion-numero').textContent = habitacionNumero;
                }
                if (document.getElementById('checkin-cliente')) {
                    document.getElementById('checkin-cliente').textContent = cliente;
                }
                // Actualizar fecha y hora dinámicamente
                if (document.getElementById('checkin-fecha-hora')) {
                    var ahora = new Date();
                    var fechaHora = ahora.toLocaleDateString('es-ES', { 
                        day: '2-digit', 
                        month: '2-digit', 
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    document.getElementById('checkin-fecha-hora').textContent = fechaHora;
                }
                
                if (modalCheckInInstance) {
                    modalCheckInInstance.show();
                } else if (modalCheckIn) {
                    modalCheckIn.style.display = 'block';
                    modalCheckIn.classList.add('show');
                }
            });
        });
        
        // Event listeners para botones de check-out
        document.querySelectorAll('.btn-checkout').forEach(function(btn) {
            btn.addEventListener('click', function() {
                reservaIdSeleccionada = this.getAttribute('data-reserva-id');
                var habitacionNumero = this.getAttribute('data-habitacion-numero');
                var cliente = this.getAttribute('data-cliente');
                
                if (document.getElementById('checkout-habitacion-numero')) {
                    document.getElementById('checkout-habitacion-numero').textContent = habitacionNumero;
                }
                if (document.getElementById('checkout-cliente')) {
                    document.getElementById('checkout-cliente').textContent = cliente;
                }
                // Actualizar fecha y hora dinámicamente
                if (document.getElementById('checkout-fecha-hora')) {
                    var ahora = new Date();
                    var fechaHora = ahora.toLocaleDateString('es-ES', { 
                        day: '2-digit', 
                        month: '2-digit', 
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    document.getElementById('checkout-fecha-hora').textContent = fechaHora;
                }
                
                if (modalCheckOutInstance) {
                    modalCheckOutInstance.show();
                } else if (modalCheckOut) {
                    modalCheckOut.style.display = 'block';
                    modalCheckOut.classList.add('show');
                }
            });
        });
        
        // Re-configurar confirmación de check-in
        if (btnConfirmarCheckIn) {
            var nuevoBtnCheckIn = btnConfirmarCheckIn.cloneNode(true);
            btnConfirmarCheckIn.parentNode.replaceChild(nuevoBtnCheckIn, btnConfirmarCheckIn);
            
            nuevoBtnCheckIn.addEventListener('click', function() {
                if (!reservaIdSeleccionada) {
                    showNotificationModal('error', 'Error', 'No se seleccionó una reserva.');
                    return;
                }
                
                nuevoBtnCheckIn.disabled = true;
                nuevoBtnCheckIn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Procesando...';
                
                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
