@model HotelPrado.Abstracciones.Modelos.Habitaciones.HabitacionesDTO

@{
    ViewBag.Title = "EditarImagenes";
}

<h2>Editar Imágenes del Habitacion</h2>

@if (TempData["ErrorImagenes"] != null)
{
    <div class="alert alert-warning">@TempData["ErrorImagenes"]</div>
}
@if (TempData["MensajeImagenes"] != null)
{
    <div class="alert alert-success">@TempData["MensajeImagenes"]</div>
}

<div class="card p-3">
    <h4>Habitacion: @Model.NumeroHabitacion</h4>

    @if (!string.IsNullOrEmpty(Model.UrlImagenes))
    {
        <h5>Imágenes Actuales:</h5>
        <div class="d-flex flex-wrap">
            @foreach (var imagenUrl in Model.UrlImagenes.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
            {
                var url = (imagenUrl ?? "").Trim();
                if (string.IsNullOrWhiteSpace(url)) { continue; }
                var urlNorm = url.TrimStart('/');
                if (urlNorm.StartsWith("imagenes/", StringComparison.OrdinalIgnoreCase) || urlNorm.StartsWith("Uploads/", StringComparison.OrdinalIgnoreCase))
                {
                    var fileName = urlNorm.Contains("/") ? urlNorm.Substring(urlNorm.LastIndexOf('/') + 1) : urlNorm;
                    urlNorm = "Content/Imagenes/" + fileName;
                }
                var srcUrl = url.StartsWith("~") ? Url.Content(url) : Url.Content("~/" + urlNorm);
                <div class="m-2 text-center">
                    <img src="@srcUrl" alt="Imagen Habitación" class="img-thumbnail" style="width: 100px; height: 100px; object-fit: cover;" onerror="this.onerror=null; this.style.background='#f0f0f0'; this.alt='Imagen no encontrada'; this.title='Si la imagen no carga, elimínela y use Agregar imágenes para subir de nuevo.';">
                    <small class="d-block text-muted mt-1" style="font-size:0.75rem;">Si no se ve, elimine y suba de nuevo</small>
                    @using (Html.BeginForm("EliminarImagen", "Habitacion", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.IdHabitacion" />
                        <input type="hidden" name="imagenUrl" value="@url" />
                        <button type="submit" class="btn btn-danger btn-sm mt-1">Eliminar</button>
                    }
                </div>
            }
        </div>
    }

    <h5 class="mt-4">Agregar nuevas imágenes:</h5>

    @using (Html.BeginForm("ActualizarImagenes", "Habitacion", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.IdHabitacion" />

        <div class="form-group mt-3">
            <input type="file" name="imagenes" multiple class="form-control" accept="image/*,.heic,image/heic" />
        </div>

        <button type="submit" class="btn btn-success mt-3">Agregar Imágenes</button>
        @Html.ActionLink("Cancelar", "IndexHabitaciones", null, new { @class = "btn btn-secondary mt-3" })
    }
</div>
