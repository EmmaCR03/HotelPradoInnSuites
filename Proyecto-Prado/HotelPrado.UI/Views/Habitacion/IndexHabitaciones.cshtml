@model IEnumerable<HotelPrado.Abstracciones.Modelos.Habitaciones.HabitacionesDTO>

@{
    ViewBag.Title = "IndexHabitaciones";
}

<h2>Todas las habitaciones</h2>

<p>
    @Html.ActionLink("Create New", "Crear", null, new { @class = "btn btn-success" })
</p>

<!-- Barra de Búsqueda -->
<form method="get" asp-action="Listar" style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">

    <div>
        <label for="estado" style="font-weight: bold;">Estado:</label>
        <select name="estado" class="input-style">
            <option value="">Todos</option>
            <option value="Disponible">Disponible</option>
            <option value="Ocupado">Ocupado</option>
            <option value="En Mantenimiento">En Mantenimiento</option>
        </select>
    </div>

    <button type="submit" class="btn-filtrar">Filtrar</button>
</form>


<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4 habitacion-item">
            <div class="border p-3 rounded shadow-sm hover-effect" data-bs-toggle="collapse" data-bs-target="#habitacion-@item.IdHabitacion" aria-expanded="false" aria-controls="habitacion-@item.IdHabitacion">
                <h5>Habitación @item.NumeroHabitacion</h5>
                <p><strong>Capacidad:</strong> @item.CapacidadMax personas</p>
                <p><strong>Estado:</strong> @item.Estado</p>
            </div>

            <div id="habitacion-@item.IdHabitacion" class="collapse">
                <div class="border p-3 mt-2 rounded shadow-sm">
                    <p><strong>Precio 1P:</strong> @item.PrecioPorNoche1P</p>
                    <p><strong>Precio 2P:</strong> @item.PrecioPorNoche2P</p>
                    <p><strong>Precio 3P:</strong> @item.PrecioPorNoche3P</p>
                    <p><strong>Precio 4P:</strong> @item.PrecioPorNoche4P</p>
                    <p><strong>Tipo:</strong> @item.IdTipoHabitacion</p>

                    <div class="mb-3">
                        @if (item.ListaImagenes.Any())
                        {
                            foreach (var imagenUrl in item.ListaImagenes)
                            {
                                <img src="@Url.Content(imagenUrl)" alt="Imagen Departamento" class="lazy" data-src="@Url.Content(imagenUrl)" style="width: 100px; height: 100px; margin-right: 5px;" />
                            }
                        }
                        else
                        {
                            <img src="@Url.Content("/imagenes/default.jpg")" alt="Imagen por defecto" class="lazy" data-src="@Url.Content("/imagenes/default.jpg")" style="width: 100px; height: 100px;" />
                        }
                    </div>

                    <div class="d-flex justify-content-between">
                        @Html.ActionLink("Ver Citas Disponibles", "IndexCitas", "Citas", new { id = item.IdHabitacion }, new { @class = "btn btn-outline-primary btn-sm" })

                    </div>

                    <div class="d-flex justify-content-between mt-2">

                        @Html.ActionLink("Editar Imágenes", "EditarImagenes", "Departamento", new { id = item.IdHabitacion }, new { @class = "btn btn-outline-info btn-sm" })
                    </div>

                    <div class="d-flex justify-content-between">
                        @Html.ActionLink("Detalles", "Details", new { id = item.IdHabitacion }, new { @class = "btn btn-outline-info btn-sm" })
                        @Html.ActionLink("Editar", "Edit", new { id = item.IdHabitacion }, new { @class = "btn btn-outline-warning btn-sm" })
                        @Html.ActionLink("Eliminar", "Delete", new { id = item.IdHabitacion }, new { @class = "btn btn-outline-danger btn-sm" })
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Scripts para interactividad -->
<script>
    // Filtro de búsqueda
    document.getElementById("search").addEventListener("input", function () {
        let filter = this.value.toLowerCase();
        let items = document.querySelectorAll(".departamento-item");

        items.forEach(function (item) {
            let nombre = item.querySelector("h5").innerText.toLowerCase();
            if (nombre.includes(filter)) {
                item.style.display = "block";
            } else {
                item.style.display = "none";
            }
        });
    });

    // Lazy Loading de Imágenes
    document.addEventListener("DOMContentLoaded", function () {
        let lazyImages = [].slice.call(document.querySelectorAll("img.lazy"));

        if ("IntersectionObserver" in window) {
            let lazyImageObserver = new IntersectionObserver(function (entries, observer) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        let lazyImage = entry.target;
                        lazyImage.src = lazyImage.dataset.src;
                        lazyImage.classList.remove("lazy");
                        lazyImageObserver.unobserve(lazyImage);
                    }
                });
            });

            lazyImages.forEach(function (lazyImage) {
                lazyImageObserver.observe(lazyImage);
            });
        }
    });

    // Efecto Hover
    document.querySelectorAll('.hover-effect').forEach(function (element) {
        element.addEventListener('mouseover', function () {
            element.style.transform = 'scale(1.05)';
            element.style.boxShadow = '0 4px 8px rgba(0, 0, 0, 0.2)';
        });
        element.addEventListener('mouseout', function () {
            element.style.transform = 'scale(1)';
            element.style.boxShadow = 'none';
        });
    });
</script>

<!-- Estilos para hover y botones -->
<style>
    .hover-effect {
        transition: all 0.3s ease;
    }

        .hover-effect:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

    /* Estilo para el filtro de búsqueda */
    #search {
        max-width: 300px;
        margin-bottom: 20px;
    }

    /* Estilo de los botones */
    .btn-outline-primary, .btn-outline-info, .btn-outline-warning, .btn-outline-danger {
        width: 100%;
        text-align: center;

    }
    .input-style {
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 16px;
    }

    .btn-filtrar {
        background-color: #007bff;
        color: white;
        border: none;
        padding: 10px 15px;
        border-radius: 5px;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-filtrar:hover {
            background-color: #0056b3;
        }
</style>