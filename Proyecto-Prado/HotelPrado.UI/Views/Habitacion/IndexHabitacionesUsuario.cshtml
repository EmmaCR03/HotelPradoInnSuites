@model IEnumerable<HotelPrado.Abstracciones.Modelos.Habitaciones.HabitacionesDTO>

@{
    ViewBag.Title = "IndexHabitacionesUsuario";
}

<h2>IndexHabitacionesUsuario</h2>


<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.NumeroHabitacion)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.PrecioFinal)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.TotalPrecio)

        </th>

        <th>
            @Html.DisplayNameFor(model => model.TotalNoches)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IdTipoHabitacion)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.Capacidad)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NumeroHabitacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PrecioFinal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TotalPrecio)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TotalNoches)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdTipoHabitacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Capacidad)
            </td>

        </tr>
    }

</table>