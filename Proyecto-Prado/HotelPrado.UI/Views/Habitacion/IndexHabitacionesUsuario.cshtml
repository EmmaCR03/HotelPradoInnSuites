@model IEnumerable<HotelPrado.Abstracciones.Modelos.Habitaciones.HabitacionesDTO>

@{
    ViewBag.Title = "Habitaciones Disponibles";
    var checkIn = ViewBag.CheckIn as DateTime?;
    var checkOut = ViewBag.CheckOut as DateTime?;
}

<!-- Estilos mejorados -->
<link href="~/Content/aos.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    :root {
        --primary-color: #2c3e50;
        --secondary-color: #3498db;
        --accent-color: #e74c3c;
        --light-color: #ecf0f1;
        --dark-color: #2c3e50;
        --success-color: #27ae60;
        --text-color: #34495e;
        --text-light: #7f8c8d;
        --box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        --transition: all 0.3s ease;
    }

    body {
        font-family: 'Montserrat', sans-serif;
        color: var(--text-color);
        background-color: #f9f9f9;
    }

    .display-4 {
        font-weight: 700;
        color: var(--primary-color);
        position: relative;
        padding-bottom: 15px;
    }

        .display-4:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 3px;
            background: var(--secondary-color);
        }

    .room-container {
        perspective: 1000px;
    }

    .room-item {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--box-shadow);
        transition: var(--transition);
        transform-style: preserve-3d;
        position: relative;
        margin-bottom: 30px;
    }

        .room-item:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
        }

    .room-image {
        height: 250px;
        width: 100%;
        object-fit: cover;
        border-bottom: 4px solid var(--secondary-color);
    }

    .room-info {
        padding: 25px;
        position: relative;
    }

    .room-badge {
        position: absolute;
        top: -20px;
        right: 20px;
        background: var(--accent-color);
        color: white;
        padding: 8px 15px;
        border-radius: 30px;
        font-weight: 600;
        box-shadow: 0 5px 15px rgba(231, 76, 60, 0.3);
    }

    .room-features {
        list-style: none;
        padding: 0;
        margin: 20px 0;
    }

        .room-features li {
            padding: 8px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            align-items: center;
        }

            .room-features li i {
                margin-right: 10px;
                color: var(--secondary-color);
                width: 20px;
                text-align: center;
            }

    .price-total {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--success-color);
        margin: 20px 0;
        text-align: center;
        background: rgba(39, 174, 96, 0.1);
        padding: 10px;
        border-radius: 8px;
    }

    .btn-reserve {
        background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
        border: none;
        padding: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border-radius: 8px;
        width: 100%;
        color: white;
        transition: var(--transition);
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);
    }

        .btn-reserve:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(52, 152, 219, 0.4);
            color: white;
        }

    .no-rooms {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
        max-width: 600px;
        margin: 0 auto;
    }

        .no-rooms i {
            font-size: 3rem;
            color: var(--accent-color);
            margin-bottom: 20px;
        }

    .date-info {
        background: var(--light-color);
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 30px;
        text-align: center;
    }

        .date-info strong {
            color: var(--primary-color);
        }
</style>

<section id="room" class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h3 class="display-4 fw-bold">Habitaciones Disponibles</h3>
            <p class="text-muted">Descubre el confort perfecto para tu estadía</p>

            @if (checkIn != null && checkOut != null)
            {
                <div class="date-info">
                    <i class="far fa-calendar-alt me-2"></i>
                    <strong>Check-in:</strong> @checkIn.Value.ToString("dd MMM yyyy")
                    <i class="fas fa-arrow-right mx-3"></i>
                    <strong>Check-out:</strong> @checkOut.Value.ToString("dd MMM yyyy")
                    (@((checkOut.Value - checkIn.Value).Days) noches)
                </div>
            }
        </div>

        <div class="row justify-content-center">
            @if (Model != null && Model.Any())
            {
                var hab = Model.First();
                <div class="col-lg-8 room-container">
                    <div class="room-item">


                        <div class="room-info">
                            <h4 class="fw-bold mb-3">Habitación @hab.NumeroHabitacion</h4>

                            <ul class="room-features">
                                <li>
                                    <i class="fas fa-user-friends"></i>
                                    <strong>Capacidad:</strong> @hab.Capacidad personas
                                </li>

                                <li>
                                    <i class="fas fa-money-bill-wave"></i>
                                    <strong>Precio por noche:</strong> ₡@hab.PrecioFinal.ToString("0.00")
                                </li>
                                <li>
                                    <i class="far fa-calendar-check"></i>
                                    <strong>Total noches:</strong> @hab.TotalNoches noches
                                </li>
                            </ul>

                            <div class="price-total">
                                <i class="fas fa-tag me-2"></i>Total: ₡@hab.TotalPrecio.ToString("0.00")
                            </div>

                            <a href="@Url.Action("ConfirmarReserva", "Reservas", new {
                                 id = hab.IdHabitacion,
                                 checkIn = checkIn?.ToString("yyyy-MM-dd"),
                                 checkOut = checkOut?.ToString("yyyy-MM-dd"),
                                 totalPrecio = hab.TotalPrecio,
                                 cantidadPersonas = hab.Capacidad })"
                               class="btn btn-reserve">
                                <i class="fas fa-calendar-check me-2"></i> RESERVAR AHORA
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-md-8 text-center no-rooms">
                    <i class="fas fa-calendar-times"></i>
                    <h4 class="fw-bold mb-3">No hay disponibilidad</h4>
                    <p class="mb-4">Lo sentimos, no encontramos habitaciones disponibles para las fechas seleccionadas.</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-2"></i>Volver a intentar
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- Scripts -->
<script src="~/Scripts/aos.js"></script>
<script>
    AOS.init({
        duration: 800,
        easing: 'ease-in-out'
    });

    // Efecto hover más suave
    document.querySelectorAll('.room-item').forEach(item => {
        item.addEventListener('mouseenter', function () {
            this.style.transition = 'transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
        });

        item.addEventListener('mouseleave', function () {
            this.style.transition = 'transform 0.3s ease-out';
        });
    });
</script>