@model IEnumerable<HotelPrado.Abstracciones.Modelos.Habitaciones.HabitacionesDTO>

@{
    ViewBag.Title = "Habitaciones Disponibles";
    var checkIn = ViewBag.CheckIn as DateTime?;
    var checkOut = ViewBag.CheckOut as DateTime?;
}

<!-- Estilos -->
<link href="~/Content/aos.css" rel="stylesheet" />
<link href="~/Content/Hotel/habitaciones.css" rel="stylesheet" />

<section id="room" class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h3 class="display-4 fw-bold text-primary">Habitaciones Disponibles</h3>
            <p class="text-muted">Encuentra la mejor habitación para tu estadía.</p>
        </div>
        <div class="row justify-content-center">
            @if (Model != null && Model.Any())
            {
                var hab = Model.First(); // Mostrar solo la primera habitación disponible
                <div class="col-md-6 d-flex justify-content-center">
                    <div class="room-item shadow-lg rounded" style="max-width: 500px; width: 100%;">
                        <!-- Carrusel de imágenes -->
                        <div id="carousel-@hab.IdHabitacion" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2500">
                            <div class="carousel-inner">
                                @if (!string.IsNullOrEmpty(hab.UrlImagenes))
                                {
                                    var images = hab.UrlImagenes.Split(',').ToList();
                                    for (int i = 0; i < images.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <img src="@Url.Content(images[i])" class="d-block w-100 rounded-top" alt="Habitación @hab.NumeroHabitacion">
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="carousel-item active">
                                        <img src="@Url.Content("~/imagenes/default.jpg")" class="d-block w-100 rounded-top" alt="Imagen por defecto">
                                    </div>
                                }
                            </div>
                            <a class="carousel-control-prev" href="#carousel-@hab.IdHabitacion" role="button" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                            </a>
                            <a class="carousel-control-next" href="#carousel-@hab.IdHabitacion" role="button" data-bs-slide="next">
                                <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                            </a>
                        </div>

                        <!-- Información de la habitación -->
                        <div class="room-info p-4 bg-white">
                            <h4 class="fw-bold text-primary">Habitación @hab.NumeroHabitacion</h4>
                            <ul class="list-unstyled">
                                <li><strong>🛏️ Capacidad:</strong> @hab.Capacidad personas</li>
                                <li><strong>💰 Precio por noche:</strong> $@hab.PrecioFinal.ToString("0.00")</li>
                                <li><strong>📅 Total noches:</strong> @hab.TotalNoches noches</li>
                                <li class="text-success fw-bold fs-5">Total: $@hab.TotalPrecio</li>
                            </ul>
                            <!-- Botón Reservar -->
                            <a href="@Url.Action("ConfirmarReserva", "Reservas", new { id = hab.IdHabitacion,
                             checkIn = checkIn?.ToString("yyyy-MM-dd"), checkOut = checkOut?.ToString("yyyy-MM-dd"),
                             totalPrecio = hab.TotalPrecio, cantidadPersonas = hab.Capacidad })"
                               class="btn btn-primary btn-lg w-100 shadow">
                                Reservar Ahora 🚀
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center">
                    <p class="text-danger fs-4">❌ No hay habitaciones disponibles para las fechas seleccionadas.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Scripts -->
<script src="~/Scripts/aos.js"></script>
<script>
    AOS.init();
</script>
<script src="~/Scripts/bootstrap.bundle.min.js"></script>

<style>
    /* Ajustes del Carrusel */
    .carousel-control-prev, .carousel-control-next {
        top: 50%;
        transform: translateY(-50%);
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        filter: invert(1);
    }

    /* Tarjetas */
    .room-item {
        position: relative;
        transition: transform 0.3s ease-in-out;
        overflow: hidden;
        border-radius: 15px;
        border: 1px solid #ddd;
        background: #fff;
    }

        .room-item img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 15px 15px 0 0;
        }

    /* Botón mejorado */
    .btn-primary {
        background-color: #007bff;
        border-color: #0056b3;
        font-size: 1.2rem;
    }

        .btn-primary:hover {
            background-color: #0056b3;
        }
</style>
