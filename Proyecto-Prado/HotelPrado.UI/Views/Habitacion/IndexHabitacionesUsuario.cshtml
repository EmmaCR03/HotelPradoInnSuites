@model IEnumerable<HotelPrado.Abstracciones.Modelos.Habitaciones.HabitacionesDTO>

@{
    ViewBag.Title = "Habitaciones Disponibles";
    var checkIn = ViewBag.CheckIn as DateTime?;
    var checkOut = ViewBag.CheckOut as DateTime?;
}

<!-- Estilos -->
<link href="~/Content/aos.css" rel="stylesheet" />
<link href="~/Content/Hotel/habitaciones.css" rel="stylesheet" />

<section id="room" class="py-4">
    <div class="container">
        <div class="text-center mb-4">
            <h3 class="display-4 fw-bold">Habitaciones Disponibles</h3>
        </div>
        <div class="row justify-content-center">
            @if (Model != null && Model.Any())
            {
                var hab = Model.First(); // Mostrar solo la primera habitación disponible
                <div class="col-md-6 mb-5">
                    <div class="room-item">
                        <!-- Carrusel de imágenes -->
                        <div id="carousel-@hab.IdHabitacion" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
                            <div class="carousel-inner">
                                @if (!string.IsNullOrEmpty(hab.UrlImagenes))
                                {
                                    var images = hab.UrlImagenes.Split(',').ToList();
                                    for (int i = 0; i < images.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <img src="@Url.Content(images[i])" class="d-block w-100" alt="Habitación @hab.NumeroHabitacion">
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="carousel-item active">
                                        <img src="@Url.Content("~/imagenes/default.jpg")" class="d-block w-100" alt="Imagen por defecto">
                                    </div>
                                }
                            </div>
                            <a class="carousel-control-prev" href="#carousel-@hab.IdHabitacion" role="button" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            </a>
                            <a class="carousel-control-next" href="#carousel-@hab.IdHabitacion" role="button" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            </a>
                        </div>

                        <!-- Información de la habitación -->
                        <div class="room-info p-3">
                            <h5 class="fw-bold">Habitación @hab.NumeroHabitacion</h5>
                            <p><strong>Capacidad:</strong> @hab.Capacidad personas</p>
                            <p><strong>Precio por noche:</strong> $@hab.PrecioFinal.ToString("0.00")</p>
                            <p><strong>Total noches:</strong> @hab.TotalNoches noches</p>
                            <p class="text-success fw-bold"><strong>Precio Total: @hab.TotalPrecio</strong></p>
                            <p><strong>Estado:</strong> @hab.Estado</p>

                            <!-- Botón Reservar -->
                            <a href="@Url.Action("Reservar", "Habitacion", new { id = hab.IdHabitacion, checkIn = checkIn?.ToString("yyyy-MM-dd"), checkOut = checkOut?.ToString("yyyy-MM-dd") })"
                               class="btn btn-dark btn-sm w-100">
                                Reservar
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <p class="text-center text-danger">No hay habitaciones disponibles para las fechas seleccionadas.</p>
            }
        </div>
    </div>
</section>

<!-- Scripts -->
<script src="~/Scripts/aos.js"></script>
<script>
    AOS.init();
</script>
<script src="~/Scripts/bootstrap.bundle.min.js"></script>

<style>
    /* Ajustes del Carrusel */
    .carousel-control-prev, .carousel-control-next {
        top: 50%;
        transform: translateY(-50%);
    }

    /* Tarjetas */
    .room-item {
        position: relative;
        width: 100%;
        height: auto;
        transition: transform 0.3s ease-in-out;
        overflow: hidden;
        border-radius: 15px;
        border: 1px solid #ddd;
        padding: 10px;
    }

        .room-item img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 15px;
        }

    /* Botón mejorado */
    .btn-dark {
        background-color: #333;
        border-color: #222;
    }

        .btn-dark:hover {
            background-color: #222;
            border-color: #111;
        }
</style>
