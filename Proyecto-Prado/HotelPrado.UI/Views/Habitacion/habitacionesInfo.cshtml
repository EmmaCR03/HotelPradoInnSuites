@section scripts {
<script>
    // Sistema de Tabs
    document.addEventListener('DOMContentLoaded', function() {
        var tabs = document.querySelectorAll('.habitaciones-tab');
        var contents = document.querySelectorAll('.tab-content-wrapper');
        
        tabs.forEach(function(tab) {
            tab.addEventListener('click', function() {
                var targetTab = this.getAttribute('data-tab');
                
                // Remover active de todos los tabs
                tabs.forEach(function(t) { t.classList.remove('active'); });
                
                // Remover active de todos los contenidos
                contents.forEach(function(c) { c.classList.remove('active'); });
                
                // Agregar active al tab clickeado
                this.classList.add('active');
                
                // Agregar active al contenido correspondiente
                var targetContent = document.querySelector('[data-content="' + targetTab + '"]');
                if (targetContent) {
                    targetContent.classList.add('active');
                }
            });
        });
    });
</script>
}
