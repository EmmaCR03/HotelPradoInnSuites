@model HotelPrado.UI.Models.CheckInDetalleViewModel
@{
    Layout = null;
    var checkIn = Model;
    var logoPath = Url.Content("~/Img/images/main-Prado-removebg-preview.png");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tarjeta de Registro de Hospedaje</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 10px;
            line-height: 1.25;
            color: #000;
            background: #fff;
        }

        @@media print {
            body {
                margin: 0;
                padding: 0;
            }

            .no-print {
                display: none !important;
            }

            @@page {
                size: A4;
                margin: 0.8cm;
            }

            .tarjeta {
                page-break-inside: avoid;
            }
        }

        .container {
            width: 100%;
            max-width: 21.59cm; /* Ancho de media hoja carta */
            margin: 0 auto;
            padding: 0.5cm;
        }

        .tarjeta {
            border: 3px solid #2c3e50;
            border-radius: 8px;
            padding: 0.6cm 1cm;
            background: #fff;
            position: relative;
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 0.5cm;
            margin-bottom: 0.6cm;
        }

        .logo-container {
            flex-shrink: 0;
        }

        .logo-container img {
            max-height: 80px;
            max-width: 150px;
            object-fit: contain;
        }

        .header-text {
            flex: 1;
            text-align: center;
            margin: 0 1cm;
        }

        .header-text h1 {
            font-size: 16px;
            font-weight: bold;
            text-transform: uppercase;
            color: #2c3e50;
            margin-bottom: 0.1cm;
            letter-spacing: 1px;
        }

        .header-text h2 {
            font-size: 12px;
            font-weight: normal;
            color: #555;
            text-transform: uppercase;
        }

        .folio {
            position: absolute;
            top: 1.2cm;
            right: 1.2cm;
            font-weight: bold;
            font-size: 11px;
            color: #2c3e50;
            background: #f8f9fa;
            padding: 0.2cm 0.4cm;
            border-radius: 4px;
            border: 1px solid #dee2e6;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.2cm;
            margin-bottom: 0.25cm;
        }

        .form-group {
            margin-bottom: 0.15cm;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group-inline {
            display: flex;
            align-items: baseline;
            gap: 0.3cm;
        }

        .form-label {
            font-weight: 600;
            font-size: 9px;
            color: #495057;
            min-width: 3.5cm;
            flex-shrink: 0;
            text-transform: uppercase;
        }

        .form-value {
            flex: 1;
            border-bottom: 2px solid #2c3e50;
            padding: 0.15cm 0.2cm;
            font-size: 10px;
            color: #212529;
            min-height: 0.5cm;
            display: inline-block;
        }

        .terms {
            margin-top: 0.3cm;
            padding-top: 0.25cm;
            border-top: 2px solid #dee2e6;
            font-size: 6px;
            line-height: 1.3;
        }

        .terms-title {
            font-weight: bold;
            margin-bottom: 0.1cm;
            font-size: 6.5px;
            color: #2c3e50;
            text-transform: uppercase;
        }

        .terms-text {
            margin-bottom: 0.08cm;
            text-align: justify;
            color: #495057;
        }

        .signature-section {
            margin-top: 0.3cm;
            padding-top: 0.25cm;
            border-top: 2px solid #dee2e6;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5cm;
        }

        .signature-box {
            display: flex;
            flex-direction: column;
        }

        .signature-label {
            font-weight: 600;
            font-size: 8px;
            color: #495057;
            margin-bottom: 0.3cm;
            text-transform: uppercase;
        }

        .signature-line {
            border-bottom: 2px solid #2c3e50;
            min-height: 1.2cm;
            margin-bottom: 0.2cm;
            position: relative;
        }

        .signature-name-label {
            font-size: 7px;
            color: #6c757d;
            margin-top: 0.1cm;
            font-style: italic;
        }

        .btn-print {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 10px 20px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            z-index: 1000;
        }

        .btn-print:hover {
            background: #0056b3;
        }
    </style>
</head>
<body>
    <button class="btn-print no-print" onclick="window.print()">
        <i class="fas fa-print"></i> Imprimir
    </button>

    <div class="container">
        <div class="tarjeta">
            <div class="folio">
                # FOLIO: @(Model?.CodigoFolio?.ToString("D8") ?? Model?.IdCheckIn?.ToString("D8") ?? "")
            </div>

            <div class="header">
                <div class="logo-container">
                    <img src="@logoPath" alt="Prado Inn & Suites Logo" />
                </div>
                <div class="header-text">
                    <h1>TARJETA DE REGISTRO HOSPEDAJE</h1>
                    <h2>REGISTRATION CARD</h2>
                </div>
                <div class="logo-container" style="width: 150px;"></div> <!-- Espaciador para centrar -->
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">HABITACION / ROOM:</span>
                        <span class="form-value">@(Model?.NumeroHabitacion ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label"># HUESPEDES / NBR. OF GUESTS:</span>
                        <span class="form-value">@((Model?.NumeroAdultos ?? 0) + (Model?.NumeroNinos ?? 0))</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">FECHA DE LLEGADA / ARRIVAL DATE:</span>
                        <span class="form-value">@(Model?.FechaCheckIn?.ToString("dd-MM-yyyy") ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">FECHA DE SALIDA / DEP. DATE:</span>
                        <span class="form-value">@(Model?.FechaCheckOut?.ToString("dd-MM-yyyy") ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">DEPOSITO / DEPOSIT:</span>
                        <span class="form-value">@((Model?.Deposito ?? 0).ToString("N2"))</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">IDENTIFICACION:</span>
                        <span class="form-value">@(Model?.CedulaCliente ?? "")</span>
                    </div>
                </div>

                <div class="form-group full-width">
                    <div class="form-group-inline">
                        <span class="form-label">NOMBRE/NAME:</span>
                        <span class="form-value">@(Model?.NombreCliente ?? "")</span>
                    </div>
                </div>

                <div class="form-group full-width">
                    <div class="form-group-inline">
                        <span class="form-label">DIRECCION/ADRESS:</span>
                        <span class="form-value">@(Model?.DireccionCliente ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">TELEFONOS/TELEFONE:</span>
                        <span class="form-value">@(Model?.TelefonoCliente ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">Email:</span>
                        <span class="form-value">@(Model?.EmailCliente ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">COMPAÑIA/COMPANY:</span>
                        <span class="form-value">@(Model?.NombreEmpresa ?? "")</span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-group-inline">
                        <span class="form-label">Motivo del Viaje:</span>
                        <span class="form-value">TRABAJO</span>
                    </div>
                </div>

                <div class="form-group full-width">
                    <div class="form-group-inline">
                        <span class="form-label">OBSERVACIONES:</span>
                        <span class="form-value">@(Model?.Observaciones ?? "")</span>
                    </div>
                </div>
            </div>

            <div class="terms">
                <div class="terms-title">TÉRMINOS Y CONDICIONES / TERMS AND CONDITIONS:</div>
                <div class="terms-text">
                    <strong>PRADO INN AND SUITES ES UNA INSTALACION PRIVADA, LA GERENCIA SE RESERVA EL DERECHO DE RECHAZAR EL SERVICIO A CUALQUIER PERSONA QUE CONSIDERE NECESARIO, NO SE HARA RESPONSABLE DE ACCIDENTES, LESIONES, PERDIDAS DE DINERO Y/O OBJETOS DE NINGUNA INDOLE. EL HOTEL HA DISPUESTO DE CAJAS DE SEGURIDAD EN SU HABITACION. POR ESTE MEDIO CONFIRMO QUE HE LEIDO Y COMPRENDIDO TODAS Y CADA UNA DE LAS REGLAS DEL HOTEL, AL IGUAL MIS FAMILIARES, INVITADOS Y/O CUALQUIER PERSONA QUE TENGA ACCESO AL HOTEL. ESTOY DE ACUERDO EN DESOCUPAR LA HABITACION EN LA FECHA ARRIBA INDICADA A LAS DOCE MEDIO DIA.</strong>
                </div>
                <div class="terms-text">
                    <strong>PRADO INN AND SUITES IS PRIVATELY OWNED AND MANAGEMENT RESERVE THE RIGHT TO REFUSE SERVICE TO ANYONE, AND WILL BE NOT RESPONSIBLE FOR ACCIDENTS OR INJURY OR LOSS OF MONEY OR VALUABLES OF ANY KIND. SAFETY DEPOSIT BOXES ARE PROVIDED IN YOUR ROOM. BY THIS MEANS I CONFIRM THAT I HAVE READ AND UNDERSTOOD EACH AND EVERY SINGLE ONE OF THE RULES OF THE HOTEL, AS WELL MY RELATIVES, VISITORS AND/OR ANY INDIVIDUAL THAT HAS ACCESS TO THE HOTEL PERMISES. I AGREE TO CHECK-OUT BY NOON ON THE DEPARTURE DAY SHOW ABOVE.</strong>
                </div>
            </div>

            <div class="signature-section">
                <div class="signature-box">
                    <div class="signature-label">FIRMA DEL HUÉSPED / GUEST SIGNATURE</div>
                    <div class="signature-line"></div>
                    <div class="signature-name-label">NOMBRE / NAME</div>
                </div>
                <div class="signature-box">
                    <div class="signature-label">FIRMA DEL RECEPCIONISTA / RECEPTIONIST SIGNATURE</div>
                    <div class="signature-line"></div>
                    <div class="signature-name-label">NOMBRE / NAME</div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
