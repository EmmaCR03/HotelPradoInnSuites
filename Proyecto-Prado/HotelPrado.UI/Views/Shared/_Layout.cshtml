    @if (User.IsInRole("Administrador") || User.IsInRole("Colaborador"))
    {
        <script>
            // Sistema de Notificaciones
            (function() {
                let notificacionesVistas = new Set();
                let intentosCarga = 0;
                const maxIntentos = 10;
                
                function cargarNotificaciones() {
                    intentosCarga++;
                    
                    // Verificar que jQuery esté disponible
                    if (typeof $ === 'undefined' || typeof jQuery === 'undefined') {
                        if (intentosCarga < maxIntentos) {
                            setTimeout(cargarNotificaciones, 500);
                        }
                        return;
                    }
                    
                    // Verificar que la lista exista
                    const lista = document.getElementById('notificaciones-lista');
                    if (!lista) {
                        if (intentosCarga < maxIntentos) {
                            setTimeout(cargarNotificaciones, 500);
                        }
                        return;
                    }
                    
                    $.ajax({
                        url: '@Url.Action("Obtener", "Notificaciones")',
                        type: 'GET',
                        dataType: 'json',
                        cache: false,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        success: function(notificaciones) {
                            todasLasNotificaciones = notificaciones || [];
                            // Actualizar badge inmediatamente
                            actualizarBadge();
                            
                            // Mostrar notificaciones filtradas solo si el dropdown está abierto
                            const dropdown = document.getElementById('notificaciones-dropdown');
                            if (dropdown && (dropdown.style.display === 'block' || dropdown.style.display === '')) {
                                mostrarNotificacionesFiltradas();
                            }
                        },
                        error: function(xhr, status, error) {
                            // Ocultar badge si hay error
                            const badge = document.getElementById('notificaciones-badge');
                            if (badge) {
                                badge.textContent = '';
                                badge.style.display = 'none';
                                badge.setAttribute('data-count', '0');
                            }
                        }
                    });
                }
                
                function mostrarNotificaciones(notificaciones) {
                    const lista = document.getElementById('notificaciones-lista');
                    const badge = document.getElementById('notificaciones-badge');
                    const dropdown = document.getElementById('notificaciones-dropdown');
                    if (!lista) return;
                    
                    // NO abrir el dropdown automáticamente - solo actualizar el badge
                    const isDropdownOpen = dropdown && (dropdown.style.display === 'block' || dropdown.style.display === '');
                    
                    // Limpiar mensaje de carga solo si el dropdown está abierto
                    if (isDropdownOpen) {
                        lista.innerHTML = '';
                    }
                    
                    if (!notificaciones || notificaciones.length === 0) {
                        if (isDropdownOpen) {
                            lista.innerHTML = '<div style="padding: 2rem; text-align: center; color: #6c757d;"><i class="fas fa-bell-slash"></i><br>No hay notificaciones</div>';
                        }
                        // Actualizar badge para ocultarlo si no hay notificaciones
                        actualizarBadge();
                        return;
                    }
                    
                    // Guardar notificaciones globalmente
                    todasLasNotificaciones = notificaciones || [];
                    
                    // Actualizar badge SIEMPRE (sin abrir dropdown)
                    actualizarBadge();
                    
                    // Solo actualizar la lista si el dropdown está abierto
                    if (!isDropdownOpen) {
                        return;
                    }
                    
                    // Filtrar notificaciones ya vistas
                    const nuevas = notificaciones.filter(n => !notificacionesVistas.has(n.tipo + '-' + n.id));
                    
                    if (nuevas.length === 0 && notificaciones.length > 0) {
                        lista.innerHTML = '<div style="padding: 2rem; text-align: center; color: #6c757d;"><i class="fas fa-check-circle"></i><br>Todas las notificaciones han sido vistas</div>';
                        return;
                    }
                    
                    nuevas.forEach(function(notif) {
                        const key = notif.tipo + '-' + notif.id;
                        notificacionesVistas.add(key);
                        
                        // Determinar icono y color según el tipo de notificación (ANTES de usarlos)
                        let icono, color;
                        switch(notif.tipo) {
                            case 'reserva':
                                icono = 'fa-calendar-check';
                                color = '#28a745';
                                break;
                            case 'limpieza':
                                icono = 'fa-broom';
                                color = '#17a2b8';
                                break;
                            case 'checkin':
                                icono = 'fa-sign-in-alt';
                                color = '#ffc107';
                                break;
                            case 'checkout':
                                icono = 'fa-sign-out-alt';
                                color = '#dc3545';
                                break;
                            case 'cita':
                                icono = 'fa-calendar-alt';
                                color = '#6D7BB8';
                                break;
                            default:
                                icono = 'fa-bell';
                                color = '#6D7BB8';
                        }
                        
                        const notificacion = document.createElement('div');
                        notificacion.className = 'notificacion-item';
                        notificacion.style.cssText = `
                            padding: 1rem;
                            margin-bottom: 0.5rem;
                            border-radius: 8px;
                            border-left: 4px solid ${color};
                            background: #f8f9fa;
                            cursor: pointer;
                            transition: all 0.3s ease;
                        `;
                        
                        notificacion.innerHTML = `
                            <div style="display: flex; align-items: start; gap: 0.75rem;">
                                <div style="background: ${color}; color: white; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.9rem;">
                                    <i class="fas ${icono}"></i>
                                </div>
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; color: #2c3e50; margin-bottom: 0.25rem; font-size: 0.9rem;">
                                        ${notif.mensaje}
                                    </div>
                                    <div style="font-size: 0.75rem; color: #6c757d;">
                                        ${formatearFecha(notif.fecha)}
                                    </div>
                                </div>
                            </div>
                        `;
                        
                        notificacion.onclick = function(e) {
                            e.stopPropagation();
                            if (notif.url) {
                                window.location.href = notif.url;
                            }
                        };
                        
                        notificacion.onmouseenter = function() {
                            this.style.background = '#e9ecef';
                            this.style.transform = 'translateX(3px)';
                        };
                        
                        notificacion.onmouseleave = function() {
                            this.style.background = '#f8f9fa';
                            this.style.transform = 'translateX(0)';
                        };
                        
                        lista.appendChild(notificacion);
                    });
                }
                
                // Hacer toggleNotificaciones global - disponible en todas las vistas
                window.toggleNotificaciones = function() {
                    const dropdown = document.getElementById('notificaciones-dropdown');
                    const badge = document.getElementById('notificaciones-badge');
                    
                    if (dropdown) {
                        const isVisible = dropdown.style.display === 'block' || 
                                         (dropdown.style.display !== 'none' && window.getComputedStyle(dropdown).display !== 'none');
                        
                        if (!isVisible) {
                            // Abrir dropdown
                            dropdown.style.display = 'block';
                            
                            // Marcar todas las notificaciones actuales como vistas cuando se abre el dropdown
                            marcarTodasComoVistas();
                            
                            // Ocultar badge inmediatamente al abrir (comportamiento estándar como WhatsApp)
                            if (badge) {
                                badge.style.display = 'none';
                                badge.setAttribute('data-count', '0');
                                badge.textContent = '';
                            }
                            
                            // Cargar notificaciones solo cuando se abre manualmente
                            if (typeof cargarNotificaciones === 'function') {
                                cargarNotificaciones();
                            }
                        } else {
                            // Cerrar dropdown
                            dropdown.style.display = 'none';
                        }
                    }
                };
                
                // También definir la función local para compatibilidad
                function toggleNotificaciones() {
                    window.toggleNotificaciones();
                }
                
                // Cerrar dropdown al hacer click fuera (MEJORADO - NO INTERFIERE CON OTROS DROPDOWNS)
                document.addEventListener('click', function(e) {
                    const dropdown = document.getElementById('notificaciones-dropdown');
                    const btn = document.getElementById('btn-notificaciones');
                    
                    // No cerrar si se hace click en el offcanvas
                    if (e.target.closest('.offcanvas') || e.target.closest('#navbarOffcanvas')) {
                        return;
                    }
                    
                    // No cerrar si se hace click en otros dropdowns
                    if (e.target.closest('.dropdown-menu') && !e.target.closest('.notificaciones-dropdown')) {
                        return;
                    }
                    
                    if (dropdown && btn && !dropdown.contains(e.target) && !btn.contains(e.target)) {
                        dropdown.style.display = 'none';
                    }
                }, true); // Usar capture phase para que se ejecute antes
                
                window.cerrarNotificacion = function(btn) {
                    const notificacion = btn ? btn.closest('.notificacion-item') : null;
                    if (notificacion) {
                        const tipo = notificacion.getAttribute('data-tipo');
                        const mensaje = notificacion.querySelector('div[style*="font-weight: 600"]')?.textContent;
                        
                        // Eliminar de la lista global
                        todasLasNotificaciones = todasLasNotificaciones.filter(n => 
                            !(n.tipo === tipo && n.mensaje === mensaje)
                        );
                        
                        notificacion.style.opacity = '0';
                        notificacion.style.transform = 'translateX(20px)';
                        setTimeout(function() {
                            notificacion.remove();
                            actualizarBadge();
                            // Refrescar la vista filtrada
                            mostrarNotificacionesFiltradas();
                        }, 300);
                    }
                };
                
                // Variable global para almacenar todas las notificaciones
                let todasLasNotificaciones = [];
                let filtroActual = 'todas';

                // Función para obtener las notificaciones vistas (guardadas en localStorage)
                function obtenerNotificacionesVistas() {
                    try {
                        const vistas = localStorage.getItem('notificaciones_vistas');
                        return vistas ? JSON.parse(vistas) : [];
                    } catch (e) {
                        return [];
                    }
                }
                
                // Función para guardar una notificación como vista
                function marcarNotificacionComoVista(tipo, id) {
                    try {
                        const vistas = obtenerNotificacionesVistas();
                        const key = tipo + '-' + id;
                        if (!vistas.includes(key)) {
                            vistas.push(key);
                            localStorage.setItem('notificaciones_vistas', JSON.stringify(vistas));
                        }
                    } catch (e) { }
                }
                
                // Función para marcar todas las notificaciones actuales como vistas
                function marcarTodasComoVistas() {
                    if (!todasLasNotificaciones || todasLasNotificaciones.length === 0) return;
                    
                    try {
                        const vistas = obtenerNotificacionesVistas();
                        todasLasNotificaciones.forEach(function(notif) {
                            const key = notif.tipo + '-' + notif.id;
                            if (!vistas.includes(key)) {
                                vistas.push(key);
                            }
                        });
                        localStorage.setItem('notificaciones_vistas', JSON.stringify(vistas));
                    } catch (e) { }
                }
                
                function actualizarBadge() {
                    const badge = document.getElementById('notificaciones-badge');
                    if (!badge) return;
                    
                    if (!todasLasNotificaciones || todasLasNotificaciones.length === 0) {
                        badge.textContent = '';
                        badge.style.display = 'none';
                        badge.setAttribute('data-count', '0');
                        return;
                    }
                    
                    const vistas = obtenerNotificacionesVistas();
                    const notificacionesNuevas = todasLasNotificaciones.filter(function(notif) {
                        if (!notif || !notif.tipo || !notif.id) return false;
                        const key = notif.tipo + '-' + notif.id;
                        return !vistas.includes(key);
                    });
                    const total = notificacionesNuevas.length;
                    
                    if (total > 0) {
                        badge.textContent = total > 99 ? '99+' : total.toString();
                        badge.style.display = 'flex';
                        badge.setAttribute('data-count', total);
                    } else {
                        badge.textContent = '';
                        badge.style.display = 'none';
                        badge.setAttribute('data-count', '0');
                    }
                }

                // Función para filtrar notificaciones
                window.filtrarNotificaciones = function(tipo) {
                    filtroActual = tipo;
                    
                    // Actualizar botones de filtro
                    document.querySelectorAll('.filtro-notificacion').forEach(btn => {
                        const filtro = btn.getAttribute('data-filtro');
                        if (filtro === tipo) {
                            btn.classList.add('active');
                            // Aplicar estilo activo
                            const color = obtenerColorPorTipo(tipo);
                            btn.style.background = color;
                            btn.style.color = 'white';
                            btn.style.borderColor = color;
                        } else {
                            btn.classList.remove('active');
                            const color = obtenerColorPorTipo(filtro);
                            btn.style.background = 'white';
                            btn.style.color = color;
                            btn.style.borderColor = color;
                        }
                    });
                    
                    // Filtrar y mostrar notificaciones
                    mostrarNotificacionesFiltradas();
                };

                function obtenerColorPorTipo(tipo) {
                    switch(tipo) {
                        case 'reserva': return '#28a745';
                        case 'limpieza': return '#17a2b8';
                        case 'checkin': return '#ffc107';
                        case 'checkout': return '#dc3545';
                        case 'cita': return '#6D7BB8';
                        default: return '#6D7BB8';
                    }
                }

                function mostrarNotificacionesFiltradas() {
                    const lista = document.getElementById('notificaciones-lista');
                    if (!lista) return;
                    
                    // Filtrar según el tipo seleccionado
                    let notificacionesFiltradas = todasLasNotificaciones;
                    if (filtroActual !== 'todas') {
                        notificacionesFiltradas = todasLasNotificaciones.filter(n => n.tipo === filtroActual);
                    }
                    
                    // Limpiar lista
                    lista.innerHTML = '';
                    
                    if (notificacionesFiltradas.length === 0) {
                        lista.innerHTML = '<div style="padding: 2rem; text-align: center; color: #6c757d;"><i class="fas fa-bell-slash"></i><br>No hay notificaciones de este tipo</div>';
                        return;
                    }
                    
                    // Mostrar notificaciones filtradas
                    notificacionesFiltradas.forEach(function(notif) {
                        const key = notif.tipo + '-' + notif.id;
                        
                        // Determinar icono y color según el tipo de notificación
                        let icono, color;
                        switch(notif.tipo) {
                            case 'reserva':
                                icono = 'fa-calendar-check';
                                color = '#28a745';
                                break;
                            case 'limpieza':
                                icono = 'fa-broom';
                                color = '#17a2b8';
                                break;
                            case 'checkin':
                                icono = 'fa-sign-in-alt';
                                color = '#ffc107';
                                break;
                            case 'checkout':
                                icono = 'fa-sign-out-alt';
                                color = '#dc3545';
                                break;
                            case 'cita':
                                icono = 'fa-calendar-alt';
                                color = '#6D7BB8';
                                break;
                            default:
                                icono = 'fa-bell';
                                color = '#6D7BB8';
                        }
                        
                        const notificacion = document.createElement('div');
                        notificacion.className = 'notificacion-item';
                        notificacion.setAttribute('data-tipo', notif.tipo);
                        notificacion.style.cssText = `
                            padding: 1rem;
                            margin-bottom: 0.5rem;
                            border-radius: 8px;
                            border-left: 4px solid ${color};
                            background: #f8f9fa;
                            cursor: pointer;
                            transition: all 0.3s ease;
                        `;
                        
                        notificacion.innerHTML = `
                            <div style="display: flex; align-items: start; gap: 0.75rem;">
                                <div style="background: ${color}; color: white; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.9rem;">
                                    <i class="fas ${icono}"></i>
                                </div>
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; color: #2c3e50; margin-bottom: 0.25rem; font-size: 0.9rem;">
                                        ${notif.mensaje}
                                    </div>
                                    <div style="font-size: 0.75rem; color: #6c757d;">
                                        ${formatearFecha(notif.fecha)}
                                    </div>
                                </div>
                                <button onclick="cerrarNotificacion(this); event.stopPropagation();" style="background: none; border: none; color: #6c757d; cursor: pointer; padding: 0.25rem; font-size: 0.8rem;" title="Eliminar">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        `;
                        
                        notificacion.onclick = function(e) {
                            if (e.target.closest('button')) return;
                            e.stopPropagation();
                            if (notif.url) {
                                window.location.href = notif.url;
                            }
                        };
                        
                        notificacion.onmouseenter = function() {
                            this.style.background = '#e9ecef';
                            this.style.transform = 'translateX(3px)';
                        };
                        
                        notificacion.onmouseleave = function() {
                            this.style.background = '#f8f9fa';
                            this.style.transform = 'translateX(0)';
                        };
                        
                        lista.appendChild(notificacion);
                    });
                }

                // Función para limpiar todas las notificaciones
                window.limpiarNotificaciones = function() {
                    if (confirm('¿Desea eliminar todas las notificaciones?')) {
                        todasLasNotificaciones = [];
                        const lista = document.getElementById('notificaciones-lista');
                        if (lista) {
                            lista.innerHTML = '<div style="padding: 2rem; text-align: center; color: #6c757d;"><i class="fas fa-bell-slash"></i><br>No hay notificaciones</div>';
                        }
                        actualizarBadge();
                        // Marcar todas como vistas
                        notificacionesVistas.clear();
                    }
                };
                
                function formatearFecha(fecha) {
                    if (!fecha) return 'Ahora';
                    
                    let fechaNotif;
                    // Manejar formato de fecha de .NET: /Date(1234567890)/
                    if (typeof fecha === 'string' && fecha.startsWith('/Date(')) {
                        const match = fecha.match(/\d+/);
                        if (match && match[0]) {
                            const timestamp = parseInt(match[0]);
                            fechaNotif = new Date(timestamp);
                        } else {
                            fechaNotif = new Date(fecha);
                        }
                    } else if (typeof fecha === 'string') {
                        // Intentar parsear diferentes formatos de fecha
                        fechaNotif = new Date(fecha);
                        // Si falla, intentar formato ISO
                        if (isNaN(fechaNotif.getTime())) {
                            // Intentar formato: "2026-01-05T00:00:00"
                            const isoMatch = fecha.match(/(\d{4})-(\d{2})-(\d{2})/);
                            if (isoMatch) {
                                fechaNotif = new Date(isoMatch[1], parseInt(isoMatch[2]) - 1, isoMatch[3]);
                            } else {
                                fechaNotif = new Date();
                            }
                        }
                    } else if (fecha instanceof Date) {
                        fechaNotif = fecha;
                    } else {
                        fechaNotif = new Date(fecha);
                    }
                    
                    if (isNaN(fechaNotif.getTime())) return 'Fecha inválida';
                    
                    const ahora = new Date();
                    const diffMs = ahora.getTime() - fechaNotif.getTime();
                    
                    // Si la diferencia es negativa (fecha futura), mostrar fecha completa
                    if (diffMs < 0) {
                        return fechaNotif.toLocaleDateString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                    }
                    
                    const diffSegs = Math.floor(diffMs / 1000);
                    const diffMins = Math.floor(diffSegs / 60);
                    const diffHoras = Math.floor(diffMins / 60);
                    const diffDias = Math.floor(diffHoras / 24);
                    
                    if (diffSegs < 60) return 'Hace un momento';
                    if (diffMins < 60) return `Hace ${diffMins} minuto${diffMins > 1 ? 's' : ''}`;
                    if (diffHoras < 24) return `Hace ${diffHoras} hora${diffHoras > 1 ? 's' : ''}`;
                    if (diffDias < 7) return `Hace ${diffDias} día${diffDias > 1 ? 's' : ''}`;
                    
                    // Si es más de una semana, mostrar fecha completa
                    return fechaNotif.toLocaleDateString('es-ES', { 
                        day: '2-digit', 
                        month: '2-digit', 
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                }
                
                // Agregar estilos de animación
                const style = document.createElement('style');
                style.textContent = `
                    @@keyframes slideInRight {
                        from { transform: translateX(100%); opacity: 0; }
                        to { transform: translateX(0); opacity: 1; }
                    }
                    @@keyframes slideOutRight {
                        from { transform: translateX(0); opacity: 1; }
                        to { transform: translateX(100%); opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
                
                // Cargar notificaciones al iniciar (solo actualizar badge, NO abrir dropdown)
                function initNotificaciones() {
                    // Esperar a que el DOM esté listo
                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', function() {
                            setTimeout(initNotificaciones, 100);
                        });
                        return;
                    }
                    
                    // Intentar con jQuery primero, luego con fetch como fallback
                    if (typeof $ !== 'undefined' && typeof jQuery !== 'undefined') {
                        $(document).ready(function() {
                            // Cargar notificaciones al inicio para actualizar el badge
                            cargarNotificaciones();
                            // Actualizar cada 30 segundos (solo badge, sin abrir dropdown)
                            setInterval(function() {
                                const dropdown = document.getElementById('notificaciones-dropdown');
                                // Solo actualizar si el dropdown NO está abierto
                                if (!dropdown || dropdown.style.display !== 'block') {
                                    cargarNotificaciones();
                                }
                            }, 30000);
                        });
                    } else {
                        // Fallback con fetch si jQuery no está disponible
                        setTimeout(function() {
                            cargarNotificacionesFetch();
                            setInterval(function() {
                                const dropdown = document.getElementById('notificaciones-dropdown');
                                if (!dropdown || dropdown.style.display !== 'block') {
                                    cargarNotificacionesFetch();
                                }
                            }, 30000);
                        }, 500);
                    }
                }
                
                // Función alternativa usando fetch en lugar de jQuery
                function cargarNotificacionesFetch() {
                    const lista = document.getElementById('notificaciones-lista');
                    const badge = document.getElementById('notificaciones-badge');
                    
                    if (!lista) {
                        setTimeout(cargarNotificacionesFetch, 500);
                        return;
                    }
                    
                    fetch('@Url.Action("Obtener", "Notificaciones")', {
                        method: 'GET',
                        cache: 'no-cache',
                        credentials: 'same-origin',
                        headers: {
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                    .then(notificaciones => {
                        // Guardar todas las notificaciones
                        todasLasNotificaciones = notificaciones || [];
                        // Actualizar badge inmediatamente
                        actualizarBadge();
                        // Mostrar notificaciones filtradas solo si el dropdown está abierto
                        const dropdown = document.getElementById('notificaciones-dropdown');
                        if (dropdown && (dropdown.style.display === 'block' || dropdown.style.display === '')) {
                            mostrarNotificacionesFiltradas();
                        }
                    })
                    .catch(function() { });
                }
                
                initNotificaciones();
                
                // Exponer función globalmente
                window.cerrarNotificacion = cerrarNotificacion;
            })();
        </script>
    }
    
    <!-- SOLUCIÓN MEJORADA PARA DROPDOWNS - NO INTERFIERE CON OFFCANVAS -->
    <script>
        (function() {
            var dropdownsInitialized = false;
            
            function setupDropdowns() {
                if (dropdownsInitialized) return;
                
                // Esperar a que Bootstrap esté disponible
                if (typeof bootstrap === 'undefined' || !bootstrap.Dropdown) {
                    setTimeout(setupDropdowns, 100);
                    return;
                }
                
                // Encontrar todos los elementos con data-bs-toggle="dropdown"
                var dropdownToggles = document.querySelectorAll('[data-bs-toggle="dropdown"]');
                
                if (dropdownToggles.length === 0) {
                    setTimeout(setupDropdowns, 100);
                    return;
                }
                
                dropdownsInitialized = true;
                
                dropdownToggles.forEach(function(toggle) {
                    // Inicializar con Bootstrap Dropdown
                    try {
                        var dropdownInstance = bootstrap.Dropdown.getInstance(toggle);
                        if (!dropdownInstance) {
                            new bootstrap.Dropdown(toggle, {
                                boundary: 'viewport',
                                popperConfig: {
                                    modifiers: [
                                        {
                                            name: 'preventOverflow',
                                            options: {
                                                boundary: 'viewport'
                                            }
                                        }
                                    ]
                                }
                            });
                        }
                    } catch(e) { }
                });
                
                // Cerrar dropdowns al hacer click fuera (EXCEPTO notificaciones y offcanvas)
                document.addEventListener('click', function(e) {
                    // No cerrar si se hace click en el offcanvas o su contenido
                    if (e.target.closest('.offcanvas') || e.target.closest('#navbarOffcanvas')) {
                        return;
                    }
                    
                    // No cerrar si se hace click en notificaciones
                    if (e.target.closest('.notificaciones-navbar') || e.target.closest('#notificaciones-dropdown')) {
                        return;
                    }
                    
                    var clickedDropdown = e.target.closest('.nav-item.dropdown') || e.target.closest('.dropdown');
                    if (!clickedDropdown) {
                        // Cerrar todos los dropdowns excepto los de notificaciones
                        document.querySelectorAll('.dropdown-menu.show').forEach(function(menu) {
                            if (!menu.closest('.notificaciones-navbar')) {
                                var toggle = menu.previousElementSibling || 
                                           document.querySelector('[aria-labelledby="' + menu.getAttribute('aria-labelledby') + '"]');
                                if (toggle) {
                                    var instance = bootstrap.Dropdown.getInstance(toggle);
                                    if (instance) {
                                        instance.hide();
                                    } else {
                                        menu.classList.remove('show');
                                        toggle.setAttribute('aria-expanded', 'false');
                                    }
                                }
                            }
                        });
                    }
                });
            }
            
            // Ejecutar cuando el DOM esté listo
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    setTimeout(setupDropdowns, 100);
                });
            } else {
                setTimeout(setupDropdowns, 100);
            }
            
            // También ejecutar después de que todo cargue por si acaso
            window.addEventListener('load', function() {
                setTimeout(setupDropdowns, 150);
            });
        })();
    </script>
