    <!-- SCRIPT GLOBAL PARA MANEJAR RESIZE Y PREVENIR CONGELAMIENTOS -->
    <script>
        (function() {
            'use strict';
            
            // Debounce function para optimizar el resize
            function debounce(func, wait) {
                var timeout;
                return function executedFunction() {
                    var context = this;
                    var args = arguments;
                    var later = function() {
                        timeout = null;
                        func.apply(context, args);
                    };
                    clearTimeout(timeout);
                    timeout = setTimeout(later, wait);
                };
            }
            
            // ELIMINADO: handleResize ya no es necesario
            // El CSS inline con padding-top maneja todo correctamente
            // No necesitamos ajustar margin-top del body-content porque body ya tiene padding-top
            
            // Asegurar que el viewport meta tag esté correcto
            var viewport = document.querySelector('meta[name="viewport"]');
            if (!viewport) {
                var meta = document.createElement('meta');
                meta.name = 'viewport';
                meta.content = 'width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes';
                document.getElementsByTagName('head')[0].appendChild(meta);
            } else {
                viewport.setAttribute('content', 'width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes');
            }
            
            // Prevenir overflow horizontal
            document.documentElement.style.overflowX = 'hidden';
            document.body.style.overflowX = 'hidden';
            
        })();
    </script>
    
    <!-- SCRIPT PARA INICIALIZAR MENÚ HAMBURGUESA Y PREVENIR CONGELAMIENTOS -->
    <script>
        (function() {
            'use strict';
            
            var offcanvasElement = null;
            var offcanvasInstance = null;
            
            // Inicializar offcanvas - SIMPLIFICADO Y MEJORADO
            function initOffcanvas() {
                offcanvasElement = document.getElementById('navbarOffcanvas');
                if (!offcanvasElement) return;
                
                // Esperar a que Bootstrap esté disponible
                if (typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
                    try {
                        // Obtener instancia existente o crear nueva
                        if (typeof bootstrap.Offcanvas.getInstance === 'function') {
                            offcanvasInstance = bootstrap.Offcanvas.getInstance(offcanvasElement);
                        }
                        
                        if (!offcanvasInstance) {
                            offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement, {
                                backdrop: true,
                                keyboard: true,
                                scroll: false
                            });
                        }
                        
                        // Prevenir animación de rebote
                        offcanvasElement.addEventListener('hide.bs.offcanvas', function() {
                            offcanvasElement.style.transition = 'transform 0.3s ease-in-out';
                        });
                        
                        offcanvasElement.addEventListener('show.bs.offcanvas', function() {
                            offcanvasElement.style.transition = 'transform 0.3s ease-in-out';
                        });
                        
                        // Prevenir que el backdrop cierre el offcanvas cuando se hace click en elementos interactivos
                        document.addEventListener('click', function(e) {
                            // Si el offcanvas está abierto y se hace click en un dropdown o botón dentro del offcanvas
                            if (offcanvasElement.classList.contains('show')) {
                                var clickedElement = e.target.closest('.dropdown-menu') || 
                                                   e.target.closest('[data-bs-toggle="dropdown"]') ||
                                                   e.target.closest('button[type="submit"]') ||
                                                   e.target.closest('form');
                                
                                if (clickedElement && offcanvasElement.contains(clickedElement)) {
                                    // No cerrar el offcanvas
                                    e.stopPropagation();
                                }
                            }
                        }, true);
                        
                    } catch (e) { }
                } else {
                    setTimeout(initOffcanvas, 100);
                }
            }
            
            // Setup botón hamburguesa - MEJORADO - PREVIENE CIERRE AUTOMÁTICO
            function setupHamburgerButton() {
                var hamburgerButton = document.querySelector('.navbar-toggle[data-bs-target="#navbarOffcanvas"]');
                
                if (hamburgerButton && offcanvasElement) {
                    // Remover listeners anteriores si existen
                    var newButton = hamburgerButton.cloneNode(true);
                    hamburgerButton.parentNode.replaceChild(newButton, hamburgerButton);
                    hamburgerButton = newButton;
                    
                    hamburgerButton.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        // Prevenir que otros scripts interfieran
                        setTimeout(function() {
                            if (offcanvasInstance) {
                                var isShown = offcanvasElement.classList.contains('show');
                                if (!isShown) {
                                    offcanvasInstance.show();
                                }
                            } else if (typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
                                try {
                                    offcanvasInstance = new bootstrap.Offcanvas(offcanvasElement, {
                                        backdrop: true,
                                        keyboard: true,
                                        scroll: false
                                    });
                                    offcanvasInstance.show();
                                } catch (err) { }
                            }
                        }, 10);
                    }, true); // Usar capture phase
                }
            }
            
            // Cerrar offcanvas al hacer click en links - MEJORADO
            // SOLO cerrar si el link NO es un dropdown toggle o un botón de acción
            function setupOffcanvasLinks() {
                if (!offcanvasElement) return;
                
                // Solo cerrar al hacer click en links de navegación principales
                var navLinks = offcanvasElement.querySelectorAll('.navbar-menu-mobile a[href]:not([data-bs-toggle="dropdown"]):not([href^="javascript:"]):not([href="#"]):not(.dropdown-toggle)');
                navLinks.forEach(function(link) {
                    // Verificar que no sea parte de un dropdown
                    if (link.closest('.dropdown-menu')) {
                        return; // No cerrar si está dentro de un dropdown
                    }
                    
                    link.addEventListener('click', function(e) {
                        // Solo cerrar si el link tiene un href válido (no es # o javascript:)
                        var href = link.getAttribute('href');
                        if (href && href !== '#' && !href.startsWith('javascript:') && !href.startsWith('#')) {
                            if (offcanvasInstance) {
                                setTimeout(function() {
                                    offcanvasInstance.hide();
                                }, 200);
                            }
                        }
                    });
                });
            }
            
            // Ajustar navbar - Simplificado - SOLO AJUSTAR CONTENIDO, NO MOVER NAVBAR
            function adjustNavbar() {
                try {
                    var header = document.querySelector('header#header');
                    var bodyContent = document.querySelector('.body-content');
                    
                    // IMPORTANTE: Solo ajustar el contenido, NO mover el navbar
                    if (header && bodyContent) {
                        var isMobile = window.innerWidth < 992;
                        var headerHeight = isMobile ? 60 : 105;
                        bodyContent.style.marginTop = headerHeight + 'px';
                        // NO modificar posición del header
                    }
                } catch (e) { }
            }
            
            // Ejecutar al cargar
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    initOffcanvas();
                    setupHamburgerButton();
                    setupOffcanvasLinks();
                    adjustNavbar();
                });
            } else {
                initOffcanvas();
                setupHamburgerButton();
                setupOffcanvasLinks();
                adjustNavbar();
            }
            
            // Reajustar en resize
            window.addEventListener('resize', function() {
                adjustNavbar();
            });
            
            // Re-inicializar si el DOM cambia
            var observer = new MutationObserver(function() {
                if (!offcanvasInstance && offcanvasElement) {
                    initOffcanvas();
                }
            });
            
            if (document.body) {
                observer.observe(document.body, { childList: true, subtree: true });
            }
        })();
    </script>
    
