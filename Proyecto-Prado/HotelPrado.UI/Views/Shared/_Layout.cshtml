<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Mi aplicación ASP.NET</title>
    @Styles.Render("~/Content/css")
    <link href="~/Scripts/bootstrap-datepicker.min.css" rel="stylesheet" />
    <link href="~/Scripts/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/flatpickr.min.css" rel="stylesheet" />
    <link href="~/Views/mellow-1.0.0/mellow-1.0.0/style.css" rel="stylesheet" />
    <link href="~/Views/mellow-1.0.0/mellow-1.0.0/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Views/mellow-1.0.0/mellow-1.0.0/css/vendor.css" rel="stylesheet" />
    <link href="~/Content/DepartamentoClientes/site.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    @Scripts.Render("~/bundles/modernizr")
    @RenderSection("Styles", required: false)
    <style>
        html, body {
            height: 100vh;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1030;
            background-color: #fff;
        }
        .body-content {
            position: relative;
            margin-top: 160px;
            padding: 20px;
            min-height: calc(100vh - 160px - 400px);
        }

        .header-top {
            padding: 2px 0 !important;
            font-size: 0.8em;
        }

        .header-top .info li {
            margin-right: 15px !important;
        }

        #primary-header {
            padding: 5px 0 !important;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            padding: 0;
        }

        .navbar-brand img {
            max-height: 50px;
            width: auto;
        }

        .navbar-nav {
            gap: 5px;
        }

        .nav-link {
            padding: 5px 10px !important;
            font-size: 0.9em;
        }

        .dropdown-menu {
            margin-top: 0;
            border-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            border: none;
            padding: 5px 0;
        }

        .dropdown-item {
            font-size: 0.9em;
            padding: 5px 15px;
        }

        .search {
            max-width: 200px;
        }

        .search .form-control {
            height: 32px;
            font-size: 0.9em;
        }

        @@media (max-width: 991px) {
            .header-top {
                display: none;
            }

            #primary-header {
                padding: 5px 0 !important;
            }

            .navbar-brand img {
                max-height: 40px;
            }

            .navbar-toggler {
                padding: 4px 8px;
            }

            .offcanvas-body {
                padding: 10px;
            }

            .nav-link {
                padding: 8px 15px !important;
            }
        }

        .body-content {
            /* flex-grow: 1;*/
            box-sizing: border-box;
            margin-top: 100px;
            /*margin-bottom: 400px;*/
            padding: 20px;
            box-sizing: border-box;
            min-height: calc(100vh-140px);
        }

        .header-top .info li {
            margin-right: 15px !important;
        }

        #primary-header {
            padding: 5px 0 !important;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            padding: 0;
        }

            .navbar-brand img {
                max-height: 50px;
                width: auto;
            }

        .navbar-nav {
            gap: 5px;
        }

        .nav-link {
            padding: 5px 10px !important;
            font-size: 0.9em;
        }

        .dropdown-menu {
            margin-top: 0;
            border-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            border: none;
            padding: 5px 0;
        }

        .dropdown-item {
            font-size: 0.9em;
            padding: 5px 15px;
        }

        .search {
            max-width: 200px;
        }

            .search .form-control {
                height: 32px;
                font-size: 0.9em;
            }

        @@media (max-width: 991px) {
            .header-top {
                display: none;
            }

            #primary-header {
                padding: 5px 0 !important;
            }

            .navbar-brand img {
                max-height: 40px;
            }

            .navbar-toggler {
                padding: 4px 8px;
            }

            .offcanvas-body {
                padding: 10px;
            }

            .nav-link {
                padding: 8px 15px !important;
            }
        }

        .body-content {
            margin-top: 120px;
        }

        @@media (max-width: 991px) {
            .body-content {
                margin-top: 80px;
            }
        }

        #footer {
            position: fixed;
            left: 0;
            bottom: 0;
            width: 100%;
            background-color: #f8f9fa;
            padding: 2px 0;
            z-index: 10;
            box-sizing: border-box;
        }

            #footer img {
                max-width: 40px;
                height: auto;
            }

            #footer .small {
                font-size: 0.85em;
            }

            #footer a {
                text-decoration: none;
            }

            #footer .row {
                margin: 0;
                padding: 0;
            }

        @@media (max-width: 768px) {
            #footer {
                position: relative;
                margin-top: 10px;
            }

            .body-content {
                margin-bottom: 0;
                padding-bottom: 60px;
            }
        }

        #footer img {
            max-width: 40px;
            height: auto;
        }

        #footer .small {
            font-size: 0.85em;
        }

        #footer a {
            text-decoration: none;
        }

        #footer .row {
            margin: 0;
            padding: 0;
        }

        @@media (max-width: 768px) {
            #footer {
                position: relative;
                margin-top: 10px;
            }
            
            .body-content {
                margin-bottom: 0;
                padding-bottom: 60px;
            }
        }

        #footer img {
            max-width: 40px;
            height: auto;
        }

        #footer .small {
            font-size: 0.85em;
        }

        #footer a {
            text-decoration: none;
        }

        #footer .row {
            margin: 0;
            padding: 0;
        }

        @@media (max-width: 768px) {
            #footer {
                position: relative;
                margin-top: 10px;
            }
            
            .body-content {
                margin-bottom: 0;
                padding-bottom: 60px;
            }
        }

        #footer img {
            max-width: 40px;
            height: auto;
        }

        #footer .small {
            font-size: 0.85em;
        }

        #footer a {
            text-decoration: none;
        }

        #footer .row {
            margin: 0;
            padding: 0;
        }

        @@media (max-width: 768px) {
            #footer {
                position: relative;
                margin-top: 10px;
            }
            
            .body-content {
                margin-bottom: 0;
                padding-bottom: 60px;
            }
        }
    </style>
</head>
<body>
    <header id="header">
        <nav class="header-top bg-secondary py-1">
            <div class="container-fluid padding-side">
                <div class="d-flex flex-wrap justify-content-between align-items-center">
                    <ul class="info d-flex flex-wrap list-unstyled m-0">
                        <li class="location text-capitalize d-flex align-items-center me-4" style="font-size: 14px;">
                            <svg class="color me-1" width="15" height="15">
                                <use xlink:href="#location"></use>
                            </svg>Torre Mercedes, 300m North, 100m West, 100m North of, San José, 10102
                        </li>
                        <li class="phone d-flex align-items-center me-4" style="font-size: 14px;">
                            <svg class="color me-1" width="15" height="15">
                                <use xlink:href="#phone"></use>
                            </svg>2256-0106
                        </li>
                        <li class="time d-flex align-items-center me-4" style="font-size: 14px;">
                            <svg class="color me-1" width="15" height="15">
                                <use xlink:href="#email"></use>
                            </svg>info@pradoinn.com
                        </li>
                    </ul>
                    <ul class="social-links d-flex flex-wrap list-unstyled m-0 ">
                        <li class="social">
                            <a href="https://www.facebook.com/share/19uV5QTfRa/?mibextid=LQQJ4d">
                                <svg class="social" width="16" height="16">
                                    <use xlink:href="#facebook"></use>
                                </svg>
                            </a>
                        </li>
                        <li class="social ms-4">
                            <a href="#">
                                <svg class="social" width="16" height="16">
                                    <use xlink:href="#instagram"></use>
                                </svg>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        <nav id="primary-header" class="navbar navbar-expand-lg py-4 navbar-dark bg-dark">
            <div class="container-fluid padding-side">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">

                    <img src="~/Img/images/main-Prado-removebg-preview.png"
                         class="img-fluid logo"
                         alt="Logo"
                         style="max-width: 100px; height: auto; display: block;">
                </a>
                <button class="navbar-toggler border-0 d-flex d-lg-none order-3 p-2 shadow-none" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#bdNavbar" aria-controls="bdNavbar" aria-expanded="false">
                    <svg class="navbar-icon" width="60" height="60">
                        <use xlink:href="#navbar-icon"></use>
                    </svg>
                </button>
                <div class="header-bottom offcanvas offcanvas-end" id="bdNavbar" aria-labelledby="bdNavbarOffcanvasLabel">
                    <div class="offcanvas-header px-4 pb-0">
                        <button type="button" class="btn-close btn-close-black mt-2" data-bs-dismiss="offcanvas"
                                aria-label="Close" data-bs-target="#bdNavbar"></button>
                    </div>
                    <div class="offcanvas-body align-items-center justify-content-center">
                        <ul class="navbar-nav align-items-center mb-2 mb-lg-0">
                            <li class="nav-item px-3">
                                @Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item px-3">
                                @Html.ActionLink("Habitaciones", "habitacionesInfo", "Habitacion", new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item px-3">
                                @Html.ActionLink("Departamentos", "IndexDepartamentosClientes", "Departamento", new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item px-3">
                                @Html.ActionLink("Acerca de", "About", "Home", new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item px-3">
                                @Html.ActionLink("Servicios", "Services", "Home", new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item px-3">
                                @Html.ActionLink("Blog", "Blog", "Home", new { area = "" }, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item px-3">
                                @Html.ActionLink("Contact", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })
                            </li>

                            <!-- Opciones del administrador -->
                            <li class="nav-item dropdown px-3">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Administrador
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                    <li>@Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Departamentos", "IndexDepartamentos", "Departamento", new { area = "" }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Colaboradores", "IndexColaborador", "Colaborador", new { area = "" }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Habitaciones", "IndexHabitaciones", "Habitacion", new { area = "" }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Reservas", "IndexReservasA", "ReservasA", new { area = "" }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Mantenimientos", "IndexMantenimiento", "Mantenimiento", new { area = "" }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Bitácora de Eventos", "IndexBitacoraEventos", "Bitacora", new { area = "" }, new { @class = "dropdown-item" })</li>
                                </ul>
                            </li>

                        </ul>
                    </div>
                </div>

                <!-- Formulario de búsqueda -->
                <div class="search d-lg-block d-none">
                    <form class="position-relative">
                        <input type="text" class="form-control bg-secondary border-0 rounded-5 px-4 py-2" placeholder="Search...">
                        <a href="#" class="position-absolute top-50 end-0 translate-middle-y p-1 me-3">
                            <svg width="20" height="20">
                                <use xlink:href="#search"></use>
                            </svg>
                        </a>
                    </form>
                </div>

                <!-- Login -->
                @Html.Partial("_LoginPartial")
            </div>
        </nav>
    </header>
    <div class="container body-content">
        @RenderBody()
        <hr />

        <section id="footer" class="bg-light text-dark mt-5 w-100">
            <div class="padding-side padding-small pt-2 px-3" data-aos="fade-up">
                <footer class="row justify-content-between align-items-center">
                    <!-- Logo y descripción -->
                    <div class="col-md-3 text-center text-md-start d-flex align-items-center">
                        <img src="~/Img/images/main-Prado-removebg-preview.png" style="max-width: 50px; height: auto;" alt="logo-footer" class="img-fluid me-2">
                        <div class="d-none d-md-block">
                            <p class="small mb-0">Hotel Prado Inn Suites</p>
                        </div>
                    </div>

                    <!-- Información de contacto -->
                    <div class="col-md-5 text-center my-1">
                        <span class="small me-3"><i class="fas fa-phone"></i> +506 2256-0106</span>
                        <span class="small"><i class="fas fa-envelope"></i> info@pradoinn.com</span>
                    </div>

                    <!-- Redes sociales -->
                    <div class="col-md-3 text-center text-md-end">
                        <a href="#" class="text-dark me-2"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-dark me-2"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-dark"><i class="fab fa-twitter"></i></a>
                    </div>
                </footer>
            </div>

            <!-- Copyright -->
            <div class="text-center py-1">
                <p class="small m-0">© 2024 Hotel Prado Inn Suites</p>
            </div>
        </section>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script src="~/Scripts/bootstrap-datepicker.min.js"></script>
    <script src="~/Scripts/flatpickr.js"></script>
    <script src="~/Scripts/bootstrap.bundle.js"></script>
    <a href="~/Scripts/bootstrap.bundle.js.map"></a>
    <script src="js/jquery-1.11.0.min.js"></script>
    <script type="text/javascript" src="js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript" src="js/plugins.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script type="text/javascript" src="js/script.js"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>


