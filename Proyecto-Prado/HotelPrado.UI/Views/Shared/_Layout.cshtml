    <!-- Evitar doble envío: deshabilitar botones y mostrar "Cargando..." al enviar formularios (script protegido para no romper la página) -->
    <script>
        (function() {
            try {
                document.addEventListener('submit', function(e) {
                    try {
                        var form = e && e.target;
                        if (!form || form.tagName !== 'FORM') return;
                        var btns = form.querySelectorAll('button[type="submit"], input[type="submit"], input[type="image"]');
                        setTimeout(function() {
                            try {
                                if (!form.ownerDocument || form.ownerDocument !== document) return;
                                for (var i = 0; i < btns.length; i++) {
                                    var btn = btns[i];
                                    if (btn && !btn.disabled) {
                                        btn.disabled = true;
                                        btn.classList.add('btn-loading');
                                        btn.setAttribute('data-loading', '1');
                                    }
                                }
                                setTimeout(function() {
                                    try {
                                        if (!document.body || !form.parentNode) return;
                                        for (var j = 0; j < btns.length; j++) {
                                            var b = btns[j];
                                            if (b && b.getAttribute('data-loading') === '1') {
                                                b.disabled = false;
                                                b.classList.remove('btn-loading');
                                                b.removeAttribute('data-loading');
                                            }
                                        }
                                    } catch (err) { }
                                }, 3000);
                            } catch (err) { }
                        }, 100);
                    } catch (err) { }
                }, true);
            } catch (err) { }
        })();
    </script>
    
    <!-- SCRIPT FINAL - MANTENER FOOTER FUNCIONANDO -->
    <script>
        (function() {
            'use strict';
            function mantenerPosiciones() {
                var header = document.querySelector('header#header');
                var footer = document.querySelector('#footer, section#footer');
                
                // Navbar - Asegurar que esté RELATIVE (no fixed)
                if (header) {
                    header.style.setProperty('position', 'relative', 'important');
                    header.style.setProperty('width', '100%', 'important');
                }
                
                // Footer siempre relative (FUNCIONA - NO TOCAR)
                if (footer) {
                    footer.style.setProperty('position', 'relative', 'important');
                    footer.style.setProperty('bottom', 'auto', 'important');
                    footer.style.setProperty('margin-top', 'auto', 'important');
                }
                
                // Body sin padding
                document.body.style.setProperty('padding-top', '0', 'important');
                document.body.style.setProperty('padding-bottom', '0', 'important');
            }
            
            // Solo ejecutar una vez al cargar y en resize
            window.addEventListener('load', mantenerPosiciones);
            window.addEventListener('resize', mantenerPosiciones, { passive: true });
            mantenerPosiciones();
        })();
    </script>
