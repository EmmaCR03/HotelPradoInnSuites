@model HotelPrado.Abstracciones.Modelos.Configuracion.ConfiguracionPreciosDepartamentosDTO

@{
    ViewBag.Title = "Configurar Precios de Departamentos";
}

<style>
    .admin-panel {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: calc(100vh - 200px);
        padding: 2rem 0;
    }

    .panel-header {
        text-align: center;
        margin-bottom: 3rem;
        padding: 2rem 0;
    }

    .panel-header h1 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #2c3e50;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .config-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .config-card {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 2rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: #2c3e50;
        font-size: 1.1rem;
    }

    .form-group input[type="text"],
    .form-group input[type="number"] {
        width: 100%;
        padding: 0.875rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.3s;
    }

    .form-group input:focus {
        outline: none;
        border-color: #6D7BB8;
    }

    .form-group .input-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-group .input-group span {
        font-size: 1.25rem;
        color: #6c757d;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .checkbox-group input[type="checkbox"] {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

    .checkbox-group label {
        margin: 0;
        cursor: pointer;
    }

    .btn-save {
        background: linear-gradient(135deg, #6D7BB8, #5a6aa8);
        color: white;
        border: none;
        padding: 1rem 3rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(109, 123, 184, 0.4);
    }

    .btn-back {
        background: #6c757d;
        color: white;
        text-decoration: none;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 2rem;
        transition: all 0.3s;
    }

    .btn-back:hover {
        background: #5a6268;
        color: white;
        text-decoration: none;
    }

    .alert {
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .field-validation-error {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }

    .preview-section {
        background: #f8f9fa;
        padding: 2rem;
        border-radius: 12px;
        margin-top: 2rem;
        text-align: center;
    }

    .preview-section h3 {
        color: #2c3e50;
        margin-bottom: 1rem;
    }

    .preview-price {
        font-size: 3rem;
        font-weight: 700;
        color: #6D7BB8;
        margin: 1rem 0;
    }
</style>

<div class="admin-panel">
    <div class="panel-header">
        <h1><i class="fas fa-tag me-3" style="color: #6D7BB8;"></i>Configurar Precios de Departamentos</h1>
        <p>Edita los precios mostrados en la sección de departamentos</p>
    </div>

    <div class="config-container">
        <a href="@Url.Action("Configuraciones", "Admin")" class="btn-back">
            <i class="fas fa-arrow-left me-2"></i>Volver a Configuraciones
        </a>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-error" style="background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
                <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error" style="background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
                <i class="fas fa-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            </div>
        }

        <div class="config-card">
            @using (Html.BeginForm("ActualizarPreciosDepartamentos", "Admin", FormMethod.Post, new { @class = "precios-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.IdConfiguracion)

                <div class="form-group">
                    @Html.LabelFor(m => m.PrecioBase, "Precio Base (₡)")
                    <div class="input-group">
                        <span>₡</span>
                        @Html.TextBoxFor(m => m.PrecioBase, new { @type = "number", @step = "0.01", @min = "0", @class = "form-control" })
                    </div>
                    @Html.ValidationMessageFor(m => m.PrecioBase)
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.TextoPrecio, "Texto del Precio")
                    @Html.TextBoxFor(m => m.TextoPrecio, new { @class = "form-control", @placeholder = "Ej: Por mes" })
                    @Html.ValidationMessageFor(m => m.TextoPrecio)
                </div>

                <div class="form-group">
                    <div class="checkbox-group">
                        @Html.CheckBoxFor(m => m.MostrarPrecio, new { @id = "MostrarPrecio" })
                        @Html.LabelFor(m => m.MostrarPrecio, "Mostrar precio en la página de departamentos", new { @for = "MostrarPrecio" })
                    </div>
                </div>

                <button type="submit" class="btn-save">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
                <p class="mt-3 text-muted" style="font-size: 0.9rem; text-align: center;">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Nota:</strong> Después de guardar, recarga la página de Departamentos (Ctrl + F5) para ver los cambios.
                </p>
            }

            <div class="preview-section">
                <h3>Vista Previa</h3>
                <div class="preview-price" id="preview-price">₡@Model.PrecioBase.ToString("N0")</div>
                <p id="preview-text">@Model.TextoPrecio</p>
                <p id="preview-visibility" style="color: @(Model.MostrarPrecio ? "#28a745" : "#dc3545");">
                    <i class="fas fa-@(Model.MostrarPrecio ? "eye" : "eye-slash") me-2"></i>
                    @(Model.MostrarPrecio ? "Visible" : "Oculto")
                </p>
            </div>
        </div>
    </div>
</div>

<script>
    // Actualizar preview en tiempo real
    document.querySelector('#PrecioBase').addEventListener('input', function() {
        const value = parseFloat(this.value) || 0;
        document.querySelector('#preview-price').textContent = '₡' + value.toLocaleString('es-CR');
    });

    document.querySelector('#TextoPrecio').addEventListener('input', function() {
        document.querySelector('#preview-text').textContent = this.value || 'Por mes';
    });

    document.querySelector('#MostrarPrecio').addEventListener('change', function() {
        const preview = document.querySelector('#preview-visibility');
        if (this.checked) {
            preview.innerHTML = '<i class="fas fa-eye me-2"></i>Visible';
            preview.style.color = '#28a745';
        } else {
            preview.innerHTML = '<i class="fas fa-eye-slash me-2"></i>Oculto';
            preview.style.color = '#dc3545';
        }
    });
</script>

