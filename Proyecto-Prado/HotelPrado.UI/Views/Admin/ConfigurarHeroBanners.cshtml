@model List<HotelPrado.Abstracciones.Modelos.Configuracion.ConfiguracionHeroBannerDTO>

@{
    ViewBag.Title = "Configurar Hero Banners";
}

<style>
    .admin-panel {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: calc(100vh - 200px);
        padding: 2rem 0;
    }

    .panel-header {
        text-align: center;
        margin-bottom: 3rem;
        padding: 2rem 0;
    }

    .panel-header h1 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #2c3e50;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .banners-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .banner-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .banner-preview {
        flex: 0 0 300px;
        height: 200px;
        border-radius: 12px;
        overflow: hidden;
        background: #f0f0f0;
        position: relative;
    }

    .banner-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .banner-form {
        flex: 1;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #2c3e50;
    }

    .form-group input[type="text"] {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.3s;
    }
    
    .form-group input[type="file"] {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.3s;
        background: white;
    }

    .form-group input:focus {
        outline: none;
        border-color: #6D7BB8;
    }

    .btn-save {
        background: linear-gradient(135deg, #6D7BB8, #5a6aa8);
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(109, 123, 184, 0.4);
    }

    .btn-back {
        background: #6c757d;
        color: white;
        text-decoration: none;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 2rem;
        transition: all 0.3s;
    }

    .btn-back:hover {
        background: #5a6268;
        color: white;
        text-decoration: none;
    }

    .alert {
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .page-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }
</style>

<div class="admin-panel">
    <div class="panel-header">
        <h1><i class="fas fa-image me-3" style="color: #6D7BB8;"></i>Configurar Hero Banners</h1>
        <p>Cambia las imágenes de los hero banners en las diferentes páginas. Para configurar galerías (Apartamentos, Instalaciones, Habitaciones) use <a href="@Url.Action("ConfigurarGaleriaUsuarios", "Admin")">Configurar galería usuarios</a>.</p>
    </div>

    <div class="banners-container">
        @Html.AntiForgeryToken()
        <a href="@Url.Action("Configuraciones", "Admin")" class="btn-back">
            <i class="fas fa-arrow-left me-2"></i>Volver a Configuraciones
        </a>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-error" style="background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
                <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            </div>
        }

        @foreach (var banner in Model)
        {
            <div class="banner-card" data-id="@banner.IdConfiguracion">
                <div class="banner-preview">
                    <img src="@Url.Content(banner.UrlImagen)" alt="@banner.Pagina" onerror="this.src='@Url.Content("~/Img/images/default.jpg")'">
                </div>
                <div class="banner-form">
                    <div class="page-name">
                        <i class="fas fa-file-alt me-2"></i>@banner.Pagina
                    </div>
                    <div class="form-group">
                        <label>Subir Imagen desde tu Computadora:</label>
                        <input type="file" class="file-input" data-id="@banner.IdConfiguracion" accept="image/*,.heic,image/heic" onchange="previewImage(this, @banner.IdConfiguracion)">
                        <small class="text-muted d-block mt-2">O ingresa una URL:</small>
                        <input type="text" class="url-input mt-2" value="@banner.UrlImagen" data-id="@banner.IdConfiguracion" placeholder="/Img/images/ejemplo.jpg">
                    </div>
                    <button type="button" class="btn-save" onclick="guardarBanner(@banner.IdConfiguracion)">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                    @if (!string.IsNullOrEmpty(banner.ActualizadoPor))
                    {
                        <p style="margin-top: 0.5rem; font-size: 0.875rem; color: #6c757d;">
                            <i class="fas fa-clock me-1"></i>Última actualización: @banner.FechaActualizacion.ToString("dd/MM/yyyy HH:mm")
                        </p>
                    }
                </div>
            </div>
        }
    </div>
</div>

<script>
    function previewImage(input, id) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.querySelector(`.banner-card[data-id="${id}"] .banner-preview img`);
                preview.src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function guardarBanner(id) {
        const fileInput = document.querySelector(`input[type="file"][data-id="${id}"]`);
        const urlInput = document.querySelector(`input[type="text"][data-id="${id}"]`);
        const file = fileInput.files[0];
        const urlImagen = urlInput.value.trim();

        // Si hay archivo, subirlo primero
        if (file) {
            const formData = new FormData();
            formData.append('id', id);
            formData.append('imagen', file);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            // Mostrar loading
            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Subiendo...';
            btn.disabled = true;

            fetch('@Url.Action("SubirImagenHeroBanner", "Admin")', {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            })
            .then(function(response) {
                var ct = response.headers.get('Content-Type') || '';
                if (!response.ok || ct.indexOf('application/json') === -1) {
                    return response.text().then(function() {
                        throw new Error('La sesión pudo haber expirado o hubo un error. Recarga la página e intenta de nuevo.');
                    });
                }
                return response.json();
            })
            .then(function(data) {
                if (data.success) {
                    // Actualizar preview
                    const preview = document.querySelector(`.banner-card[data-id="${id}"] .banner-preview img`);
                    preview.src = data.urlImagen + '?t=' + new Date().getTime(); // Forzar recarga
                    
                    // Limpiar el input de archivo
                    fileInput.value = '';
                    
                    // Actualizar el input de URL
                    urlInput.value = data.urlImagen;
                    
                    mostrarMensaje('success', data.message + ' Recarga la página para ver los cambios en el sitio.');
                } else {
                    mostrarMensaje('error', data.message || 'Error al subir.');
                }
            })
            .catch(function(error) {
                mostrarMensaje('error', error.message || 'Error al subir. Recarga la página e intenta de nuevo.');
            })
            .finally(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        } else if (urlImagen) {
            // Si no hay archivo pero hay URL, usar el método anterior
            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Guardando...';
            btn.disabled = true;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            
            fetch('@Url.Action("ActualizarHeroBanner", "Admin")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'id=' + id + '&urlImagen=' + encodeURIComponent(urlImagen) + '&__RequestVerificationToken=' + encodeURIComponent(token),
                credentials: 'same-origin'
            })
            .then(function(response) {
                var ct = response.headers.get('Content-Type') || '';
                if (!response.ok || ct.indexOf('application/json') === -1) {
                    return response.text().then(function() {
                        throw new Error('La sesión pudo haber expirado. Recarga la página e intenta de nuevo.');
                    });
                }
                return response.json();
            })
            .then(function(data) {
                if (data.success) {
                    var preview = document.querySelector('.banner-card[data-id="' + id + '"] .banner-preview img');
                    if (preview) preview.src = urlImagen + '?t=' + new Date().getTime();
                    mostrarMensaje('success', data.message + ' Recarga la página para ver los cambios en el sitio.');
                } else {
                    mostrarMensaje('error', data.message || 'Error al guardar.');
                }
            })
            .catch(function(error) {
                mostrarMensaje('error', error.message || 'Error al guardar. Recarga la página e intenta de nuevo.');
            })
            .finally(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
            });
        } else {
            alert('Por favor sube una imagen o ingresa una URL');
        }
    }

    function mostrarMensaje(tipo, mensaje) {
        const alert = document.createElement('div');
        alert.className = `alert alert-${tipo === 'success' ? 'success' : 'error'}`;
        alert.innerHTML = `<i class="fas fa-${tipo === 'success' ? 'check' : 'exclamation'}-circle me-2"></i>${mensaje}`;
        const container = document.querySelector('.banners-container');
        const firstChild = container.querySelector('a.btn-back');
        if (firstChild && firstChild.nextSibling) {
            container.insertBefore(alert, firstChild.nextSibling);
        } else {
            container.insertBefore(alert, container.firstChild);
        }
        setTimeout(() => alert.remove(), 5000);
    }

    // Actualizar preview al escribir URL
    document.querySelectorAll('.url-input').forEach(input => {
        input.addEventListener('blur', function() {
            const id = this.getAttribute('data-id');
            const preview = document.querySelector(`.banner-card[data-id="${id}"] .banner-preview img`);
            if (this.value.trim()) {
                preview.src = this.value;
            }
        });
    });
</script>

