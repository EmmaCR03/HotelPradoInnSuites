@model IEnumerable<HotelPrado.Abstracciones.Modelos.Reservas.ReservasDTO>

@{
    ViewBag.Title = "IndexReservasA";
}

<style>
    body {
        margin: 0; /* Eliminar márgenes predeterminados del body */
        padding: 0 20px; /* Agregar padding a los laterales */
        overflow-x: hidden;
    }

    /* Contenedor principal centrado */
    .container-fluid {
        max-width: 100%;
        padding: 0 15px;
    }

    /* Tarjeta responsive y centrada */
    .card {
        width: 100%;
        max-width: 1600px; /* Máximo ancho pero puede ser menor */
        margin: 0 auto; /* Centrado horizontal */
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    /* Cuerpo de la tarjeta con padding adecuado */
    .card-body {
        padding: 1.25rem;
    }

    /* Contenedor de tabla responsive */
    .table-responsive {
        width: 100%;
        overflow-x: auto; /* Scroll horizontal solo cuando sea necesario */
        -webkit-overflow-scrolling: touch; /* Mejor scroll en móviles */
    }

    /* Tabla que se ajusta al contenido */
    .table {
        width: auto;
        min-width: 100%; /* Mínimo el ancho del contenedor */
        margin: 0 auto; /* Centrada dentro de su contenedor */
        table-layout: auto;
    }

        /* Estilos para celdas */
        .table th, .table td {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            padding: 12px 15px;
            vertical-align: middle;
        }

        /* Encabezados fijos al hacer scroll */
        .table thead th {
            position: sticky;
            top: 0;
            background-color: #f8f9fa;
            z-index: 10;
        }

    /* Estilos para el header */
    .page-header {
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 15px;
    }

    /* Badges para estados */
    .badge {
        font-size: 0.85em;
        padding: 0.5em 0.75em;
    }

    .bg-success {
        background-color: #28a745 !important;
    }

    .bg-warning {
        background-color: #ffc107 !important;
    }

    .bg-danger {
        background-color: #dc3545 !important;
    }

    .bg-secondary {
        background-color: #6c757d !important;
    }

    /* Media queries para responsividad */
    @@media (max-width: 768px) {
        .table th, .table td {
            padding: 8px 10px;
            font-size: 0.9rem;
        }

        .btn-group .btn {
            padding: 0.25rem 0.5rem;
            font-size: 0.8rem;
        }

        h2 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="container-fluid px-0">
    <div class="row justify-content-center my-4">
        <div class="col-12">
            <div class="page-header d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Gestión de Reservas</h2>

            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.First().IdReserva)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().IdCliente)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().cantidadPersonas)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().NombreCliente)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().IdHabitacion)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().FechaInicio)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().FechaFinal)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().EstadoReserva)</th>
                                    <th>@Html.DisplayNameFor(model => model.First().MontoTotal)</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(modelItem => item.IdReserva)</td>
                                        <td>@Html.DisplayFor(modelItem => item.IdCliente)</td>
                                        <td>@Html.DisplayFor(modelItem => item.cantidadPersonas)</td>
                                        <td>@Html.DisplayFor(modelItem => item.NombreCliente)</td>
                                        <td>@Html.DisplayFor(modelItem => item.IdHabitacion)</td>
                                        <td>@Html.DisplayFor(modelItem => item.FechaInicio)</td>
                                        <td>@Html.DisplayFor(modelItem => item.FechaFinal)</td>
                                        <td>
                                            <span class="badge rounded-pill @(item.EstadoReserva == "Completado" ? "bg-success" :
                                                                            item.EstadoReserva == "En Proceso" ? "bg-warning" :
                                                                            item.EstadoReserva == "Pendiente" ? "bg-danger" : "bg-secondary")">
                                                @item.EstadoReserva
                                            </span>
                                        </td>
                                        <td>@Html.DisplayFor(modelItem => item.MontoTotal)</td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Edit", new { IdReserva = item.IdReserva })" class="btn btn-sm btn-outline-primary" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/your-code.js" crossorigin="anonymous"></script>
}