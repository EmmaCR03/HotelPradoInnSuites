@model HotelPrado.UI.Models.IndexViewModel
@{
    ViewBag.Title = "Mi Perfil";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-body px-5 py-4">
                    <h2 class="fw-bold mb-4 text-primary">Mi Perfil</h2>

                    @if (!string.IsNullOrEmpty(ViewBag.StatusMessage))
                    {
                        <div class="alert alert-success rounded-3 shadow-sm">
                            @ViewBag.StatusMessage
                        </div>
                    }

                    <dl class="row fs-5">
                        <dt class="col-sm-5 fw-semibold">Nombre de usuario:</dt>
                        <dd class="col-sm-7">@Model.UserName</dd>

                        <dt class="col-sm-5 fw-semibold">Nombre completo:</dt>
                        <dd class="col-sm-7">@Model.NombreCompleto</dd>

                        <dt class="col-sm-5 fw-semibold">Correo electrónico:</dt>
                        <dd class="col-sm-7">@Model.Email</dd>

                        <dt class="col-sm-5 fw-semibold">Cédula:</dt>
                        <dd class="col-sm-7">@Model.Cedula</dd>

                        <dt class="col-sm-5 fw-semibold">Teléfono:</dt>
                        <dd class="col-sm-7">@Model.Telefono</dd>
                    </dl>

                    <hr />

                    <dl class="row fs-5">
                        <dt class="col-sm-5 fw-semibold">Contraseña:</dt>
                        <dd class="col-sm-7">
                            [
                            @if (Model.HasPassword)
                            {
                                @Html.ActionLink("Cambiar contraseña", "ChangePassword", null, new { @class = "link-primary text-decoration-none fw-semibold" })
                            }
                            else
                            {
                                @Html.ActionLink("Crear contraseña", "SetPassword", null, new { @class = "link-primary text-decoration-none fw-semibold" })
                            }
                            ]
                        </dd>

                       
                    </dl>

                    <div class="d-flex justify-content-between mt-5">
                        <a href="@Url.Action("ReservasUsuario", "Reservas")" class="btn btn-outline-primary px-4 py-2 rounded-3 shadow-sm fw-semibold">
                            Mis Reservas
                        </a>

                        @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger px-4 py-2 rounded-3 shadow-sm fw-semibold">
                                Cerrar Sesión
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
