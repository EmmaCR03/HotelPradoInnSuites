@model HotelPrado.UI.Models.IndexViewModel
@{
    ViewBag.Title = "Mi Perfil";
}

<div class="container-fluid py-5 bg-light">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-6">
            <div class="card shadow-lg rounded-4 overflow-hidden border-0">
                <!-- Card Header with Gradient Background -->
                <div class="card-header bg-gradient-primary py-4">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="avatar avatar-xl bg-white rounded-circle text-primary d-flex align-items-center justify-content-center">
                                <i class="fas fa-user fa-2x"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-4">
                            <h2 class="fw-bold text-white mb-1">Mi Perfil</h2>
                            <p class="text-white-50 mb-0">Administra tu información personal</p>
                        </div>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body px-4 py-4">
                    @if (!string.IsNullOrEmpty(ViewBag.StatusMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4">
                            @ViewBag.StatusMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- User Information Section -->
                    <div class="mb-5">
                        <h5 class="fw-bold text-uppercase text-muted mb-4">Información Personal</h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-3 bg-white rounded-3 shadow-sm">
                                    <label class="form-label text-muted small mb-1">Nombre completo</label>
                                    <p class="mb-0 fw-semibold fs-5">@Model.NombreCompleto</p>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="p-3 bg-white rounded-3 shadow-sm">
                                    <label class="form-label text-muted small mb-1">Teléfono</label>
                                    <p class="mb-0 fw-semibold fs-5">@Model.Telefono</p>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="p-3 bg-white rounded-3 shadow-sm">
                                    <label class="form-label text-muted small mb-1">Correo electrónico</label>
                                    <p class="mb-0 fw-semibold fs-5">@Model.Email</p>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="p-3 bg-white rounded-3 shadow-sm">
                                    <label class="form-label text-muted small mb-1">Cédula</label>
                                    <p class="mb-0 fw-semibold fs-5">@Model.Cedula</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Security Section -->
                    <div class="mb-4">
                        <h5 class="fw-bold text-uppercase text-muted mb-4">Seguridad</h5>

                        <div class="p-4 bg-white rounded-3 shadow-sm">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <label class="form-label text-muted small mb-1">Contraseña</label>
                                    <p class="mb-0 fw-semibold">•••••••••••</p>
                                </div>
                                <div>
                                    @if (Model.HasPassword)
                                    {
                                        @Html.ActionLink("Cambiar contraseña", "ChangePassword", null, new { @class = "btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold" })
                                    }
                                    else
                                    {
                                        @Html.ActionLink("Crear contraseña", "SetPassword", null, new { @class = "btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold" })
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between mt-5 pt-3 border-top">
                        <a href="@Url.Action("ReservasUsuario", "Reservas")" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-semibold">
                            <i class="fas fa-calendar-alt me-2"></i> Mis Reservas
                        </a>

                        @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger px-4 py-2 rounded-pill shadow-sm fw-semibold">
                                <i class="fas fa-sign-out-alt me-2"></i> Cerrar Sesión
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #3a7bd5 0%, #00d2ff 100%);
    }

    .avatar {
        width: 60px;
        height: 60px;
    }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .form-label {
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }
</style>