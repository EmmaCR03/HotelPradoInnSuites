@model HotelPrado.UI.Models.EditProfileViewModel
@{
    ViewBag.Title = "Editar Perfil";
}

<div class="container-fluid py-5 bg-light">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-6">
            <div class="card shadow-lg rounded-4 overflow-hidden border-0">
                <!-- Card Header -->
                <div class="card-header bg-gradient-primary py-4">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="avatar avatar-xl bg-white rounded-circle text-primary d-flex align-items-center justify-content-center">
                                <i class="fas fa-user-edit fa-2x"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-4">
                            <h2 class="fw-bold text-white mb-1">Editar Perfil</h2>
                            <p class="text-white-50 mb-0">Actualiza tu información personal y de contacto</p>
                        </div>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body px-4 py-4">
                    @using (Html.BeginForm("EditProfile", "Manage", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="mb-4">
                            <h5 class="fw-bold text-uppercase text-muted mb-4">Información Personal</h5>

                            <div class="row g-3">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.NombreCompleto, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control form-control-lg", placeholder = "Ingrese su nombre completo" })
                                        @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger small" })
                                    </div>
                                </div>

                                <div class="col-md-12">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg", type = "email", placeholder = "correo@ejemplo.com" })
                                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.Telefono, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control form-control-lg", placeholder = "12345678" })
                                        @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger small" })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.Cedula, new { @class = "form-label fw-semibold" })
                                        @Html.TextBoxFor(m => m.Cedula, new { @class = "form-control form-control-lg", placeholder = "123456789" })
                                        @Html.ValidationMessageFor(m => m.Cedula, "", new { @class = "text-danger small" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between mt-5 pt-3 border-top">
                            @Html.ActionLink("Cancelar", "Index", "Manage", null, new { @class = "btn btn-outline-secondary px-4 py-2 rounded-pill shadow-sm fw-semibold" })
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-semibold">
                                <i class="fas fa-save me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #3a7bd5 0%, #00d2ff 100%);
    }

    .avatar {
        width: 60px;
        height: 60px;
    }

    .card {
        transition: transform 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .form-control-lg {
        padding: 0.75rem 1rem;
        font-size: 1rem;
    }

    .form-label {
        font-size: 0.875rem;
        margin-bottom: 0.5rem;
    }
</style>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

