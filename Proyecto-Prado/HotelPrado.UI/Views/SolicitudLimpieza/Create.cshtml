@model HotelPrado.Abstracciones.Modelos.SolicitudLimpieza.SolicitudLimpiezaDTO

@{
    ViewBag.Title = "Solicitar Limpieza";
}

<style>
    .card {
        border: none;
        border-radius: 8px;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
    }

    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid rgba(0,0,0,.05);
        padding: 1rem 1.5rem;
    }

    .form-label {
        font-weight: 500;
        margin-bottom: .5rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border: 1px solid #dee2e6;
        padding: .5rem .75rem;
        font-size: 0.9rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #80bdff;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
        }

    .btn-primary {
        padding: .5rem 1.5rem;
        font-weight: 500;
    }

    .btn-secondary {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
        padding: .5rem 1.5rem;
        font-weight: 500;
    }

    .text-danger {
        font-size: 0.8rem;
        margin-top: .25rem;
    }
</style>

<div class="container-fluid px-4">
    <div class="row my-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0"><i class="fas fa-broom me-2"></i>Solicitar Limpieza</h2>
                <a href="@Url.Action("IndexSolicitudLimpieza")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Volver
                </a>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="row g-4">
                            @if (ViewBag.IdDepartamento == null && ViewBag.IdHabitacion == null)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="form-group">
                                        <label class="form-label">Tipo</label>
                                        <select id="tipoSeleccionado" name="tipoSeleccionado" class="form-select" onchange="toggleTipo()">
                                            <option value="">Seleccione un tipo</option>
                                            <option value="Departamento">Departamento</option>
                                            <option value="Habitacion">Habitación</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3" id="departamentoGroup" style="display: none;">
                                    <div class="form-group">
                                        <label class="form-label">Departamento</label>
                                        @Html.DropDownList("idDepartamento",
                                            (SelectList)ViewBag.Departamentos,
                                            "Seleccione un departamento",
                                            new { @class = "form-select", id = "idDepartamento" })
                                        @Html.ValidationMessageFor(model => model.idDepartamento, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3" id="habitacionGroup" style="display: none;">
                                    <div class="form-group">
                                        <label class="form-label">Habitación</label>
                                        @Html.DropDownList("idHabitacion",
                                            (SelectList)ViewBag.Habitaciones,
                                            "Seleccione una habitación",
                                            new { @class = "form-select", id = "idHabitacion" })
                                        @Html.ValidationMessageFor(model => model.idHabitacion, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            }
                            else
                            {
                                if (ViewBag.IdDepartamento != null)
                                {
                                    <div class="col-md-12 mb-3">
                                        <div class="alert alert-info">
                                            <i class="fas fa-building me-2"></i><strong>Departamento:</strong> @ViewBag.DepartamentoNombre
                                        </div>
                                        <input type="hidden" name="idDepartamento" value="@ViewBag.IdDepartamento" />
                                        <input type="hidden" name="idHabitacion" value="0" />
                                    </div>
                                }
                                else if (ViewBag.IdHabitacion != null)
                                {
                                    <div class="col-md-12 mb-3">
                                        <div class="alert alert-info">
                                            <i class="fas fa-bed me-2"></i><strong>Habitación:</strong> @ViewBag.HabitacionNombre
                                        </div>
                                        <input type="hidden" name="idHabitacion" value="@ViewBag.IdHabitacion" />
                                        <input type="hidden" name="idDepartamento" value="0" />
                                    </div>
                                }
                            }

                            <div class="col-md-12 mb-3">
                                <div class="form-group">
                                    @Html.LabelFor(model => model.Descripcion, "Descripción de la limpieza", new { @class = "form-label" })
                                    @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = "4", placeholder = "Ej: Limpieza general después del desalojo. Revisar baños, cambiar sábanas, limpiar áreas comunes, etc.\n\nO simplemente: 'Limpieza estándar - recién desalojado'" })
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Describa qué tipo de limpieza se requiere. Si es limpieza estándar después del desalojo, puede indicarlo brevemente.
                                    </small>
                                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="@Url.Action("IndexSolicitudLimpieza")" class="btn btn-secondary">
                                        <i class="fas fa-times me-2"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save me-2"></i>Guardar Solicitud
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        function toggleTipo() {
            var tipo = document.getElementById("tipoSeleccionado").value;
            var departamentoGroup = document.getElementById("departamentoGroup");
            var habitacionGroup = document.getElementById("habitacionGroup");
            var idDepartamento = document.getElementById("idDepartamento");
            var idHabitacion = document.getElementById("idHabitacion");

            if (tipo === "Departamento") {
                departamentoGroup.style.display = "block";
                habitacionGroup.style.display = "none";
                idHabitacion.value = "0";
                idDepartamento.required = true;
                idHabitacion.required = false;
            } else if (tipo === "Habitacion") {
                departamentoGroup.style.display = "none";
                habitacionGroup.style.display = "block";
                idDepartamento.value = "0";
                idDepartamento.required = false;
                idHabitacion.required = true;
            } else {
                departamentoGroup.style.display = "none";
                habitacionGroup.style.display = "none";
                idDepartamento.value = "0";
                idHabitacion.value = "0";
                idDepartamento.required = false;
                idHabitacion.required = false;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            // Si viene con ID, no hacer nada ya que está oculto
            // Si no viene con ID, inicializar el toggle
            @if (ViewBag.IdDepartamento == null && ViewBag.IdHabitacion == null)
            {
                <text>
                // No hay ID preseleccionado, dejar que el usuario seleccione
                </text>
            }
        });
    </script>
}

