@model HotelPrado.Abstracciones.Modelos.SolicitudLimpieza.SolicitudLimpiezaDTO

@{
    ViewBag.Title = "Editar Solicitud de Limpieza";
}

<style>
    :root {
        --hotel-primary: #6D7BB8;
        --hotel-gold: #D4AF37;
        --hotel-dark: #2c3e50;
    }

    .edit-container {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: calc(100vh - 200px);
        padding: 2rem 0;
    }

    .edit-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        max-width: 800px;
        margin: 0 auto;
    }

    .edit-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e9ecef;
    }

    .edit-header h2 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--hotel-dark);
        margin-bottom: 0.5rem;
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border-left: 4px solid var(--hotel-primary);
    }

    .info-box h4 {
        color: var(--hotel-dark);
        font-size: 1.1rem;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-box p {
        margin: 0.5rem 0;
        color: #6c757d;
    }

    .form-label {
        font-weight: 600;
        color: var(--hotel-dark);
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 2px solid #dee2e6;
        padding: 0.75rem;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--hotel-primary);
        box-shadow: 0 0 0 0.2rem rgba(109, 123, 184, 0.25);
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--hotel-primary), #8a9dd4);
        border: none;
        border-radius: 8px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #5a6ba8, var(--hotel-primary));
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(109, 123, 184, 0.4);
    }

    .btn-secondary {
        border-radius: 8px;
        padding: 0.75rem 2rem;
        font-weight: 600;
    }

    .status-badge {
        display: inline-block;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge.pendiente {
        background: #fee;
        color: #dc3545;
    }

    .status-badge.proceso {
        background: #fff8e1;
        color: #f57c00;
    }

    .status-badge.completado {
        background: #e8f5e9;
        color: #28a745;
    }
</style>

<div class="edit-container">
    <div class="container-fluid">
        <div class="edit-card">
            <div class="edit-header">
                <h2><i class="fas fa-broom me-2" style="color: var(--hotel-primary);"></i>Editar Solicitud de Limpieza</h2>
                <p class="text-muted mb-0">Actualiza el estado y la información de la solicitud</p>
            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
                @Html.HiddenFor(model => model.IdSolicitudLimpieza)
                @Html.HiddenFor(model => model.FechaSolicitud)

                <!-- Información de la Solicitud -->
                <div class="info-box">
                    <h4><i class="fas fa-info-circle"></i>Información de la Solicitud</h4>
                    <p><strong>ID:</strong> #@Model.IdSolicitudLimpieza</p>
                    @if (!string.IsNullOrEmpty(Model.DepartamentoNombre))
                    {
                        <p><strong>Ubicación:</strong> <i class="fas fa-building me-1"></i>@Model.DepartamentoNombre</p>
                    }
                    else if (!string.IsNullOrEmpty(Model.HabitacionNombre))
                    {
                        <p><strong>Ubicación:</strong> <i class="fas fa-bed me-1"></i>@Model.HabitacionNombre</p>
                    }
                    @if (Model.FechaSolicitud.HasValue)
                    {
                        <p><strong>Fecha de Solicitud:</strong> @Model.FechaSolicitud.Value.ToString("dd/MM/yyyy HH:mm")</p>
                    }
                    <p>
                        <strong>Estado Actual:</strong> 
                        <span class="status-badge @(Model.Estado?.ToLower().Replace(" ", "") ?? "pendiente")">@Model.Estado</span>
                    </p>
                </div>

                <!-- Descripción -->
                <div class="mb-4">
                    <label class="form-label">Descripción</label>
                    @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = "4", placeholder = "Describe los detalles de la limpieza requerida..." })
                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                </div>

                <!-- Estado -->
                <div class="mb-4">
                    <label class="form-label">Estado</label>
                    @Html.DropDownListFor(model => model.Estado,
                        (SelectList)ViewBag.Estados,
                        new { @class = "form-select" })
                    @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                    <small class="form-text text-muted">
                        <i class="fas fa-lightbulb me-1"></i>
                        <strong>Pendiente:</strong> Aún no se ha iniciado | 
                        <strong>En Proceso:</strong> Limpieza en curso | 
                        <strong>Completado:</strong> Limpieza finalizada
                    </small>
                </div>

                <!-- Botones de Acción -->
                <div class="d-flex justify-content-between align-items-center mt-4 pt-4 border-top">
                    <a href="@Url.Action("IndexSolicitudLimpieza")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Volver
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

