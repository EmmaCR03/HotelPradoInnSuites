	<connectionStrings>
		<add name="Contexto"
			 connectionString="Data Source=SQL5106.site4now.net;Initial Catalog=db_ac52da_pradoinn;User Id=db_ac52da_pradoinn_admin;Password=Prado2026!;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;MultipleActiveResultSets=True;Pooling=true;Min Pool Size=5;Max Pool Size=100"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="owin:AutomaticAppStartup" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- Correo para verificación de cuenta (evita registros con correos falsos). Gmail con contraseña de aplicación. -->
    <!-- IMPORTANTE: Cambiar luego por la cuenta de correo del hotel en producción. -->
    <add key="EmailSmtpHost" value="smtp.gmail.com" />
    <add key="EmailSmtpPort" value="587" />
    <add key="EmailSmtpUser" value="emmaga021203@gmail.com" />
    <add key="EmailSmtpPassword" value="rjsjrxvrhhlmkahu" />
    <add key="EmailSmtpSSL" value="true" />
    <add key="EmailFrom" value="emmaga021203@gmail.com" />
    <add key="EmailFromName" value="Hotel Prado" />
    <!-- Correo del admin: no requiere verificación y no se envían correos a esta dirección (no existe). -->
    <add key="EmailAdminException" value="adminHotel@hotelPrado.com" />
  </appSettings>
  <system.web>
    <!-- Sin machineKey: ASP.NET usa claves auto-generadas (local OK). Si en hosting la sesión no se mantiene tras login,
         añada en el Web.config del servidor un machineKey generado aquí: https://www.developmentnow.com/asp-net-machinekey-generator/ -->
    <!-- Permitir anónimos: en hosting (SmarterASP) a veces se hereda deny. Solo MVC [Authorize] restringe. -->
    <authorization>
      <allow users="?" />
      <allow users="*" />
    </authorization>
    <compilation debug="true" targetFramework="4.8.1" />
    <httpRuntime targetFramework="4.8.1" maxRequestLength="1048576" executionTimeout="600" />
    <globalization culture="es-CR" uiCulture="es-CR" requestEncoding="utf-8" responseEncoding="utf-8" fileEncoding="utf-8" />
    <!-- En publicación (Web.Release.config) se reemplaza para redirigir a ~/ y no a /Error -->
    <!-- Temporalmente Off para ver el error real al cargar /Account/Register. Volver a On cuando funcione. -->
    <customErrors mode="Off" defaultRedirect="~/Error">
      <error statusCode="404" redirect="~/Error" />
      <error statusCode="500" redirect="~/Error" />
    </customErrors>
  </system.web>
  <system.webServer>
    <!-- Evitar que el servidor muestre listado de carpetas (Views, Account, etc.) -->
    <directoryBrowse enabled="false" />
    <modules runAllManagedModulesForAllRequests="false" />
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="2147483648" />
      </requestFiltering>
    </security>
    <!-- Optimizaciones de rendimiento: Compresión -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    <!-- Optimizaciones de rendimiento: Caché estático + MIME types por si el servidor no los tiene -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
      <remove fileExtension=".css" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
    </staticContent>
    <!-- Application Initialization: Calienta la aplicación antes de recibir usuarios (solo en producción) -->
    <!-- Descomentar en producción si IIS lo soporta -->
    <!--
    <applicationInitialization 
      doAppInitAfterRestart="true" 
      skipManagedModules="true">
      <add initializationPage="/" />
    </applicationInitialization>
    -->
  </system.webServer>
