<?xml version="1.0" encoding="utf-8"?>

<!--
  Transformación para DEPURACIÓN (F5 en Visual Studio).
  - En local, Login/Registro pueden fallar si la BD del hosting (SQL5106) no es accesible
    (firewall, sin internet, timeout). Si quieres usar una BD local:
  1. Crea una base de datos local (LocalDB o SQL Express) con las mismas tablas.
  2. Descomenta la sección connectionStrings más abajo y ajusta "Data Source" a tu instancia.
  3. La publicación (Release) sigue usando la cadena del Web.config base o Web.Release.config.
-->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <!--
  OPCIONAL: Usar BD local en desarrollo. Descomenta y ajusta si tienes LocalDB/SQL Express.
  <connectionStrings>
    <add name="Contexto"
         connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=HotelPradoLocal;Integrated Security=True;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient"
         xdt:Transform="SetAttributes" xdt:Locator="Match(name)" />
  </connectionStrings>
  -->
  <system.web>
    <!--
      En el siguiente ejemplo, la transformación de "Replace" reemplazará toda la sección de
      <customErrors> del archivo Web.config.
      Tenga en cuenta que dado que solo hay una sesión customErrors en el nodo 
      <system.web>, no es necesario usar el atributo "xdt:Locator".

      <customErrors defaultRedirect="GenericError.htm"
        mode="RemoteOnly" xdt:Transform="Replace">
        <error statusCode="500" redirect="InternalError.htm"/>
      </customErrors>
    -->
  </system.web>
</configuration>
